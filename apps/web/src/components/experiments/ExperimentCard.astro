---
/**
 * ExperimentCard.astro — Experiment preview card for the labs grid
 *
 * Used in: experiments/index.astro (full grid), index.astro (latest 3 on homepage)
 *
 * Props:
 *  experiment — frontmatter from the experiment's Content Collection entry.
 *               title, summary, status, stack are required; mainImage is optional
 *               (not currently rendered — reserved for future use).
 *  slug       — the experiment's URL slug (passed from the parent page alongside
 *               the frontmatter since data and slug live on separate keys of
 *               the collection entry).
 *
 * Status badge:
 *  Colour-coded via statusColors map: active → accent blue, completed → warm,
 *  archived → muted. The map must be kept in sync with the Zod schema in
 *  content/config.ts.
 *
 * Stack chips:
 *  Only the first 3 stack items are shown; overflow count is displayed as "+N".
 *  This keeps cards visually consistent regardless of how many stack items an
 *  experiment lists.
 */

interface Props {
  experiment: {
    title: string;
    summary: string;
    status: 'active' | 'completed' | 'archived';
    stack: string[];
    mainImage?: string;
  };
  slug: string;
}

const { experiment, slug } = Astro.props;

const statusColors = {
  active: 'text-accent border-accent/20 bg-accent/5',
  completed: 'text-accent-warm border-accent-warm/20 bg-accent-warm/5',
  archived: 'text-text-muted border-border/20 bg-bg-elevated',
};
---

<a 
  href={`/experiments/${slug}`}
  class="experiment-card group relative block p-5 md:p-6 bg-bg-surface border border-border rounded-xl transition-all duration-300 hover:border-accent/50 opacity-100"
>
  <div class="flex flex-col h-full justify-between gap-6">
    <div class="space-y-4">
      <div class="flex justify-between items-center">
        <span class={`text-[10px] uppercase tracking-widest font-mono border px-2 py-1 rounded-md ${statusColors[experiment.status]}`}>
          {experiment.status}
        </span>
      </div>

      <h3 class="text-2xl font-heading font-medium text-text-primary group-hover:text-accent transition-colors">
        {experiment.title}
      </h3>
      
      <p class="text-sm text-text-secondary leading-relaxed">
        {experiment.summary}
      </p>
    </div>

    <div class="space-y-4">
      <div class="flex flex-wrap gap-2">
        {experiment.stack.slice(0, 3).map((item) => (
          <span class="text-[10px] text-text-muted font-mono bg-bg-elevated px-2 py-1 rounded border border-border-subtle">
            {item}
          </span>
        ))}
        {experiment.stack.length > 3 && (
          <span class="text-[10px] text-text-muted font-mono px-1">+{experiment.stack.length - 3}</span>
        )}
      </div>
    </div>
  </div>
</a>
