---
/**
 * ExperimentCard.astro — Experiment preview card for the labs grid
 *
 * Used in: experiments/index.astro (full grid), index.astro (latest 3 on homepage)
 *
 * Props:
 *  experiment — frontmatter from the experiment's Content Collection entry.
 *               title, summary, status, stack are required; mainImage is optional
 *               (not currently rendered — reserved for future use).
 *  slug       — the experiment's URL slug (passed from the parent page alongside
 *               the frontmatter since data and slug live on separate keys of
 *               the collection entry).
 *
 * Status badge:
 *  Colour-coded via statusColors map: active → accent blue, completed → warm,
 *  archived → muted. The map must be kept in sync with the Zod schema in
 *  content/config.ts.
 *
 * Stack chips:
 *  Only the first 3 stack items are shown; overflow count is displayed as "+N".
 *  This keeps cards visually consistent regardless of how many stack items an
 *  experiment lists.
 */

interface Props {
  experiment: {
    title: string;
    summary: string;
    status: 'active' | 'completed' | 'archived';
    stack: string[];
    mainImage?: string;
  };
  slug: string;
}

const { experiment, slug } = Astro.props;

const statusColors = {
  active: 'text-accent border-accent/20 bg-accent/5',
  completed: 'text-accent-warm border-accent-warm/20 bg-accent-warm/5',
  archived: 'text-text-muted border-border/20 bg-bg-elevated',
};
---

<a
  href={`/experiments/${slug}/`}
  class="experiment-card group relative block p-5 md:p-6 bg-bg-surface border border-border rounded-xl transition-all duration-300 hover:border-accent/50 hover:shadow-2xl hover:shadow-accent/5 opacity-100"
>
  <!-- Mouse-tracking glow layer, mirrors PostCard; radial gradient defined in <style> below -->
  <div class="glow-layer pointer-events-none absolute -inset-px rounded-xl opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

  <div class="relative z-10 flex flex-col h-full justify-between gap-6">
    <div class="space-y-4">
      <div class="flex justify-between items-center">
        <span class={`text-[10px] uppercase tracking-widest font-mono border px-2 py-1 rounded-md ${statusColors[experiment.status]}`}>
          {experiment.status}
        </span>
      </div>

      <h3 class="text-2xl font-heading font-medium text-text-primary group-hover:text-accent transition-colors">
        {experiment.title}
      </h3>
      
      <p class="text-sm text-text-secondary leading-relaxed">
        {experiment.summary}
      </p>
    </div>

    <div class="space-y-4">
      <div class="flex flex-wrap gap-2">
        {experiment.stack.slice(0, 3).map((item) => (
          <span class="text-[10px] text-text-muted font-mono bg-bg-elevated px-2 py-1 rounded border border-border-subtle">
            {item}
          </span>
        ))}
        {experiment.stack.length > 3 && (
          <span class="text-[10px] text-text-muted font-mono px-1">+{experiment.stack.length - 3}</span>
        )}
      </div>
    </div>
  </div>
</a>

<script>
  /**
   * initExperimentCards — entrance animation, mouse glow, and 3D tilt.
   *
   * Mirrors PostCard's pattern so both card types feel identical on interaction.
   * ExperimentCard had no JS previously — this adds parity with PostCard:
   *  1. Motion One inView() fade-up entrance (once per element via _animated guard)
   *  2. CSS-var-driven radial gradient glow following the cursor (.glow-layer)
   *  3. 3D perspective tilt (up to ±8°) following the cursor
   *
   * Bound to astro:after-swap so re-queried after View Transitions; _animated
   * and _tiltInitialized flags prevent double-binding.
   */
  import { animate, inView } from "motion";

  const initExperimentCards = () => {
    const cards = document.querySelectorAll(".experiment-card");
    const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    cards.forEach((card) => {
      // 1. Entrance animation — fade + slide up once per element
      if (!isReducedMotion && !(card as any)._animated) {
        (card as any)._animated = true;
        inView(card, () => {
          animate(
            card,
            { opacity: [0, 1], y: [20, 0] },
            { duration: 0.6, easing: [0.22, 1, 0.36, 1] }
          );
        });
      }

      // 2 + 3. Glow tracking and 3D tilt — both on mousemove.
      // Performance: rect cached on mouseenter; DOM writes RAF-gated (max 60/s).
      if (!(card as any)._tiltInitialized) {
        (card as any)._tiltInitialized = true;

        let rect = card.getBoundingClientRect();
        let rafPending = false;
        let isHovered = false;
        let pendingX = 0;
        let pendingY = 0;

        card.addEventListener("mouseenter", () => {
          isHovered = true;
          rect = card.getBoundingClientRect();
        });

        card.addEventListener("mousemove", (e: any) => {
          pendingX = e.clientX - rect.left;
          pendingY = e.clientY - rect.top;

          if (!rafPending) {
            rafPending = true;
            requestAnimationFrame(() => {
              // Guard: mouseleave may have fired in the 16ms window before this runs.
              if (isHovered) {
                (card as HTMLElement).style.setProperty("--mouse-x", `${pendingX}px`);
                (card as HTMLElement).style.setProperty("--mouse-y", `${pendingY}px`);

                if (!isReducedMotion) {
                  const rotateY = ((pendingX - rect.width / 2) / (rect.width / 2)) * 8;
                  const rotateX = ((rect.height / 2 - pendingY) / (rect.height / 2)) * 8;
                  (card as HTMLElement).style.transform =
                    `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px)`;
                }
              }
              rafPending = false;
            });
          }
        }, { passive: true });

        card.addEventListener("mouseleave", () => {
          isHovered = false;
          if (!isReducedMotion) {
            (card as HTMLElement).style.transform = '';
          }
        });
      }
    });
  };

  initExperimentCards();
  document.addEventListener('astro:after-swap', initExperimentCards);
</script>

<style>
  .experiment-card {
    /* 3D tilt setup — preserve-3d enables rotateX/rotateY perspective;
       will-change hints the browser to promote the card to its own GPU layer */
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* Radial gradient glow following --mouse-x / --mouse-y (updated by JS).
     Defaults to (0, 0) so there's no flash before the first mousemove. */
  .experiment-card .glow-layer {
    background: radial-gradient(
      400px circle at var(--mouse-x, 0px) var(--mouse-y, 0px),
      rgba(255, 255, 255, 0.05),
      transparent 40%
    );
  }
</style>
