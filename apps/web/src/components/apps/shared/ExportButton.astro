---
interface Props {
  filename?: string;
  label?: string;
}

const { filename = 'export.csv', label = 'Export CSV' } = Astro.props;
---

<button
  class="export-btn inline-flex items-center gap-2 px-4 py-2 rounded-full bg-bg-elevated border border-border
         text-[10px] font-mono uppercase tracking-widest text-text-secondary
         hover:border-accent hover:text-accent transition-all"
  data-filename={filename}
  aria-label={label}
>
  ↓ <span>{label}</span>
</button>

<script>
  const initExportButtons = () => {
    document.querySelectorAll<HTMLButtonElement>('.export-btn').forEach(btn => {
      if ((btn as any)._exportInit) return;
      (btn as any)._exportInit = true;

      btn.addEventListener('click', () => {
        document.dispatchEvent(new CustomEvent('app:export', {
          detail: { filename: btn.dataset.filename },
        }));
      });
    });
  };

  initExportButtons();
  document.addEventListener('astro:after-swap', initExportButtons);
</script>
