---
import AttributionFooter from './AttributionFooter.astro';
import ExportButton from './shared/ExportButton.astro';
import CopyButton from './shared/CopyButton.astro';
import ResetButton from './shared/ResetButton.astro';

interface Props {
  title: string;
  job: string;
  category: string;
  slug: string;
  lastVerified?: string;
  companionPostSlug?: string;
  license?: string;
  exportFilename?: string;
}

const {
  title,
  job,
  category,
  slug,
  lastVerified,
  companionPostSlug,
  license = 'MIT',
  exportFilename = `${slug}-export.csv`,
} = Astro.props;

const categoryLabels: Record<string, string> = {
  ai: 'AI', infra: 'Infra', ev: 'EV', trading: 'Trading', dev: 'Dev', finance: 'Finance',
};
---

<div class="space-y-8">
  <!-- Header -->
  <div class="space-y-4">
    <div class="flex items-center gap-3">
      <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-accent">
        {categoryLabels[category] ?? category}
      </span>
      <span class="text-border text-xs">·</span>
      <span class="text-[10px] font-mono uppercase tracking-[0.3em] text-text-muted">Free Tool</span>
    </div>
    <h1 class="text-3xl lg:text-5xl font-heading font-medium text-text-primary tracking-tighter">{title}</h1>
    <p class="text-text-secondary text-lg leading-relaxed max-w-2xl">{job}</p>
  </div>

  <!-- Toolbar -->
  <div class="flex flex-wrap items-center gap-3 py-4 border-y border-border-subtle">
    <ExportButton filename={exportFilename} />
    <CopyButton label="Copy Result" />
    <button
      id="btn-share"
      class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-bg-elevated border border-border
             text-[10px] font-mono uppercase tracking-widest text-text-secondary
             hover:border-accent hover:text-accent transition-all"
      aria-label="Share link"
    >
      ⤢ <span id="share-label">Share Link</span>
    </button>
    <ResetButton />

    {lastVerified && (
      <span class="ml-auto text-[10px] font-mono text-text-muted">
        Data verified: {lastVerified}
      </span>
    )}
  </div>

  <!-- Calculator island slot -->
  <div class="relative py-4" id="calculator-island" style="opacity: 0;">
    <!-- Ambient Underglow -->
    <div class="absolute inset-x-0 -top-20 -bottom-20 bg-[radial-gradient(ellipse_at_center,var(--color-accent)_0%,transparent_60%)] opacity-5 pointer-events-none" aria-hidden="true"></div>
    
    <div class="relative z-10 glass-island">
      <slot />
    </div>
  </div>

  <!-- Methodology link -->
  {companionPostSlug && (
    <div class="pt-4">
      <a
        href={`/blog/${companionPostSlug}/`}
        class="inline-flex items-center gap-2 text-sm font-mono text-text-muted hover:text-accent transition-colors group"
      >
        Read the methodology
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
    </div>
  )}

  <!-- Attribution -->
  <AttributionFooter license={license} slug={slug} />
</div>

<script>
  const initShareButton = () => {
    const btn = document.getElementById('btn-share');
    const label = document.getElementById('share-label');
    if (!btn || (btn as any)._shareInit) return;
    (btn as any)._shareInit = true;

    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(window.location.href);
      if (label) { label.textContent = 'Copied!'; }
      setTimeout(() => { if (label) label.textContent = 'Share Link'; }, 1500);
    });
  };

  const initAppAnimations = async () => {
    const island = document.getElementById('calculator-island');
    if (!island || (island as any)._animInit) return;
    (island as any)._animInit = true;

    try {
      const { gsap } = await import('gsap');
      gsap.to(island, { opacity: 1, duration: 0.1 });
      
      const targets = island.querySelectorAll('.glass-island > div > *, .glass-island > * > div, input, select, button');
      if(targets.length > 0) {
        gsap.from(targets, {
          y: 20,
          opacity: 0,
          stagger: 0.02,
          ease: "power2.out",
          duration: 0.4,
          clearProps: "all"
        });
      }
    } catch (e) {
      if(island) island.style.opacity = '1';
    }
  };

  initShareButton();
  initAppAnimations();
  document.addEventListener('astro:after-swap', () => {
    initShareButton();
    initAppAnimations();
  });
</script>
