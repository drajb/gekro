---
import {
  CLOUD_MODELS, LOCAL_MODELS, LOCAL_HARDWARE,
  ELECTRICITY_RATE_DEFAULT_USD_KWH,
} from './data';

// Default model selections for API tab (cheapest across all three providers)
const DEFAULT_SELECTED = ['claude-haiku-4-5', 'gpt-5-4-mini', 'gemini-2-5-flash'];
const DEFAULT_INPUT_PER_DAY = 500_000;
const DEFAULT_OUTPUT_PER_DAY = 100_000;
const DEFAULT_CACHE_HIT = 30;
const DEFAULT_HARDWARE = 'rtx-5060ti-16gb';
const DEFAULT_LOCAL_MODEL = 'llama-3-1-8b';
const DEFAULT_AMORT_YEARS = 3;
const DEFAULT_ELECTRICITY = ELECTRICITY_RATE_DEFAULT_USD_KWH * 100; // store as cents in UI
---

<div id="llm-calc" class="space-y-6">

  <!-- Tab bar -->
  <div class="flex gap-1 bg-bg-elevated p-1 rounded-xl border border-border" role="tablist">
    {[
      { id: 'api',     label: 'API Cost' },
      { id: 'local',   label: 'Local Hardware' },
      { id: 'compare', label: 'Break-even' },
    ].map(tab => (
      <button
        role="tab"
        aria-selected={tab.id === 'api' ? 'true' : 'false'}
        data-tab={tab.id}
        class={`calc-tab flex-1 py-2.5 px-3 text-[10px] font-mono uppercase tracking-widest rounded-lg transition-all
                ${tab.id === 'api'
                  ? 'bg-bg-surface text-accent border border-border shadow-sm'
                  : 'text-text-muted hover:text-text-secondary'}`}
      >
        {tab.label}
      </button>
    ))}
  </div>

  <!-- ── API Cost panel ───────────────────────────────────────────────────── -->
  <div id="panel-api" class="space-y-8">

    <!-- Model selection -->
    <div class="space-y-3">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Select Models to Compare</p>
      <div class="flex flex-wrap gap-2">
        {['Anthropic', 'OpenAI', 'Google'].map(provider => (
          <div class="space-y-2 mr-2">
            <p class="text-[9px] font-mono uppercase tracking-widest text-text-muted/60">{provider}</p>
            <div class="flex flex-col gap-1.5">
              {CLOUD_MODELS.filter(m => m.provider === provider).map(model => (
                <label class="flex items-center gap-2 cursor-pointer group">
                  <input
                    type="checkbox"
                    class="model-check accent-[color:var(--color-accent)] w-3.5 h-3.5 rounded cursor-pointer"
                    data-model={model.id}
                    checked={DEFAULT_SELECTED.includes(model.id)}
                  />
                  <span class="text-xs font-mono text-text-secondary group-hover:text-text-primary transition-colors">
                    {model.label}
                  </span>
                </label>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Inputs -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="space-y-1.5">
        <label class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Input Tokens / Day</label>
        <input id="api-input-tokens" type="number" value={DEFAULT_INPUT_PER_DAY} min="0" step="10000" inputmode="numeric"
          class="w-full bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/20 transition-colors [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
      </div>
      <div class="space-y-1.5">
        <label class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Output Tokens / Day</label>
        <input id="api-output-tokens" type="number" value={DEFAULT_OUTPUT_PER_DAY} min="0" step="1000" inputmode="numeric"
          class="w-full bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/20 transition-colors [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
      </div>
      <div class="space-y-1.5">
        <label class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Cache Hit Rate</label>
        <div class="relative">
          <input id="api-cache-hit" type="number" value={DEFAULT_CACHE_HIT} min="0" max="100" step="5" inputmode="numeric"
            class="w-full bg-bg-elevated border border-border rounded-xl px-4 py-3 pr-8 text-text-primary font-mono text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/20 transition-colors [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-mono text-text-muted pointer-events-none">%</span>
        </div>
      </div>
    </div>

    <!-- Results -->
    <div id="api-results" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <!-- Populated by JS -->
    </div>
  </div>

  <!-- ── Local Hardware panel ─────────────────────────────────────────────── -->
  <div id="panel-local" class="space-y-8 hidden">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1.5">
        <label for="local-hardware" class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Hardware</label>
        <div class="relative">
          <select id="local-hardware" class="w-full appearance-none bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors cursor-pointer pr-10">
            {LOCAL_HARDWARE.map(hw => (
              <option value={hw.id} selected={hw.id === DEFAULT_HARDWARE}>{hw.shortLabel}</option>
            ))}
          </select>
          <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs">▾</span>
        </div>
      </div>
      <div class="space-y-1.5">
        <label for="local-model" class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Model</label>
        <div class="relative">
          <select id="local-model" class="w-full appearance-none bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors cursor-pointer pr-10">
            {LOCAL_MODELS.map(m => (
              <option value={m.id} selected={m.id === DEFAULT_LOCAL_MODEL}>{m.label}</option>
            ))}
          </select>
          <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs">▾</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="space-y-1.5">
        <label class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Tokens / Day</label>
        <input id="local-tokens" type="number" value={DEFAULT_INPUT_PER_DAY + DEFAULT_OUTPUT_PER_DAY} min="0" step="10000" inputmode="numeric"
          class="w-full bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
      </div>
      <div class="space-y-1.5">
        <label class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Electricity Rate</label>
        <div class="relative">
          <input id="local-electricity" type="number" value={DEFAULT_ELECTRICITY} min="0" step="0.5" inputmode="decimal"
            class="w-full bg-bg-elevated border border-border rounded-xl px-4 py-3 pr-14 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-mono text-text-muted pointer-events-none">¢/kWh</span>
        </div>
      </div>
      <div class="space-y-1.5">
        <label class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Amortize Over</label>
        <div class="relative">
          <input id="local-amort" type="number" value={DEFAULT_AMORT_YEARS} min="1" max="10" step="1" inputmode="numeric"
            class="w-full bg-bg-elevated border border-border rounded-xl px-4 py-3 pr-12 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-mono text-text-muted pointer-events-none">yrs</span>
        </div>
      </div>
    </div>

    <!-- Hardware note -->
    <div id="local-hw-note" class="text-[10px] font-mono text-text-muted px-1"></div>

    <!-- Results -->
    <div id="local-results" class="grid grid-cols-2 md:grid-cols-4 gap-4">
      <!-- Populated by JS -->
    </div>

    <!-- Null state -->
    <div id="local-null-state" class="hidden py-10 text-center border border-dashed border-border rounded-xl">
      <p class="text-sm font-mono text-text-muted">No published benchmark for this hardware/model combination.</p>
      <p class="text-xs text-text-muted/60 mt-2">Try Llama 3.1 8B on RTX hardware, or Llama 3.2 3B on Pi AI HAT+ 2.</p>
    </div>
  </div>

  <!-- ── Break-even panel ─────────────────────────────────────────────────── -->
  <div id="panel-compare" class="space-y-8 hidden">

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div class="space-y-1.5">
        <label for="cmp-cloud" class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Cloud Model</label>
        <div class="relative">
          <select id="cmp-cloud" class="w-full appearance-none bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors cursor-pointer pr-10">
            {CLOUD_MODELS.map(m => (
              <option value={m.id} selected={m.id === 'claude-haiku-4-5'}>{m.label}</option>
            ))}
          </select>
          <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs">▾</span>
        </div>
      </div>
      <div class="space-y-1.5">
        <label for="cmp-hardware" class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Local Hardware</label>
        <div class="relative">
          <select id="cmp-hardware" class="w-full appearance-none bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors cursor-pointer pr-10">
            {LOCAL_HARDWARE.map(hw => (
              <option value={hw.id} selected={hw.id === DEFAULT_HARDWARE}>{hw.shortLabel}</option>
            ))}
          </select>
          <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs">▾</span>
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
      <div class="space-y-1.5">
        <label for="cmp-hw-model" class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Local Model</label>
        <div class="relative">
          <select id="cmp-hw-model" class="w-full appearance-none bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors cursor-pointer pr-10">
            {LOCAL_MODELS.map(m => (
              <option value={m.id} selected={m.id === DEFAULT_LOCAL_MODEL}>{m.label}</option>
            ))}
          </select>
          <span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 text-text-muted text-xs">▾</span>
        </div>
      </div>
      <div class="space-y-1.5">
        <label class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Total Tokens / Day</label>
        <input id="cmp-tokens" type="number" value={DEFAULT_INPUT_PER_DAY + DEFAULT_OUTPUT_PER_DAY} min="0" step="10000" inputmode="numeric"
          class="w-full bg-bg-elevated border border-border rounded-xl px-4 py-3 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
      </div>
      <div class="space-y-1.5">
        <label class="block text-[10px] font-mono uppercase tracking-widest text-text-muted">Electricity Rate</label>
        <div class="relative">
          <input id="cmp-electricity" type="number" value={DEFAULT_ELECTRICITY} min="0" step="0.5" inputmode="decimal"
            class="w-full bg-bg-elevated border border-border rounded-xl px-4 py-3 pr-14 text-text-primary font-mono text-sm focus:outline-none focus:border-accent transition-colors [appearance:textfield] [&::-webkit-inner-spin-button]:appearance-none" />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs font-mono text-text-muted pointer-events-none">¢/kWh</span>
        </div>
      </div>
    </div>

    <!-- Break-even summary — the LinkedIn punchline -->
    <div id="cmp-summary" class="space-y-4">
      <!-- Populated by JS -->
    </div>

    <!-- Cumulative cost table (first 24 months) -->
    <div class="overflow-x-auto">
      <table class="w-full text-xs font-mono" id="cmp-table">
        <thead>
          <tr class="border-b border-border-subtle text-text-muted text-[10px] uppercase tracking-widest">
            <th class="text-left py-2 pr-4">Month</th>
            <th class="text-right py-2 pr-4">Cloud Cumulative</th>
            <th class="text-right py-2 pr-4">Local Cumulative</th>
            <th class="text-right py-2">Δ Savings</th>
          </tr>
        </thead>
        <tbody id="cmp-table-body" class="divide-y divide-border-subtle/30">
          <!-- Populated by JS -->
        </tbody>
      </table>
    </div>
  </div>

</div>

<script>
  import {
    CLOUD_MODELS, LOCAL_MODELS, LOCAL_HARDWARE,
    calcApiCost, calcLocalTCO, calcBreakEven,
  } from './data';
  import { exportRows } from '../shared/csv';
  import { readState, writeState } from '../shared/url-state';

  // ── Defaults ────────────────────────────────────────────────────────────────

  const DEFAULTS = {
    tab: 'api',
    apiInput: 500000,
    apiOutput: 100000,
    apiCache: 30,
    apiSelected: 'claude-haiku-4-5,gpt-5-4-mini,gemini-2-5-flash',
    localHardware: 'rtx-5060ti-16gb',
    localModel: 'llama-3-1-8b',
    localTokens: 600000,
    localElec: 17.45,
    localAmort: 3,
    cmpCloud: 'claude-haiku-4-5',
    cmpHardware: 'rtx-5060ti-16gb',
    cmpHwModel: 'llama-3-1-8b',
    cmpTokens: 600000,
    cmpElec: 17.45,
  };

  const fmt = (n: number, dec = 2) =>
    n.toLocaleString('en-US', { minimumFractionDigits: dec, maximumFractionDigits: dec });
  const fmtUSD = (n: number) => `$${fmt(n)}`;

  // ── DOM helpers ──────────────────────────────────────────────────────────────

  const el = <T extends HTMLElement>(id: string) => document.getElementById(id) as T | null;
  const val = (id: string) => (el<HTMLInputElement>(id)?.value ?? '');
  const numVal = (id: string) => parseFloat(val(id)) || 0;

  // ── Tab switching ────────────────────────────────────────────────────────────

  const showPanel = (tabId: string) => {
    ['api', 'local', 'compare'].forEach(id => {
      const panel = el(`panel-${id}`);
      const tab = document.querySelector<HTMLElement>(`[data-tab="${id}"]`);
      const active = id === tabId;
      if (panel) panel.classList.toggle('hidden', !active);
      if (tab) {
        tab.setAttribute('aria-selected', String(active));
        tab.className = tab.className
          .replace(/bg-bg-surface text-accent border border-border shadow-sm|text-text-muted hover:text-text-secondary/g, '')
          .trim() + ' ' + (active
            ? 'bg-bg-surface text-accent border border-border shadow-sm'
            : 'text-text-muted hover:text-text-secondary');
      }
    });
  };

  // ── API Cost calculations ────────────────────────────────────────────────────

  const renderApiResults = (state: typeof DEFAULTS) => {
    const resultsEl = el('api-results');
    if (!resultsEl) return;

    const selectedIds = state.apiSelected.split(',').filter(Boolean);
    const selectedModels = CLOUD_MODELS.filter(m => selectedIds.includes(m.id));

    if (selectedModels.length === 0) {
      resultsEl.innerHTML = `<div class="col-span-full py-8 text-center text-sm font-mono text-text-muted">Select at least one model above.</div>`;
      return;
    }

    const results = selectedModels
      .map(m => calcApiCost(m, state.apiInput, state.apiOutput, state.apiCache / 100))
      .sort((a, b) => a.perMonth - b.perMonth);

    const cheapest = results[0];

    resultsEl.innerHTML = results.map((r, i) => `
      <div class="p-5 rounded-xl border ${i === 0 ? 'border-accent/30 bg-accent/5' : 'border-border bg-bg-elevated'} space-y-3">
        <div class="flex items-center justify-between gap-2">
          <p class="text-[10px] font-mono uppercase tracking-widest ${i === 0 ? 'text-accent' : 'text-text-muted'}">${r.model.provider}</p>
          ${i === 0 ? '<span class="text-[9px] font-mono uppercase tracking-widest text-accent border border-accent/30 px-1.5 py-0.5 rounded-full">Cheapest</span>' : ''}
        </div>
        <p class="text-sm font-mono text-text-secondary">${r.model.label}</p>
        <p class="${i === 0 ? 'text-accent' : 'text-text-primary'} text-3xl font-heading font-medium tabular-nums">${fmtUSD(r.perMonth)}<span class="text-sm font-mono ml-1 text-text-muted">/mo</span></p>
        <div class="space-y-1 pt-2 border-t border-border-subtle/50">
          <div class="flex justify-between text-xs font-mono text-text-muted">
            <span>Per day</span><span>${fmtUSD(r.perDay)}</span>
          </div>
          <div class="flex justify-between text-xs font-mono text-text-muted">
            <span>Per year</span><span>${fmtUSD(r.perYear)}</span>
          </div>
          ${results.length > 1 && i > 0 ? `
          <div class="flex justify-between text-xs font-mono text-text-muted">
            <span>vs cheapest</span><span class="text-orange-400">+${fmtUSD(r.perMonth - cheapest.perMonth)}/mo</span>
          </div>` : ''}
        </div>
      </div>
    `).join('');
  };

  // ── Local TCO calculations ───────────────────────────────────────────────────

  const renderLocalResults = (state: typeof DEFAULTS) => {
    const resultsEl = el('local-results');
    const nullEl = el('local-null-state');
    const noteEl = el('local-hw-note');
    if (!resultsEl) return;

    const hardware = LOCAL_HARDWARE.find(h => h.id === state.localHardware);
    const localModel = LOCAL_MODELS.find(m => m.id === state.localModel);
    if (!hardware || !localModel) return;

    if (noteEl) noteEl.textContent = hardware.note;

    const tco = calcLocalTCO(hardware, localModel, state.localTokens, state.localElec / 100, state.localAmort);

    if (!tco) {
      resultsEl.innerHTML = '';
      resultsEl.classList.add('hidden');
      nullEl?.classList.remove('hidden');
      return;
    }

    resultsEl.classList.remove('hidden');
    nullEl?.classList.add('hidden');

    resultsEl.innerHTML = `
      <div class="p-5 rounded-xl border border-accent/30 bg-accent/5 space-y-1 col-span-2 md:col-span-1">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Total / Month</p>
        <p class="text-3xl font-heading font-medium text-accent tabular-nums">${fmtUSD(tco.totalPerMonth)}<span class="text-sm font-mono ml-1 text-text-muted">/mo</span></p>
        <p class="text-[10px] font-mono text-text-muted">${fmtUSD(tco.totalPerMonth * 12)}/yr</p>
      </div>
      <div class="p-5 rounded-xl border border-border bg-bg-elevated space-y-1">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Hardware Cost</p>
        <p class="text-xl font-heading font-medium text-text-primary tabular-nums">${fmtUSD(tco.hardwarePerMonth)}<span class="text-sm font-mono ml-1 text-text-muted">/mo</span></p>
        <p class="text-[10px] font-mono text-text-muted">${fmtUSD(hardware.msrpUSD)} over ${state.localAmort}yr</p>
      </div>
      <div class="p-5 rounded-xl border border-border bg-bg-elevated space-y-1">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Electricity</p>
        <p class="text-xl font-heading font-medium text-text-primary tabular-nums">${fmtUSD(tco.electricityPerMonth)}<span class="text-sm font-mono ml-1 text-text-muted">/mo</span></p>
        <p class="text-[10px] font-mono text-text-muted">${fmt(tco.inferenceHoursPerDay, 1)}h inference/day · ${hardware.tdpWatts}W</p>
      </div>
      <div class="p-5 rounded-xl border border-border bg-bg-elevated space-y-1">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Effective Rate</p>
        <p class="text-xl font-heading font-medium text-text-primary tabular-nums">${fmtUSD(tco.effectiveCostPerMTok)}</p>
        <p class="text-[10px] font-mono text-text-muted">per 1M tokens · ${fmt(tco.tokPerSec, 0)} tok/s</p>
      </div>
    `;
  };

  // ── Break-even calculations ──────────────────────────────────────────────────

  const renderCompare = (state: typeof DEFAULTS) => {
    const summaryEl = el('cmp-summary');
    const tbodyEl = el('cmp-table-body');
    if (!summaryEl || !tbodyEl) return;

    const cloudModel = CLOUD_MODELS.find(m => m.id === state.cmpCloud);
    const hardware = LOCAL_HARDWARE.find(h => h.id === state.cmpHardware);
    const localModel = LOCAL_MODELS.find(m => m.id === state.cmpHwModel);
    if (!cloudModel || !hardware || !localModel) return;

    // Cloud cost assumes equal input/output split for simplicity in compare tab
    const totalTokens = state.cmpTokens;
    const inputTokens = totalTokens * 0.83; // ~83% input, 17% output (typical)
    const outputTokens = totalTokens * 0.17;
    const cloudResult = calcApiCost(cloudModel, inputTokens, outputTokens, 0);
    const localTCO = calcLocalTCO(hardware, localModel, totalTokens, state.cmpElec / 100, 3);

    if (!localTCO) {
      summaryEl.innerHTML = `<div class="py-10 text-center border border-dashed border-border rounded-xl"><p class="text-sm font-mono text-text-muted">No published benchmark for this hardware/model combination.</p></div>`;
      tbodyEl.innerHTML = '';
      return;
    }

    const breakEven = calcBreakEven(cloudResult.perMonth, localTCO);
    const savings = breakEven.savings36mo;
    const savingsPositive = savings > 0;

    summaryEl.innerHTML = `
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <div class="sm:col-span-3 p-6 rounded-xl border ${savingsPositive ? 'border-accent/30 bg-accent/5' : 'border-border bg-bg-elevated'} space-y-2">
          ${breakEven.breaksEven
            ? `<p class="text-[10px] font-mono uppercase tracking-widest ${savingsPositive ? 'text-accent' : 'text-text-muted'}">Break-even</p>
               <p class="${savingsPositive ? 'text-accent' : 'text-text-primary'} text-4xl font-heading font-medium">Month ${breakEven.breakEvenMonth}</p>
               <p class="text-sm text-text-secondary">${savingsPositive ? `Save <strong class="text-accent">${fmtUSD(savings)}</strong> over 3 years after hardware pays off.` : 'Cloud is cheaper for this workload size.'}</p>`
            : `<p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">No break-even point</p>
               <p class="text-2xl font-heading font-medium text-text-primary">Cloud is cheaper</p>
               <p class="text-sm text-text-secondary">At this workload, the local hardware running cost exceeds cloud. Increase your token volume to find the crossover.</p>`
          }
        </div>
        <div class="p-5 rounded-xl border border-border bg-bg-elevated space-y-1">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Cloud / Month</p>
          <p class="text-2xl font-heading font-medium text-text-primary tabular-nums">${fmtUSD(cloudResult.perMonth)}</p>
          <p class="text-[10px] font-mono text-text-muted">${cloudModel.label}</p>
        </div>
        <div class="p-5 rounded-xl border border-border bg-bg-elevated space-y-1">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Local / Month</p>
          <p class="text-2xl font-heading font-medium text-text-primary tabular-nums">${fmtUSD(localTCO.totalPerMonth)}</p>
          <p class="text-[10px] font-mono text-text-muted">${hardware.shortLabel} · electricity + amort</p>
        </div>
        <div class="p-5 rounded-xl border border-border bg-bg-elevated space-y-1">
          <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">3-Year Savings</p>
          <p class="text-2xl font-heading font-medium ${savingsPositive ? 'text-accent' : 'text-orange-400'} tabular-nums">${savingsPositive ? '+' : ''}${fmtUSD(savings)}</p>
          <p class="text-[10px] font-mono text-text-muted">${fmtUSD(breakEven.totalCloud36mo)} cloud vs ${fmtUSD(breakEven.totalLocal36mo)} local</p>
        </div>
      </div>
    `;

    // Render table (first 24 months, then just show break-even rows)
    const rows = breakEven.monthlyRows.slice(0, 24);
    tbodyEl.innerHTML = rows.map(r => {
      const delta = r.cloudCumulative - r.localCumulative;
      const isCrossover = breakEven.breaksEven && r.month === breakEven.breakEvenMonth;
      return `<tr class="${isCrossover ? 'bg-accent/5' : ''}">
        <td class="py-1.5 pr-4 text-text-muted">${r.month}${isCrossover ? ' ✓' : ''}</td>
        <td class="py-1.5 pr-4 text-right text-text-secondary">${fmtUSD(r.cloudCumulative)}</td>
        <td class="py-1.5 pr-4 text-right text-text-secondary">${fmtUSD(r.localCumulative)}</td>
        <td class="py-1.5 text-right ${delta > 0 ? 'text-accent' : 'text-orange-400'}">${delta > 0 ? '+' : ''}${fmtUSD(delta)}</td>
      </tr>`;
    }).join('');
  };

  // ── State → URL → Recalculate ────────────────────────────────────────────────

  const getState = () => {
    const selectedIds = [...document.querySelectorAll<HTMLInputElement>('.model-check:checked')]
      .map(c => c.dataset.model || '')
      .filter(Boolean)
      .join(',');

    return {
      tab: (document.querySelector<HTMLElement>('[data-tab][aria-selected="true"]')?.dataset.tab) ?? 'api',
      apiInput: numVal('api-input-tokens'),
      apiOutput: numVal('api-output-tokens'),
      apiCache: numVal('api-cache-hit'),
      apiSelected: selectedIds || DEFAULTS.apiSelected,
      localHardware: val('local-hardware') || DEFAULTS.localHardware,
      localModel: val('local-model') || DEFAULTS.localModel,
      localTokens: numVal('local-tokens'),
      localElec: numVal('local-electricity'),
      localAmort: numVal('local-amort'),
      cmpCloud: val('cmp-cloud') || DEFAULTS.cmpCloud,
      cmpHardware: val('cmp-hardware') || DEFAULTS.cmpHardware,
      cmpHwModel: val('cmp-hw-model') || DEFAULTS.cmpHwModel,
      cmpTokens: numVal('cmp-tokens'),
      cmpElec: numVal('cmp-electricity'),
    };
  };

  const recalculate = () => {
    const state = getState();
    writeState(state as any);
    renderApiResults(state);
    renderLocalResults(state);
    renderCompare(state);
  };

  const applyState = (state: Partial<typeof DEFAULTS>) => {
    const setInput = (id: string, v: string | number) => {
      const input = el<HTMLInputElement>(id);
      if (input) input.value = String(v);
    };
    const setSelect = (id: string, v: string) => {
      const select = el<HTMLSelectElement>(id);
      if (select) select.value = v;
    };

    if (state.apiInput !== undefined) setInput('api-input-tokens', state.apiInput);
    if (state.apiOutput !== undefined) setInput('api-output-tokens', state.apiOutput);
    if (state.apiCache !== undefined) setInput('api-cache-hit', state.apiCache);
    if (state.localHardware) setSelect('local-hardware', state.localHardware);
    if (state.localModel) setSelect('local-model', state.localModel);
    if (state.localTokens !== undefined) setInput('local-tokens', state.localTokens);
    if (state.localElec !== undefined) setInput('local-electricity', state.localElec);
    if (state.localAmort !== undefined) setInput('local-amort', state.localAmort);
    if (state.cmpCloud) setSelect('cmp-cloud', state.cmpCloud);
    if (state.cmpHardware) setSelect('cmp-hardware', state.cmpHardware);
    if (state.cmpHwModel) setSelect('cmp-hw-model', state.cmpHwModel);
    if (state.cmpTokens !== undefined) setInput('cmp-tokens', state.cmpTokens);
    if (state.cmpElec !== undefined) setInput('cmp-electricity', state.cmpElec);

    if (state.apiSelected) {
      const selectedIds = state.apiSelected.split(',').filter(Boolean);
      document.querySelectorAll<HTMLInputElement>('.model-check').forEach(cb => {
        cb.checked = selectedIds.includes(cb.dataset.model || '');
      });
    }

    if (state.tab) showPanel(state.tab);
  };

  // ── CSV export ───────────────────────────────────────────────────────────────

  const buildExportRows = () => {
    const state = getState();
    const rows: Record<string, string | number>[] = [];

    const selectedIds = state.apiSelected.split(',').filter(Boolean);
    CLOUD_MODELS.filter(m => selectedIds.includes(m.id)).forEach(model => {
      const r = calcApiCost(model, state.apiInput, state.apiOutput, state.apiCache / 100);
      rows.push({
        type: 'API',
        provider: model.provider,
        model: model.label,
        input_per_day: state.apiInput,
        output_per_day: state.apiOutput,
        cache_hit_pct: state.apiCache,
        cost_per_day_usd: +r.perDay.toFixed(4),
        cost_per_month_usd: +r.perMonth.toFixed(2),
        cost_per_year_usd: +r.perYear.toFixed(2),
      });
    });

    const hw = LOCAL_HARDWARE.find(h => h.id === state.localHardware);
    const lm = LOCAL_MODELS.find(m => m.id === state.localModel);
    if (hw && lm) {
      const tco = calcLocalTCO(hw, lm, state.localTokens, state.localElec / 100, state.localAmort);
      if (tco) {
        rows.push({
          type: 'Local TCO',
          hardware: hw.label,
          model: lm.label,
          tokens_per_day: state.localTokens,
          electricity_cents_kwh: state.localElec,
          amort_years: state.localAmort,
          tok_per_sec: tco.tokPerSec,
          inference_hours_per_day: +tco.inferenceHoursPerDay.toFixed(2),
          electricity_per_month_usd: +tco.electricityPerMonth.toFixed(2),
          hardware_per_month_usd: +tco.hardwarePerMonth.toFixed(2),
          total_per_month_usd: +tco.totalPerMonth.toFixed(2),
          effective_cost_per_mtok_usd: +tco.effectiveCostPerMTok.toFixed(4),
        });
      }
    }

    return rows;
  };

  // ── Init ─────────────────────────────────────────────────────────────────────

  const initCalc = () => {
    const calc = el('llm-calc');
    if (!calc || (calc as any)._calcInit) return;
    (calc as any)._calcInit = true;

    // Apply URL state (or defaults)
    const urlState = readState(DEFAULTS as any);
    applyState(urlState as any);

    // Tab buttons
    calc.querySelectorAll<HTMLButtonElement>('[data-tab]').forEach(btn => {
      btn.addEventListener('click', () => {
        showPanel(btn.dataset.tab!);
        recalculate();
      });
    });

    // All inputs trigger recalc
    calc.querySelectorAll('input, select').forEach(input => {
      input.addEventListener('input', recalculate);
      input.addEventListener('change', recalculate);
    });

    // Toolbar events
    document.addEventListener('app:export', ((e: CustomEvent) => {
      const rows = buildExportRows();
      const filename = (e.detail?.filename as string) || 'llm-cost-calculator.csv';
      exportRows(rows, filename);
    }) as EventListener);

    document.addEventListener('app:reset', () => {
      applyState(DEFAULTS as any);
      recalculate();
    });

    document.addEventListener('app:copy', () => {
      const state = getState();
      const selectedIds = state.apiSelected.split(',').filter(Boolean);
      const results = CLOUD_MODELS.filter(m => selectedIds.includes(m.id))
        .map(m => calcApiCost(m, state.apiInput, state.apiOutput, state.apiCache / 100))
        .sort((a, b) => a.perMonth - b.perMonth);
      const summary = results.map(r => `${r.model.label}: ${fmtUSD(r.perMonth)}/mo`).join(' | ');
      navigator.clipboard.writeText(summary);
    });

    // Initial render
    recalculate();
  };

  initCalc();
  document.addEventListener('astro:after-swap', () => {
    // Reset init flag so the calc re-initializes on new page
    const calc = document.getElementById('llm-calc');
    if (calc) (calc as any)._calcInit = false;
    initCalc();
  });
</script>
