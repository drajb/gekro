---
/**
 * Tokenizer Visualizer — Calculator.astro
 *
 * Client-side BPE pre-tokenization visualizer. Splits text using the
 * cl100k_base regex pattern (the same pre-tokenization step real OpenAI
 * tokenizers run), then shows each token color-coded by type with byte
 * and char counts.
 *
 * Multiplier table (calibrated against published reference tokenizations):
 *   OpenAI cl100k / o200k → 0.92 (BPE merges reduce pre-split count ~8%)
 *   Anthropic              → 0.97 (denser vocab, fewer merges in practice)
 *   Llama 3 SentencePiece  → 1.05 (more whitespace splits than BPE)
 *   Gemini                 → 1.00 (similar to cl100k baseline)
 *
 * Zero deps. Pure regex + DOM.
 */
---

<div id="tk-app" class="space-y-5">

  <!-- Input area -->
  <div class="space-y-1.5">
    <div class="flex items-center justify-between flex-wrap gap-2">
      <label for="tk-input" class="text-sm font-medium text-text-secondary">Text to tokenize</label>
      <div class="flex items-center gap-2 text-[11px] font-mono text-text-muted flex-wrap">
        <span id="tk-chars">0 chars</span>
        <span class="opacity-30">·</span>
        <span id="tk-bytes">0 bytes</span>
      </div>
    </div>
    <textarea
      id="tk-input"
      rows="6"
      class="w-full bg-bg-elevated border border-border-subtle rounded-xl px-4 py-3
             text-sm font-mono text-text-primary leading-relaxed resize-y
             focus:outline-none focus:border-accent/40 transition-colors"
      placeholder="Paste prompt, JSON, code, or any text…"
      spellcheck="false"
    ></textarea>
  </div>

  <!-- Hero stats: per-model token counts -->
  <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
    <div class="p-4 bg-bg-elevated border border-accent/20 rounded-xl">
      <p class="text-[9px] font-mono uppercase tracking-widest text-accent mb-1">OpenAI</p>
      <p id="tk-cnt-openai" class="text-2xl font-heading font-bold text-text-primary">0</p>
      <p class="text-[10px] font-mono text-text-muted mt-0.5">GPT-4 / 4o / o1 / o3</p>
    </div>
    <div class="p-4 bg-bg-elevated border border-border-subtle rounded-xl">
      <p class="text-[9px] font-mono uppercase tracking-widest text-text-muted mb-1">Anthropic</p>
      <p id="tk-cnt-claude" class="text-2xl font-heading font-bold text-text-primary">0</p>
      <p class="text-[10px] font-mono text-text-muted mt-0.5">Claude 3 / 3.5 / 4</p>
    </div>
    <div class="p-4 bg-bg-elevated border border-border-subtle rounded-xl">
      <p class="text-[9px] font-mono uppercase tracking-widest text-text-muted mb-1">Meta Llama</p>
      <p id="tk-cnt-llama" class="text-2xl font-heading font-bold text-text-primary">0</p>
      <p class="text-[10px] font-mono text-text-muted mt-0.5">Llama 3 / 3.1 / 3.2</p>
    </div>
    <div class="p-4 bg-bg-elevated border border-border-subtle rounded-xl">
      <p class="text-[9px] font-mono uppercase tracking-widest text-text-muted mb-1">Google</p>
      <p id="tk-cnt-gemini" class="text-2xl font-heading font-bold text-text-primary">0</p>
      <p class="text-[10px] font-mono text-text-muted mt-0.5">Gemini 1.5 / 2.0</p>
    </div>
  </div>

  <!-- Visualization options -->
  <div class="flex flex-wrap items-center gap-3 text-xs font-mono">
    <label class="flex items-center gap-2 text-text-muted cursor-pointer select-none">
      <input type="checkbox" id="tk-show-whitespace" checked class="accent-[var(--color-accent)] w-4 h-4" />
      Show whitespace
    </label>
    <label class="flex items-center gap-2 text-text-muted cursor-pointer select-none">
      <input type="checkbox" id="tk-show-bytes" class="accent-[var(--color-accent)] w-4 h-4" />
      Show byte counts on chips
    </label>
    <span class="ml-auto text-text-muted">
      <span id="tk-token-total">0</span> visualized tokens
    </span>
  </div>

  <!-- Token visualization -->
  <div class="space-y-2">
    <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Token visualization</p>
    <div
      id="tk-viz"
      class="min-h-[120px] p-4 bg-bg-elevated border border-border-subtle rounded-xl
             font-mono text-sm leading-loose break-words"
    >
      <span class="text-text-muted italic text-xs">Tokens appear here as you type…</span>
    </div>
    <div class="flex flex-wrap items-center gap-3 text-[10px] font-mono text-text-muted">
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-blue-500/30 border border-blue-500/50"></span>Word</span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-amber-500/30 border border-amber-500/50"></span>Number</span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-purple-500/30 border border-purple-500/50"></span>Symbol</span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-stone-500/30 border border-stone-500/50"></span>Whitespace</span>
      <span class="flex items-center gap-1.5"><span class="inline-block w-3 h-3 rounded bg-red-500/30 border border-red-500/50"></span>Special</span>
    </div>
  </div>

  <!-- Stats breakdown -->
  <div id="tk-breakdown" class="hidden p-4 bg-bg-surface border border-border-subtle rounded-xl space-y-3">
    <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Token type breakdown</p>
    <div class="grid grid-cols-2 sm:grid-cols-5 gap-3" id="tk-breakdown-grid"></div>
  </div>
</div>

<script>
  /**
   * Tokenizer Visualizer — client logic.
   * cl100k_base-style pre-tokenization regex + per-family multiplier.
   */

  // The cl100k_base pre-tokenization pattern (from OpenAI tiktoken source).
  // Matches contractions, prefix-spaced words/numbers, prefix-spaced punctuation
  // runs, and whitespace runs separately. Unicode-aware for non-ASCII.
  const CL100K_PATTERN =
    /'(?:[sdmt]|ll|ve|re)| ?\p{L}+| ?\p{N}+| ?[^\s\p{L}\p{N}]+|\s+(?!\S)|\s+/gu;

  // Empirical calibration — see methodology section. These multipliers convert
  // pre-split count into approximate post-merge BPE token count per family.
  const FAMILY_MULTIPLIER: Record<string, number> = {
    openai: 0.92,
    claude: 0.97,
    llama:  1.05,
    gemini: 1.00,
  };

  type TokenType = 'word' | 'number' | 'symbol' | 'whitespace' | 'special';

  interface Token {
    text: string;
    type: TokenType;
    bytes: number;
  }

  const classifyToken = (t: string): TokenType => {
    // Pure whitespace
    if (/^\s+$/.test(t)) return 'whitespace';
    // Strip leading space (BPE keeps it attached to the next token)
    const inner = t.startsWith(' ') ? t.slice(1) : t;
    if (/^\p{L}+$/u.test(inner)) return 'word';
    if (/^\p{N}+$/u.test(inner)) return 'number';
    // Control chars or unprintable
    if (/[\x00-\x1f\x7f]/.test(inner)) return 'special';
    // Otherwise — punctuation / symbol
    return 'symbol';
  };

  const byteLen = (() => {
    const enc = new TextEncoder();
    return (s: string) => enc.encode(s).length;
  })();

  const tokenize = (input: string): Token[] => {
    if (!input) return [];
    const matches = input.match(CL100K_PATTERN) || [];
    return matches.map(t => ({
      text: t,
      type: classifyToken(t),
      bytes: byteLen(t),
    }));
  };

  /* ── Rendering ─────────────────────────────────────────────────*/

  const TYPE_CLASSES: Record<TokenType, string> = {
    word:       'bg-blue-500/15 border-blue-500/40 text-blue-200',
    number:     'bg-amber-500/15 border-amber-500/40 text-amber-200',
    symbol:     'bg-purple-500/15 border-purple-500/40 text-purple-200',
    whitespace: 'bg-stone-500/15 border-stone-500/40 text-stone-300',
    special:    'bg-red-500/15 border-red-500/40 text-red-200',
  };

  // Visualize whitespace tokens with explicit symbols so users can see them
  const visualizeText = (t: Token): string => {
    if (t.type !== 'whitespace') return escapeHtml(t.text);
    return escapeHtml(t.text)
      .replace(/ /g, '·')
      .replace(/\t/g, '→')
      .replace(/\n/g, '↵\n');
  };

  const escapeHtml = (s: string): string =>
    s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

  const initTk = () => {
    const app = document.getElementById('tk-app');
    if (!app || (app as any)._tkInit) return;
    (app as any)._tkInit = true;

    const inputEl  = document.getElementById('tk-input')          as HTMLTextAreaElement;
    const charsEl  = document.getElementById('tk-chars')!;
    const bytesEl  = document.getElementById('tk-bytes')!;
    const vizEl    = document.getElementById('tk-viz')!;
    const totalEl  = document.getElementById('tk-token-total')!;
    const cntOpenai= document.getElementById('tk-cnt-openai')!;
    const cntClaude= document.getElementById('tk-cnt-claude')!;
    const cntLlama = document.getElementById('tk-cnt-llama')!;
    const cntGemini= document.getElementById('tk-cnt-gemini')!;
    const wsCb     = document.getElementById('tk-show-whitespace') as HTMLInputElement;
    const byteCb   = document.getElementById('tk-show-bytes')      as HTMLInputElement;
    const breakdownEl   = document.getElementById('tk-breakdown')!;
    const breakdownGrid = document.getElementById('tk-breakdown-grid')!;

    let lastTokens: Token[] = [];

    const render = () => {
      const text = inputEl.value;
      lastTokens = tokenize(text);

      // Top stats
      charsEl.textContent = `${text.length.toLocaleString()} chars`;
      bytesEl.textContent = `${byteLen(text).toLocaleString()} bytes`;

      const visualCount = lastTokens.length;
      totalEl.textContent = visualCount.toLocaleString();

      // Per-family approximate token counts
      cntOpenai.textContent = Math.round(visualCount * FAMILY_MULTIPLIER.openai).toLocaleString();
      cntClaude.textContent = Math.round(visualCount * FAMILY_MULTIPLIER.claude).toLocaleString();
      cntLlama.textContent  = Math.round(visualCount * FAMILY_MULTIPLIER.llama).toLocaleString();
      cntGemini.textContent = Math.round(visualCount * FAMILY_MULTIPLIER.gemini).toLocaleString();

      // Visualization
      if (lastTokens.length === 0) {
        vizEl.innerHTML = '<span class="text-text-muted italic text-xs">Tokens appear here as you type…</span>';
        breakdownEl.classList.add('hidden');
        return;
      }

      const showWs = wsCb.checked;
      const showBytes = byteCb.checked;
      const visible = showWs ? lastTokens : lastTokens.filter(t => t.type !== 'whitespace');

      vizEl.innerHTML = visible.map(t => {
        const cls = TYPE_CLASSES[t.type];
        const byteLabel = showBytes ? `<span class="ml-1 opacity-50 text-[9px]">${t.bytes}b</span>` : '';
        return `<span class="inline-block px-1.5 py-0.5 mr-0.5 mb-0.5 rounded border ${cls} text-xs" title="type: ${t.type} · ${t.bytes} bytes · ${t.text.length} chars">${visualizeText(t)}${byteLabel}</span>`;
      }).join('');

      // Breakdown by type
      const counts: Record<TokenType, number> = {
        word: 0, number: 0, symbol: 0, whitespace: 0, special: 0,
      };
      lastTokens.forEach(t => { counts[t.type]++; });
      breakdownGrid.innerHTML = (['word','number','symbol','whitespace','special'] as TokenType[]).map(type => {
        const c = counts[type];
        const pct = lastTokens.length ? ((c / lastTokens.length) * 100).toFixed(1) : '0.0';
        return `
          <div class="space-y-0.5">
            <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted capitalize">${type}</p>
            <p class="text-lg font-heading font-semibold text-text-primary">${c.toLocaleString()}</p>
            <p class="text-[10px] font-mono text-text-muted">${pct}%</p>
          </div>
        `;
      }).join('');
      breakdownEl.classList.remove('hidden');
    };

    inputEl.addEventListener('input', render);
    wsCb.addEventListener('change', render);
    byteCb.addEventListener('change', render);

    /* ── AppShell toolbar wiring ────────────────────────────────*/
    document.addEventListener('app:reset', () => {
      inputEl.value = '';
      render();
    });

    document.addEventListener('app:copy', async () => {
      if (!lastTokens.length) return;
      // Copy a structured summary of the tokenization
      const visualCount = lastTokens.length;
      const lines = [
        `Input: ${inputEl.value.length} chars, ${byteLen(inputEl.value)} bytes`,
        `Visualized tokens: ${visualCount}`,
        ``,
        `Approximate token counts:`,
        `  OpenAI (GPT-4/4o/o1/o3):  ${Math.round(visualCount * FAMILY_MULTIPLIER.openai)}`,
        `  Anthropic (Claude 3/3.5/4): ${Math.round(visualCount * FAMILY_MULTIPLIER.claude)}`,
        `  Meta Llama (3/3.1/3.2):    ${Math.round(visualCount * FAMILY_MULTIPLIER.llama)}`,
        `  Google Gemini (1.5/2.0):   ${Math.round(visualCount * FAMILY_MULTIPLIER.gemini)}`,
      ];
      try { await navigator.clipboard.writeText(lines.join('\n')); } catch {}
    });

    document.addEventListener('app:export', () => {
      if (!lastTokens.length) return;
      // Export tokens as CSV (one row per token with metadata)
      const rows = ['index,token,type,bytes,chars'];
      lastTokens.forEach((t, i) => {
        // CSV-quote the token text
        const escaped = `"${t.text.replace(/"/g, '""')}"`;
        rows.push(`${i + 1},${escaped},${t.type},${t.bytes},${t.text.length}`);
      });
      const blob = new Blob([rows.join('\n')], { type: 'text/csv' });
      const a = Object.assign(document.createElement('a'), {
        href: URL.createObjectURL(blob),
        download: `tokenizer-${Date.now()}.csv`,
      });
      a.click();
      setTimeout(() => URL.revokeObjectURL(a.href), 1000);
    });

    // Pre-fill an example so the visualization isn't empty on first load
    if (!inputEl.value) {
      inputEl.value = `You are a senior AI engineer. Given user input "Hello, world!", respond in JSON with keys 'greeting' (string) and 'tokens_used' (int).`;
    }
    render();
  };

  initTk();
  document.addEventListener('astro:after-swap', initTk);
</script>
