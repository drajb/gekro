---
// Coin Flipper — crypto.getRandomValues, CSS 3D, SVG coin faces, zero deps
---

<div id="cf-app" class="space-y-6">

  <!-- Coin arena -->
  <div class="flex flex-col items-center gap-6 py-6">
    <div class="coin-scene">
      <div id="cf-coin" class="coin">

        <!-- HEADS face — portrait bust -->
        <div class="coin-face coin-heads">
          <svg viewBox="0 0 120 120" width="120" height="120" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="hGold" cx="38%" cy="32%" r="65%">
                <stop offset="0%"   stop-color="#ffe680"/>
                <stop offset="40%"  stop-color="#e6a820"/>
                <stop offset="100%" stop-color="#8a5c00"/>
              </radialGradient>
              <radialGradient id="hRim" cx="50%" cy="50%" r="50%">
                <stop offset="84%"  stop-color="transparent"/>
                <stop offset="88%"  stop-color="#c8860a"/>
                <stop offset="93%"  stop-color="#7a4800"/>
                <stop offset="100%" stop-color="#4a2c00"/>
              </radialGradient>
              <clipPath id="hCircle"><circle cx="60" cy="60" r="55"/></clipPath>
            </defs>
            <!-- Coin disc -->
            <circle cx="60" cy="60" r="58" fill="#4a2c00"/>
            <circle cx="60" cy="60" r="55" fill="url(#hGold)"/>
            <!-- Rim reeded edge detail -->
            {Array.from({length:72},(_,i)=>{
              const a=i*5*Math.PI/180, r1=55, r2=58;
              return i%2===0 ? null : <line
                x1={60+Math.cos(a)*r1} y1={60+Math.sin(a)*r1}
                x2={60+Math.cos(a)*r2} y2={60+Math.sin(a)*r2}
                stroke="#3a2000" stroke-width="1" opacity="0.6"/>;
            })}
            <circle cx="60" cy="60" r="55" fill="url(#hRim)" opacity="0.5"/>
            <!-- Inner relief ring -->
            <circle cx="60" cy="60" r="50" fill="none" stroke="#c8860a" stroke-width="0.8" opacity="0.6"/>
            <!-- Portrait bust (profile facing right) -->
            <g clip-path="url(#hCircle)" fill="#c8860a" opacity="0.85">
              <!-- Neck & shoulders -->
              <ellipse cx="60" cy="105" rx="22" ry="14"/>
              <!-- Head silhouette -->
              <ellipse cx="58" cy="68" rx="16" ry="19"/>
              <!-- Nose bump -->
              <ellipse cx="72" cy="66" rx="5" ry="3.5" transform="rotate(-15,72,66)"/>
              <!-- Chin -->
              <ellipse cx="69" cy="80" rx="6" ry="4" transform="rotate(20,69,80)"/>
              <!-- Forehead & crown -->
              <path d="M44 60 Q46 46 58 48 Q70 48 72 58 Q72 46 60 42 Q48 40 44 60Z"/>
              <!-- Laurel wreath hint -->
              <ellipse cx="50" cy="50" rx="5" ry="3" transform="rotate(-30,50,50)" opacity="0.7"/>
              <ellipse cx="44" cy="56" rx="4" ry="2.5" transform="rotate(-50,44,56)" opacity="0.7"/>
            </g>
            <!-- HEADS legend -->
            <text x="60" y="24" text-anchor="middle" font-family="Georgia,serif" font-size="7"
                  font-weight="bold" letter-spacing="2" fill="#8a5c00">HEADS</text>
            <!-- Highlight sheen -->
            <ellipse cx="46" cy="44" rx="14" ry="8" fill="white" opacity="0.08" transform="rotate(-30,46,44)"/>
          </svg>
        </div>

        <!-- TAILS face — eagle / ornate reverse -->
        <div class="coin-face coin-tails">
          <svg viewBox="0 0 120 120" width="120" height="120" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <radialGradient id="tGold" cx="62%" cy="32%" r="65%">
                <stop offset="0%"   stop-color="#ffe680"/>
                <stop offset="40%"  stop-color="#d49518"/>
                <stop offset="100%" stop-color="#7a4800"/>
              </radialGradient>
              <clipPath id="tCircle"><circle cx="60" cy="60" r="55"/></clipPath>
            </defs>
            <circle cx="60" cy="60" r="58" fill="#4a2c00"/>
            <circle cx="60" cy="60" r="55" fill="url(#tGold)"/>
            {Array.from({length:72},(_,i)=>{
              const a=i*5*Math.PI/180, r1=55, r2=58;
              return i%2===0 ? null : <line
                x1={60+Math.cos(a)*r1} y1={60+Math.sin(a)*r1}
                x2={60+Math.cos(a)*r2} y2={60+Math.sin(a)*r2}
                stroke="#3a2000" stroke-width="1" opacity="0.6"/>;
            })}
            <circle cx="60" cy="60" r="50" fill="none" stroke="#b87818" stroke-width="0.8" opacity="0.6"/>
            <!-- Eagle body -->
            <g clip-path="url(#tCircle)" fill="#8a5c00" opacity="0.82">
              <!-- Body -->
              <ellipse cx="60" cy="70" rx="14" ry="17"/>
              <!-- Head -->
              <circle cx="60" cy="50" r="9"/>
              <!-- Beak -->
              <path d="M69 49 L74 52 L69 53Z"/>
              <!-- Left wing -->
              <path d="M46 65 Q30 50 36 38 Q44 55 48 62Z"/>
              <path d="M46 65 Q26 58 28 44 Q40 58 48 64Z"/>
              <!-- Right wing -->
              <path d="M74 65 Q90 50 84 38 Q76 55 72 62Z"/>
              <path d="M74 65 Q94 58 92 44 Q80 58 72 64Z"/>
              <!-- Tail feathers -->
              <path d="M52 86 Q60 90 68 86 Q64 80 60 82 Q56 80 52 86Z"/>
              <path d="M48 84 Q60 92 72 84" fill="none" stroke="#8a5c00" stroke-width="2"/>
              <!-- Talons -->
              <path d="M54 86 L50 94 M57 87 L55 96 M63 87 L65 96 M66 86 L70 94"
                    fill="none" stroke="#7a4800" stroke-width="1.5" stroke-linecap="round"/>
              <!-- Eye -->
              <circle cx="63" cy="48" r="2" fill="#4a2c00"/>
            </g>
            <!-- Shield on breast -->
            <path d="M55 68 L65 68 L65 78 Q60 82 55 78Z" fill="#c8860a" opacity="0.5" stroke="#8a5c00" stroke-width="0.5"/>
            <!-- Stars arc -->
            {[45,55,65,75,85,95,105,115,125].map((deg,i)=>{
              const a=(deg-90)*Math.PI/180, r=40;
              const sx=60+Math.cos(a)*r, sy=60+Math.sin(a)*r;
              return i<9 ? <text x={sx} y={sy} text-anchor="middle" dominant-baseline="middle"
                font-size="4" fill="#8a5c00" opacity="0.7">★</text> : null;
            })}
            <!-- TAILS legend -->
            <text x="60" y="24" text-anchor="middle" font-family="Georgia,serif" font-size="7"
                  font-weight="bold" letter-spacing="2" fill="#7a4800">TAILS</text>
            <!-- Highlight sheen -->
            <ellipse cx="74" cy="44" rx="14" ry="8" fill="white" opacity="0.08" transform="rotate(30,74,44)"/>
          </svg>
        </div>

      </div>
    </div>

    <div class="text-center space-y-1 min-h-[3rem]">
      <p id="cf-result-text" class="text-2xl font-heading font-bold text-text-primary">&nbsp;</p>
      <p id="cf-streak-text" class="text-xs font-mono text-text-muted">&nbsp;</p>
    </div>

    <button id="cf-flip-btn"
      class="px-10 py-4 bg-accent/20 border border-accent/40 rounded-2xl text-accent font-mono font-bold text-lg
             hover:bg-accent/30 active:scale-95 transition-all select-none">
      Flip
    </button>

    <p class="text-[10px] font-mono text-text-muted">Press <kbd class="px-1.5 py-0.5 bg-bg-elevated border border-border-subtle rounded text-[10px]">Space</kbd> to flip</p>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-3 gap-3">
    <div class="p-4 bg-bg-surface border border-border-subtle rounded-xl text-center space-y-1">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Heads</p>
      <p id="cf-heads" class="text-2xl font-heading font-bold text-text-primary">0</p>
      <p id="cf-heads-pct" class="text-xs font-mono text-text-muted">—</p>
    </div>
    <div class="p-4 bg-bg-surface border border-border-subtle rounded-xl text-center space-y-1">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Total</p>
      <p id="cf-total" class="text-2xl font-heading font-bold text-accent">0</p>
      <p class="text-xs font-mono text-text-muted">flips</p>
    </div>
    <div class="p-4 bg-bg-surface border border-border-subtle rounded-xl text-center space-y-1">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Tails</p>
      <p id="cf-tails" class="text-2xl font-heading font-bold text-text-primary">0</p>
      <p id="cf-tails-pct" class="text-xs font-mono text-text-muted">—</p>
    </div>
  </div>

  <!-- Streak -->
  <div class="grid grid-cols-2 gap-3">
    <div class="p-3 bg-bg-elevated border border-border-subtle rounded-xl text-center">
      <p class="text-[10px] font-mono text-text-muted uppercase tracking-widest">Current streak</p>
      <p id="cf-streak" class="text-lg font-semibold text-text-primary mt-1">—</p>
    </div>
    <div class="p-3 bg-bg-elevated border border-border-subtle rounded-xl text-center">
      <p class="text-[10px] font-mono text-text-muted uppercase tracking-widest">Longest streak</p>
      <p id="cf-longest" class="text-lg font-semibold text-text-primary mt-1">—</p>
    </div>
  </div>

  <!-- Multi-flip -->
  <div class="p-4 bg-bg-surface border border-border-subtle rounded-xl space-y-3">
    <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Simulate many flips</p>
    <div class="flex gap-2 flex-wrap">
      {[10, 100, 1000, 10000].map(n => (
        <button class="cf-multi px-4 py-2 text-xs font-mono bg-bg-elevated border border-border-subtle rounded-lg text-text-muted hover:text-accent hover:border-accent/40 transition-all" data-n={n}>
          Flip {n.toLocaleString()}×
        </button>
      ))}
    </div>
    <div id="cf-multi-result" class="text-xs font-mono text-text-muted min-h-[1.2rem]"></div>
  </div>

</div>

<style>
  .coin-scene {
    perspective: 700px;
    width: 120px;
    height: 120px;
  }
  .coin {
    width: 120px;
    height: 120px;
    position: relative;
    transform-style: preserve-3d;
    transform: rotateY(0deg);
  }
  .coin.flipping {
    animation: coinFlip var(--flip-duration, 0.7s) cubic-bezier(0.33,0,0.3,1) forwards;
  }
  @keyframes coinFlip {
    0%   { transform: rotateY(0deg); }
    100% { transform: rotateY(var(--flip-end, 1800deg)); }
  }
  .coin-face {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    backface-visibility: hidden;
    overflow: hidden;
    box-shadow:
      0 0 0 2px #7a4800,
      0 10px 40px rgba(160,100,10,0.45),
      inset 0 1px 2px rgba(255,255,200,0.2);
  }
  .coin-tails {
    transform: rotateY(180deg);
  }
  .coin-face svg {
    display: block;
    border-radius: 50%;
  }
</style>

<script>
  const initCf = () => {
    const app = document.getElementById('cf-app');
    if (!app || (app as any)._cfInit) return;
    (app as any)._cfInit = true;

    const coin        = document.getElementById('cf-coin')!;
    const flipBtn     = document.getElementById('cf-flip-btn')!;
    const resultText  = document.getElementById('cf-result-text')!;
    const streakText  = document.getElementById('cf-streak-text')!;
    const headsEl     = document.getElementById('cf-heads')!;
    const tailsEl     = document.getElementById('cf-tails')!;
    const totalEl     = document.getElementById('cf-total')!;
    const headsPct    = document.getElementById('cf-heads-pct')!;
    const tailsPct    = document.getElementById('cf-tails-pct')!;
    const streakEl    = document.getElementById('cf-streak')!;
    const longestEl   = document.getElementById('cf-longest')!;
    const multiResult = document.getElementById('cf-multi-result')!;

    let heads = 0, tails = 0, curStreak = 0, curSide = '', longestStreak = 0, longestSide = '';
    let flipping = false;

    const secureRand = (): boolean => {
      const arr = new Uint32Array(1);
      crypto.getRandomValues(arr);
      return (arr[0] % 2) === 0;
    };

    const updateStats = () => {
      const total = heads + tails;
      headsEl.textContent = heads.toLocaleString();
      tailsEl.textContent = tails.toLocaleString();
      totalEl.textContent = total.toLocaleString();
      headsPct.textContent = total ? (heads/total*100).toFixed(1) + '%' : '—';
      tailsPct.textContent = total ? (tails/total*100).toFixed(1) + '%' : '—';
      streakEl.textContent = curStreak > 0 ? `${curStreak}× ${curSide}` : '—';
      longestEl.textContent = longestStreak > 0 ? `${longestStreak}× ${longestSide}` : '—';
    };

    const recordFlip = (isHeads: boolean) => {
      const side = isHeads ? 'Heads' : 'Tails';
      isHeads ? heads++ : tails++;
      if (side === curSide) { curStreak++; }
      else { curStreak = 1; curSide = side; }
      if (curStreak > longestStreak) { longestStreak = curStreak; longestSide = curSide; }
      updateStats();
      if (curStreak >= 5) streakText.textContent = `🔥 ${curStreak} ${curSide.toLowerCase()} in a row!`;
      else if (curStreak >= 3) streakText.textContent = `${curStreak}× ${curSide.toLowerCase()} streak`;
      else streakText.textContent = '';
    };

    const flip = () => {
      if (flipping) return;
      flipping = true;
      (flipBtn as HTMLButtonElement).disabled = true;

      const isHeads = secureRand();
      const extraSpins = 3 + Math.floor(Math.random() * 3);
      const endAngle = extraSpins * 360 + (isHeads ? 0 : 180);
      const duration = 0.7 + Math.random() * 0.25;

      coin.style.setProperty('--flip-end', endAngle + 'deg');
      coin.style.setProperty('--flip-duration', duration + 's');
      coin.classList.add('flipping');

      setTimeout(() => {
        coin.classList.remove('flipping');
        coin.style.transform = `rotateY(${endAngle % 360}deg)`;
        resultText.textContent = isHeads ? 'Heads!' : 'Tails!';
        resultText.style.color = 'var(--color-accent)';
        recordFlip(isHeads);
        flipping = false;
        (flipBtn as HTMLButtonElement).disabled = false;
      }, duration * 1000 + 50);
    };

    flipBtn.addEventListener('click', flip);

    const onKey = (e: KeyboardEvent) => {
      if (e.key === ' ' && !['INPUT','TEXTAREA','SELECT','BUTTON'].includes((e.target as HTMLElement).tagName)) {
        e.preventDefault(); flip();
      }
    };
    document.addEventListener('keydown', onKey);
    document.addEventListener('astro:before-swap', () => document.removeEventListener('keydown', onKey), { once: true });

    app.querySelectorAll<HTMLButtonElement>('.cf-multi').forEach(btn => {
      btn.addEventListener('click', () => {
        const n = parseInt(btn.dataset.n || '10');
        let h = 0;
        for (let i = 0; i < n; i++) { if (secureRand()) h++; }
        const t = n - h;
        heads += h; tails += t;
        curStreak = 0; curSide = '';
        updateStats();
        multiResult.textContent = `${n.toLocaleString()} flips: ${h.toLocaleString()} heads (${(h/n*100).toFixed(1)}%), ${t.toLocaleString()} tails (${(t/n*100).toFixed(1)}%)`;
      });
    });

    document.addEventListener('app:reset', () => {
      heads = 0; tails = 0; curStreak = 0; curSide = ''; longestStreak = 0; longestSide = '';
      resultText.textContent = '\u00a0'; resultText.style.color = '';
      streakText.textContent = '\u00a0'; multiResult.textContent = '';
      coin.style.transform = 'rotateY(0deg)';
      updateStats();
    });
    document.addEventListener('app:copy', async () => {
      const total = heads + tails;
      const text = `Coin Flipper: ${total} flips — ${heads} heads (${total?((heads/total)*100).toFixed(1):'0'}%), ${tails} tails`;
      try { await navigator.clipboard.writeText(text); } catch {}
    });
  };

  initCf();
  document.addEventListener('astro:after-swap', initCf);
</script>
