---
interface Props {
  license?: string;
  slug: string;
}

const { license = 'MIT', slug } = Astro.props;
const sourceUrl = `https://github.com/drajb/gekro/tree/main/apps/web/src/components/apps/${slug}`;
---

<div class="mt-12 pt-8 border-t border-border-subtle flex flex-wrap items-center gap-x-4 gap-y-1 text-[10px] font-mono text-text-muted">
  <span>© 2026 Rohit Burani</span>
  <span class="text-border">·</span>
  <span>{license}</span>
  <span class="text-border">·</span>
  <a href="https://gekro.com" class="hover:text-accent transition-colors">Built at gekro.com</a>
  <span class="text-border">·</span>
  <a href={sourceUrl} target="_blank" rel="noopener noreferrer" class="hover:text-accent transition-colors">View source ↗</a>
</div>
