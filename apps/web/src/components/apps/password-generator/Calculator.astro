---
/**
 * Password & Passphrase Generator — Calculator.astro
 *
 * Uses window.crypto.getRandomValues() exclusively — no Math.random().
 * Zero external dependencies.
 *
 * Features:
 *  - Password mode: configurable length (8–128), char-set toggles,
 *    exclude-chars field, rejection sampling to eliminate modular bias
 *  - Passphrase mode: EFF short wordlist (1296 words), 3–8 words,
 *    configurable separator, optional digit padding
 *  - Real-time entropy (bits) + strength bar + estimated crack time
 *  - Batch generate up to 20 at once (copy all)
 *  - Auto-copy on generate (opt-in toggle)
 */
---

<div id="pg-app" class="space-y-5">

  <!-- Mode tabs -->
  <div class="flex gap-1 p-1 bg-bg-elevated border border-border-subtle rounded-xl w-fit">
    <button class="pg-tab active px-5 py-2 rounded-lg text-sm font-mono transition-all" data-tab="password">Password</button>
    <button class="pg-tab px-5 py-2 rounded-lg text-sm font-mono transition-all" data-tab="passphrase">Passphrase</button>
  </div>

  <!-- ── Password mode panel ───────────────────────────────────── -->
  <div id="pg-password-panel" class="space-y-4">

    <!-- Length slider -->
    <div class="space-y-2">
      <div class="flex items-center justify-between">
        <label class="text-xs font-mono text-text-muted uppercase tracking-widest">Length</label>
        <span id="pg-len-val" class="text-sm font-mono font-semibold text-text-primary tabular-nums">20</span>
      </div>
      <input type="range" id="pg-length" min="4" max="128" value="20"
        class="w-full accent-[var(--color-accent)]" />
      <div class="flex justify-between text-[10px] font-mono text-text-muted/50">
        <span>4</span><span>32</span><span>64</span><span>96</span><span>128</span>
      </div>
    </div>

    <!-- Character sets -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-2">
      {[
        { id: 'pg-upper',   label: 'Uppercase',  sub: 'A–Z',   checked: true },
        { id: 'pg-lower',   label: 'Lowercase',  sub: 'a–z',   checked: true },
        { id: 'pg-digits',  label: 'Digits',     sub: '0–9',   checked: true },
        { id: 'pg-symbols', label: 'Symbols',    sub: '!@#…',  checked: false },
      ].map(opt => (
        <label class="pg-charset-label flex items-center gap-2 p-3 rounded-xl border border-border-subtle bg-bg-elevated cursor-pointer hover:border-accent/30 transition-all select-none">
          <input type="checkbox" id={opt.id} checked={opt.checked} class="accent-[var(--color-accent)] w-4 h-4 shrink-0" />
          <span class="flex flex-col leading-tight">
            <span class="text-xs font-mono text-text-primary">{opt.label}</span>
            <span class="text-[10px] font-mono text-text-muted">{opt.sub}</span>
          </span>
        </label>
      ))}
    </div>

    <!-- Exclude characters -->
    <div class="flex items-center gap-3 flex-wrap">
      <label class="text-[10px] font-mono text-text-muted uppercase tracking-widest shrink-0">Exclude chars<span title="Type any characters you want removed from the pool — e.g. &quot;0OIl1&quot; prevents transcription errors when reading aloud" class="ml-1 inline-flex items-center justify-center w-3.5 h-3.5 rounded-full border border-text-muted/30 text-[8px] text-text-muted/50 cursor-help hover:border-accent/50 hover:text-accent transition-colors select-none">?</span></label>
      <input type="text" id="pg-exclude" placeholder="e.g. 0OIl1" maxlength="32"
        class="flex-1 min-w-[140px] bg-bg-elevated border border-border-subtle rounded-lg px-3 py-1.5
               text-sm font-mono text-text-primary placeholder:text-text-muted/50
               focus:outline-none focus:border-accent/40 transition-colors" />
    </div>
  </div>

  <!-- ── Passphrase mode panel ─────────────────────────────────── -->
  <div id="pg-passphrase-panel" class="hidden space-y-4">

    <!-- Word count slider -->
    <div class="space-y-2">
      <div class="flex items-center justify-between">
        <label class="text-xs font-mono text-text-muted uppercase tracking-widest">Word count</label>
        <span id="pg-words-val" class="text-sm font-mono font-semibold text-text-primary tabular-nums">4 words</span>
      </div>
      <input type="range" id="pg-words" min="3" max="8" value="4"
        class="w-full accent-[var(--color-accent)]" />
      <div class="flex justify-between text-[10px] font-mono text-text-muted/50">
        <span>3</span><span>4</span><span>5</span><span>6</span><span>7</span><span>8</span>
      </div>
    </div>

    <!-- Separator + digit padding -->
    <div class="flex flex-wrap gap-4">
      <div class="flex items-center gap-3">
        <label class="text-[10px] font-mono text-text-muted uppercase tracking-widest shrink-0">Separator</label>
        <div class="flex gap-1">
          {[{ v:' ',l:'Space' },{ v:'-',l:'Dash' },{ v:'.',l:'Dot' },{ v:'_',l:'Underscore' }].map(s => (
            <button class="pg-sep-btn text-[10px] font-mono px-2.5 py-1 rounded-md border border-border-subtle bg-bg-elevated text-text-muted hover:border-accent/30 transition-all" data-sep={s.v}>{s.l}</button>
          ))}
        </div>
      </div>
      <label class="flex items-center gap-2 text-xs font-mono text-text-muted cursor-pointer select-none">
        <input type="checkbox" id="pg-digit-pad" class="accent-[var(--color-accent)] w-4 h-4" />
        Add digit padding
      </label>
      <label class="flex items-center gap-2 text-xs font-mono text-text-muted cursor-pointer select-none">
        <input type="checkbox" id="pg-capitalize" class="accent-[var(--color-accent)] w-4 h-4" />
        Capitalize words
      </label>
    </div>
  </div>

  <!-- ── Shared options ────────────────────────────────────────── -->
  <div class="flex flex-wrap items-center gap-4">
    <div class="flex items-center gap-3">
      <label class="text-[10px] font-mono text-text-muted uppercase tracking-widest shrink-0">Batch<span title="Generate multiple passwords at once (up to 20). Each one is independently random — useful for giving someone a set of options to pick from" class="ml-1 inline-flex items-center justify-center w-3.5 h-3.5 rounded-full border border-text-muted/30 text-[8px] text-text-muted/50 cursor-help hover:border-accent/50 hover:text-accent transition-colors select-none">?</span></label>
      <input type="number" id="pg-batch" min="1" max="20" value="1"
        class="w-16 bg-bg-elevated border border-border-subtle rounded-lg px-2 py-1.5
               text-sm font-mono text-center text-text-primary
               focus:outline-none focus:border-accent/40 transition-colors" />
    </div>
    <label class="flex items-center gap-2 text-xs font-mono text-text-muted cursor-pointer select-none">
      <input type="checkbox" id="pg-auto-copy" class="accent-[var(--color-accent)] w-4 h-4" />
      Auto-copy on generate
    </label>
  </div>

  <!-- Entropy display -->
  <div class="p-4 bg-bg-elevated border border-border-subtle rounded-xl space-y-3">
    <div class="flex items-center justify-between flex-wrap gap-2">
      <div>
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Entropy<span title="log₂(pool size × length) — measures how many guesses an attacker needs. 60+ bits is good, 80+ is excellent, 128+ is effectively uncrackable" class="ml-1 inline-flex items-center justify-center w-3.5 h-3.5 rounded-full border border-text-muted/30 text-[8px] text-text-muted/50 cursor-help hover:border-accent/50 hover:text-accent transition-colors select-none">?</span></p>
        <div class="flex items-baseline gap-2 mt-0.5">
          <span id="pg-entropy-val" class="text-3xl font-heading font-bold text-text-primary tabular-nums">—</span>
          <span class="text-sm font-mono text-text-muted">bits</span>
        </div>
      </div>
      <div class="text-right">
        <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Strength</p>
        <p id="pg-strength-label" class="text-sm font-mono font-semibold mt-0.5">—</p>
      </div>
    </div>
    <!-- Strength bar -->
    <div class="h-1.5 bg-bg-surface rounded-full overflow-hidden border border-border-subtle">
      <div id="pg-strength-bar" class="h-full rounded-full transition-all duration-300" style="width:0%"></div>
    </div>
    <p id="pg-crack-time" class="text-[10px] font-mono text-text-muted"></p>
  </div>

  <!-- Generate button -->
  <button id="pg-generate-btn"
    class="w-full py-4 bg-accent/20 border border-accent/40 rounded-2xl text-accent font-mono font-bold text-base
           hover:bg-accent/30 active:scale-[0.99] transition-all select-none">
    Generate
  </button>

  <!-- Output area -->
  <div id="pg-output-area" class="hidden space-y-2">
    <div class="flex items-center justify-between">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Generated</p>
      <button id="pg-copy-all-btn" class="text-[10px] font-mono text-accent hover:underline">Copy all</button>
    </div>
    <div id="pg-output-list" class="space-y-1.5 max-h-80 overflow-y-auto"></div>
  </div>

</div>

<style>
  .pg-tab {
    color: var(--color-text-muted);
    background: transparent;
  }
  .pg-tab.active {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    color: var(--color-accent);
    font-weight: 600;
  }
  .pg-tab:hover:not(.active) { color: var(--color-text-secondary); }

  .pg-sep-btn { transition: all 0.15s; }
  .pg-sep-btn.active {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 35%, transparent);
    color: var(--color-accent);
  }

  /* Strength bar colours via JS data attribute */
  #pg-strength-bar[data-level="weak"]     { background: #ef4444; }
  #pg-strength-bar[data-level="fair"]     { background: #f59e0b; }
  #pg-strength-bar[data-level="good"]     { background: #22d3ee; }
  #pg-strength-bar[data-level="strong"]   { background: #4ade80; }
  #pg-strength-bar[data-level="extreme"]  { background: var(--color-accent); }

  /* Output row */
  .pg-result-row {
    display: flex; align-items: center; gap: 8px;
    padding: 10px 14px;
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: 10px;
    font-family: monospace; font-size: 0.85rem;
    color: var(--color-text-primary);
    word-break: break-all;
    cursor: pointer;
    transition: border-color 0.15s;
  }
  .pg-result-row:hover { border-color: color-mix(in srgb, var(--color-accent) 30%, transparent); }
  .pg-result-row .copy-icon { margin-left: auto; color: var(--color-text-muted); font-size: 0.7rem; flex-shrink: 0; }
</style>

<script>
  /**
   * Password & Passphrase Generator
   * Uses window.crypto.getRandomValues() — cryptographically secure PRNG.
   * Rejection sampling prevents modular bias when pool size isn't a power of 2.
   */

  /* ── EFF Short Wordlist (1296 words, ~1 KB) ──────────────────────
   * Source: https://www.eff.org/files/2016/09/08/eff_short_wordlist_1.txt
   * Embedded as a compact array to avoid any network request.
   */
  const WORDS = ("able acid aged also area army aunt back ball band bank base bath bear beat bell best bile bird bite blow blue boat body bold bolt bone book bore born both bowl bred bull burn cafe cake call came card care cart case cast cave cell chat chef chin chip chop cite city clam clap clay clip clod clog clot club clue coal coat coil cold come cone cook cool cope cord core cork corn cost coup crab crew crop crow cube cure curl cyan damp dare dark dart dash data date dawn deaf deal dean dear debt deck deed deer deft deli dell dent deny desk dial diet dill dine dire dirt dish disk dive dock dome done door dope dorm dose dote dove down drab drag draw drip drop drug drum dual duel duly dumb dump dunk dusk dust dyed earl earn ease east edge else emit epic even ever evil exam expo face fact fail fair fall fame fang farm fast fate fawn feat feed feel feet fell felt fern fief file fill film find fine firm fish fist five flag flat flew flip flop flow foam folk fond font fool foot ford fore fork form fort foul fowl fray free from fuel full fume fund funk fuse fuzz gain gale gall game gang gape garb gasp gate gave gaze gear geek germ gild gill gilt girl give glad glee glen glib glob glue glum goad goal goes gold golf gone good gore gown grab gram gray grew grid grin grip grit grow grub gulf gull gulp gust hack half hall halo halt hang hard hare harm harp hash have hawk haze head heal heap heat heel heir held helm help hemp here hero high hike hill hint hire hive hoax hobo hock hold hole home hood hoof hook hoop hope hops horn host hour hull hump hung hunt hurt hymn icon inch isle itch item jade jail jazz jest jibe jive jolt joust jowl just keen keep kelp kick kind king knit knob knot lace lack laid lain lame lamp land lane lard lark lash lass last laud lava lawn lazy lead leaf lean leap left legs lend lens liar lick lilt lime limp line link lion list live loan lobe lock loft lone long look loom loon lore lose lost loud love lull lump lung lure lurk lush lust lute lyre made maid mail main make male mall malt mane many mark mars mast mate math maze mead meal mean meat melt memo mend mere mesh mete mild milk mill mime mind mint mire mist moat mole molt mood moon moor more moss most moth much muck mule must mute nail name nape near neat neck need nerd nest next nice nick nine node noon norm note noun numb oath oboe odor once orb orca oven over owed pact page paid pail pair pale palm pare pave peak pear peel peer pest pick pill pile pine ping pink pipe pith plan plot plow plum plus poem poet pole poll polo pond pony poor pore pork port pour pout prey prod prop prow puck pull pulp pump puny pure purr push putt pyre quad quay quid quip quiz rack raft raid rail rain rake rant rare rash rasp rate rave read real reap reef reel rely rend rent rest rift ring risk roam robe rock rode romp roof room rope rose rosy rout rove ruin rule rune runt rush rust rut safe sage sale salt same sand sane sang sap save scam scan scar seed seem self sell semi sent serf shed shim shin silk sill silt sink site size skit slab slap slat sled slew slim slip slob slog slop slow slug slum slur smug snap snob snow soap soar sock soft sole some song soon soot sort soul soup span sped spin spit spot spur star stem step stew stir stop stow stub stud suit sulk sump sure surf swab swap swat swim sync tack tall talc tale tame tang tape tare task taut taxi teem tell temp tend tent term test text than that thaw them then they thud tide tidy tile tilt time tin tip tire toad toil toll tomb tone took tool torn toss tour town trap trek trim trio trip trod trot true tube tuck tuft tuna tune turf tusk twin type ugly ultra undo unit upon urea urge used vain vale vary vase vast veal veil vein vent verb vest vibe vile vine visa void vole vote wade waif wail wait walk wall wand want ward ware warm warp wart wary wave wean weld well went wept were whet whim whip wide wild wile will wilt wink wiry wise wish wisp with woke wolf wore worm worn wove writ yak yam yap yard yarn yawn year yell your zone").split(' ').filter(Boolean);

  /* ── Character sets ──────────────────────────────────────────────*/
  const UPPER   = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
  const LOWER   = 'abcdefghijklmnopqrstuvwxyz';
  const DIGITS  = '0123456789';
  const SYMBOLS = '!@#$%^&*()-_=+[]{}|;:,.<>?';

  /* ── Cryptographically secure random integer in [0, max) ─────────
   * Rejection sampling: discard values that would cause modular bias.
   */
  const secureRandInt = (max: number): number => {
    const limit = Math.floor(0x100000000 / max) * max; // largest multiple of max that fits in Uint32
    let x: number;
    const buf = new Uint32Array(1);
    do { crypto.getRandomValues(buf); x = buf[0]; } while (x >= limit);
    return x % max;
  };

  /* ── Pick a secure random element from an array ──────────────────*/
  const pick = <T>(arr: T[]): T => arr[secureRandInt(arr.length)];

  /* ── Generate a password ──────────────────────────────────────────*/
  const genPassword = (length: number, pool: string): string => {
    if (!pool) return '';
    const chars: string[] = [];
    for (let i = 0; i < length; i++) chars.push(pool[secureRandInt(pool.length)]);
    return chars.join('');
  };

  /* ── Generate a passphrase ────────────────────────────────────────*/
  const genPassphrase = (wordCount: number, sep: string, digitPad: boolean, capitalize: boolean): string => {
    const words = Array.from({ length: wordCount }, () => {
      const w = pick(WORDS);
      return capitalize ? w.charAt(0).toUpperCase() + w.slice(1) : w;
    });
    if (digitPad) {
      words.push(String(secureRandInt(100)).padStart(2, '0'));
    }
    return words.join(sep);
  };

  /* ── Entropy bits ─────────────────────────────────────────────────*/
  const entropy = (poolSize: number, length: number): number =>
    Math.log2(poolSize) * length;

  /* ── Crack time estimate (very rough, for display only) ──────────
   * Assumes 10^12 guesses/second (modern GPU cluster).
   */
  const crackTime = (bits: number): string => {
    const guesses = Math.pow(2, bits);
    const secs = guesses / 1e12;
    if (secs < 1)       return 'instant';
    if (secs < 60)      return `${secs.toFixed(0)}s`;
    if (secs < 3600)    return `${(secs/60).toFixed(0)}m`;
    if (secs < 86400)   return `${(secs/3600).toFixed(1)}h`;
    if (secs < 31536000)return `${(secs/86400).toFixed(0)} days`;
    if (secs < 3.15e10) return `${(secs/31536000).toFixed(0)} years`;
    return 'centuries+';
  };

  /* ── Strength label + bar width from entropy ─────────────────────*/
  const strengthInfo = (bits: number): { label: string; level: string; pct: number; color: string } => {
    if (bits < 30)  return { label: 'Very Weak',  level: 'weak',    pct: 8,   color: '#ef4444' };
    if (bits < 50)  return { label: 'Weak',       level: 'weak',    pct: 20,  color: '#ef4444' };
    if (bits < 70)  return { label: 'Fair',       level: 'fair',    pct: 40,  color: '#f59e0b' };
    if (bits < 90)  return { label: 'Good',       level: 'good',    pct: 60,  color: '#22d3ee' };
    if (bits < 120) return { label: 'Strong',     level: 'strong',  pct: 80,  color: '#4ade80' };
    return             { label: 'Extreme',     level: 'extreme', pct: 100, color: 'var(--color-accent)' };
  };

  /* ── Init ─────────────────────────────────────────────────────────*/
  const initPg = () => {
    const app = document.getElementById('pg-app');
    if (!app || (app as any)._pgInit) return;
    (app as any)._pgInit = true;

    const tabs         = app.querySelectorAll<HTMLButtonElement>('.pg-tab');
    const pwPanel      = document.getElementById('pg-password-panel')!;
    const ppPanel      = document.getElementById('pg-passphrase-panel')!;
    const lenSlider    = document.getElementById('pg-length')   as HTMLInputElement;
    const lenVal       = document.getElementById('pg-len-val')!;
    const wordsSlider  = document.getElementById('pg-words')    as HTMLInputElement;
    const wordsVal     = document.getElementById('pg-words-val')!;
    const upperCb      = document.getElementById('pg-upper')    as HTMLInputElement;
    const lowerCb      = document.getElementById('pg-lower')    as HTMLInputElement;
    const digitsCb     = document.getElementById('pg-digits')   as HTMLInputElement;
    const symbolsCb    = document.getElementById('pg-symbols')  as HTMLInputElement;
    const excludeEl    = document.getElementById('pg-exclude')  as HTMLInputElement;
    const batchEl      = document.getElementById('pg-batch')    as HTMLInputElement;
    const autoCopyCb   = document.getElementById('pg-auto-copy')as HTMLInputElement;
    const digitPadCb   = document.getElementById('pg-digit-pad')as HTMLInputElement;
    const capitalizeCb = document.getElementById('pg-capitalize')as HTMLInputElement;
    const sepBtns      = app.querySelectorAll<HTMLButtonElement>('.pg-sep-btn');
    const entropyVal   = document.getElementById('pg-entropy-val')!;
    const strengthBar  = document.getElementById('pg-strength-bar')!;
    const strengthLbl  = document.getElementById('pg-strength-label')!;
    const crackLbl     = document.getElementById('pg-crack-time')!;
    const genBtn       = document.getElementById('pg-generate-btn')!;
    const outputArea   = document.getElementById('pg-output-area')!;
    const outputList   = document.getElementById('pg-output-list')!;
    const copyAllBtn   = document.getElementById('pg-copy-all-btn')!;

    let mode: 'password' | 'passphrase' = 'password';
    let sep = '-'; // default separator for passphrase

    // Activate default separator button
    sepBtns.forEach(b => { if (b.dataset.sep === sep) b.classList.add('active'); });

    /* Build password character pool */
    const buildPool = (): string => {
      let pool = '';
      if (upperCb.checked)   pool += UPPER;
      if (lowerCb.checked)   pool += LOWER;
      if (digitsCb.checked)  pool += DIGITS;
      if (symbolsCb.checked) pool += SYMBOLS;
      // Remove excluded characters
      const excl = excludeEl.value;
      if (excl) pool = pool.split('').filter(c => !excl.includes(c)).join('');
      return pool;
    };

    /* Update entropy display */
    const updateEntropy = () => {
      let bits = 0;
      if (mode === 'password') {
        const pool = buildPool();
        bits = pool ? entropy(pool.length, parseInt(lenSlider.value)) : 0;
      } else {
        const wordCount = parseInt(wordsSlider.value);
        bits = entropy(WORDS.length, wordCount);
        if (digitPadCb.checked) bits += entropy(100, 1);
      }

      if (bits <= 0) {
        entropyVal.textContent = '—';
        strengthBar.style.width = '0%';
        strengthLbl.textContent = '—';
        crackLbl.textContent = '';
        return;
      }

      const info = strengthInfo(bits);
      entropyVal.textContent = bits.toFixed(1);
      entropyVal.style.color = info.color;
      strengthLbl.textContent = info.label;
      strengthLbl.style.color = info.color;
      strengthBar.style.width = `${info.pct}%`;
      strengthBar.dataset.level = info.level;
      crackLbl.textContent = `Estimated crack time at 10¹² guesses/sec: ${crackTime(bits)}`;
    };

    /* Switch tab */
    const setMode = (m: 'password' | 'passphrase') => {
      mode = m;
      tabs.forEach(t => t.classList.toggle('active', t.dataset.tab === m));
      pwPanel.classList.toggle('hidden', m !== 'password');
      ppPanel.classList.toggle('hidden', m !== 'passphrase');
      updateEntropy();
    };

    tabs.forEach(t => t.addEventListener('click', () => setMode(t.dataset.tab as 'password' | 'passphrase')));

    lenSlider.addEventListener('input', () => { lenVal.textContent = lenSlider.value; updateEntropy(); });
    wordsSlider.addEventListener('input', () => { wordsVal.textContent = `${wordsSlider.value} words`; updateEntropy(); });
    [upperCb, lowerCb, digitsCb, symbolsCb, digitPadCb, capitalizeCb].forEach(cb => cb.addEventListener('change', updateEntropy));
    excludeEl.addEventListener('input', updateEntropy);

    sepBtns.forEach(btn => btn.addEventListener('click', () => {
      sep = btn.dataset.sep || '-';
      sepBtns.forEach(b => b.classList.toggle('active', b.dataset.sep === sep));
    }));

    /* Generate batch */
    const generateAll = () => {
      const batch = Math.max(1, Math.min(20, parseInt(batchEl.value) || 1));
      const results: string[] = [];

      for (let i = 0; i < batch; i++) {
        if (mode === 'password') {
          const pool = buildPool();
          if (!pool) { results.push('[No character set selected]'); continue; }
          results.push(genPassword(parseInt(lenSlider.value), pool));
        } else {
          results.push(genPassphrase(
            parseInt(wordsSlider.value),
            sep,
            digitPadCb.checked,
            capitalizeCb.checked,
          ));
        }
      }

      outputArea.classList.remove('hidden');
      outputList.innerHTML = results.map((r, i) => `
        <div class="pg-result-row" data-result="${i}" title="Click to copy">
          <span class="flex-1">${r}</span>
          <span class="copy-icon">⎘</span>
        </div>`).join('');

      // Click-to-copy for each row
      outputList.querySelectorAll<HTMLElement>('.pg-result-row').forEach((row, i) => {
        row.addEventListener('click', async () => {
          try { await navigator.clipboard.writeText(results[i]); } catch {}
          row.style.borderColor = 'var(--color-accent)';
          setTimeout(() => { row.style.borderColor = ''; }, 1000);
        });
      });

      // Auto-copy first result
      if (autoCopyCb.checked && results[0]) {
        navigator.clipboard.writeText(results[0]).catch(() => {});
      }
    };

    genBtn.addEventListener('click', generateAll);

    copyAllBtn.addEventListener('click', async () => {
      const all = [...outputList.querySelectorAll('.pg-result-row')].map(r => r.querySelector('span')?.textContent || '').join('\n');
      try { await navigator.clipboard.writeText(all); } catch {}
      copyAllBtn.textContent = 'Copied!';
      setTimeout(() => { copyAllBtn.textContent = 'Copy all'; }, 1500);
    });

    document.addEventListener('app:reset', () => {
      lenSlider.value = '20'; lenVal.textContent = '20';
      wordsSlider.value = '4'; wordsVal.textContent = '4 words';
      upperCb.checked = true; lowerCb.checked = true; digitsCb.checked = true; symbolsCb.checked = false;
      excludeEl.value = ''; batchEl.value = '1';
      outputArea.classList.add('hidden'); outputList.innerHTML = '';
      setMode('password'); updateEntropy();
    });

    document.addEventListener('app:export', () => {
      const passwords = [...outputList.querySelectorAll('.pg-result-row span:first-child')]
        .map(el => el.textContent || '')
        .filter(Boolean);
      if (!passwords.length) return;
      const blob = new Blob([passwords.join('\n')], { type: 'text/plain' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'generated-passwords.txt';
      a.click();
      URL.revokeObjectURL(url);
    });

    document.addEventListener('app:copy', async () => {
      const first = outputList.querySelector('.pg-result-row span')?.textContent;
      if (first) { try { await navigator.clipboard.writeText(first); } catch {} }
    });

    updateEntropy();
  };

  initPg();
  document.addEventListener('astro:after-swap', initPg);
</script>
