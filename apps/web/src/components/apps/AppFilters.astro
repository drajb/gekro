---
const categories = [
  { id: 'ai',      label: 'AI' },
  { id: 'infra',   label: 'Infra' },
  { id: 'ev',      label: 'EV' },
  { id: 'trading', label: 'Trading' },
  { id: 'dev',     label: 'Dev' },
  { id: 'finance', label: 'Finance' },
];
---

<div class="space-y-4" id="app-filters">
  <!-- Search -->
  <div class="relative">
    <input
      type="search"
      id="apps-search"
      placeholder="Search apps..."
      autocomplete="off"
      class="w-full bg-bg-elevated border border-border rounded-xl pl-10 pr-4 py-3
             text-text-primary text-sm font-mono placeholder:text-text-muted
             focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent/20
             hover:border-border-subtle transition-colors"
    />
    <span class="absolute left-4 top-1/2 -translate-y-1/2 text-text-muted text-sm pointer-events-none">⌕</span>
  </div>

  <!-- Category chips -->
  <div class="flex flex-wrap gap-2">
    <button
      class="filter-chip active text-[10px] font-mono uppercase tracking-widest px-3 py-1.5 rounded-full border transition-all"
      data-category="all"
    >
      All
    </button>
    {categories.map(cat => (
      <button
        class="filter-chip text-[10px] font-mono uppercase tracking-widest px-3 py-1.5 rounded-full border transition-all"
        data-category={cat.id}
      >
        {cat.label}
      </button>
    ))}
  </div>
</div>

<script>
  const initFilters = () => {
    const search = document.getElementById('apps-search') as HTMLInputElement | null;
    const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
    const cards = document.querySelectorAll<HTMLElement>('.app-card');
    if (!search) return;

    let activeCategory = 'all';

    const applyFilters = () => {
      const query = search.value.toLowerCase().trim();
      cards.forEach(card => {
        const link = card as HTMLAnchorElement;
        const title = (link.querySelector('h3')?.textContent || '').toLowerCase();
        const job = (link.querySelector('p')?.textContent || '').toLowerCase();
        const category = (link.querySelector('[data-category-val]') as HTMLElement)?.dataset.categoryVal || '';

        const matchesSearch = !query || title.includes(query) || job.includes(query);
        const matchesCategory = activeCategory === 'all' || category === activeCategory;

        card.closest<HTMLElement>('[data-card-wrapper]')!.style.display =
          matchesSearch && matchesCategory ? '' : 'none';
      });

      // Show empty state if all cards hidden
      const anyVisible = [...cards].some(c => {
        const wrapper = c.closest<HTMLElement>('[data-card-wrapper]');
        return wrapper && wrapper.style.display !== 'none';
      });
      const emptyState = document.getElementById('apps-empty');
      if (emptyState) emptyState.style.display = anyVisible ? 'none' : '';
    };

    search.addEventListener('input', applyFilters);

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        activeCategory = chip.dataset.category || 'all';
        chips.forEach(c => {
          const isActive = c.dataset.category === activeCategory;
          c.classList.toggle('active', isActive);
        });
        applyFilters();
      });
    });
  };

  initFilters();
  document.addEventListener('astro:after-swap', initFilters);
</script>

<style>
  .filter-chip {
    background: var(--color-bg-elevated);
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }
  .filter-chip:hover {
    border-color: var(--color-border-subtle);
    color: var(--color-text-secondary);
  }
  .filter-chip.active {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    color: var(--color-accent);
  }
</style>
