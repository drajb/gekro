---
/**
 * Model Benchmark Comparator — Calculator.astro
 *
 * Static data comparison tool for 15 major LLMs.
 * No API calls. All data hardcoded from official model cards and public
 * leaderboards, verified April 2026.
 *
 * Metrics covered:
 *   Context & Pricing: input/output context window, price per 1M tokens (USD),
 *     batch pricing availability.
 *   Benchmarks: MMLU, HumanEval, MATH, GPQA-Diamond.
 *   Capabilities: vision, tool use, extended thinking, training cutoff.
 *
 * Highlights: best-in-row → text-emerald-400, worst-in-row → text-red-400/70.
 * Supports up to 4 simultaneous model columns.
 *
 * Zero deps. Pure DOM.
 */
---

<div id="mb-app" class="space-y-5">

  <!-- Model picker -->
  <div class="space-y-2">
    <div class="flex items-center justify-between gap-3">
      <label class="text-[10px] font-mono uppercase tracking-widest text-text-muted">
        Select models to compare
        <span title="Pick up to 4 models. Defaults: GPT-4o, Claude 3.7 Sonnet, Gemini 2.0 Flash, Llama 3.3 70B." class="ml-1 inline-flex items-center justify-center w-3.5 h-3.5 rounded-full border border-text-muted/30 text-[8px] text-text-muted/50 cursor-help hover:border-accent/50 hover:text-accent transition-colors select-none">?</span>
      </label>
      <span id="mb-sel-count" class="text-[10px] font-mono text-accent">4 selected</span>
    </div>

    <!-- Provider groups -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3">
      <!-- OpenAI -->
      <div class="p-3 bg-bg-elevated border border-border-subtle rounded-xl space-y-2">
        <p class="text-[9px] font-mono uppercase tracking-widest text-text-muted">OpenAI</p>
        <div id="mb-openai-checks" class="space-y-1.5"></div>
      </div>
      <!-- Anthropic -->
      <div class="p-3 bg-bg-elevated border border-border-subtle rounded-xl space-y-2">
        <p class="text-[9px] font-mono uppercase tracking-widest text-text-muted">Anthropic</p>
        <div id="mb-anthropic-checks" class="space-y-1.5"></div>
      </div>
      <!-- Google -->
      <div class="p-3 bg-bg-elevated border border-border-subtle rounded-xl space-y-2">
        <p class="text-[9px] font-mono uppercase tracking-widest text-text-muted">Google</p>
        <div id="mb-google-checks" class="space-y-1.5"></div>
      </div>
      <!-- Meta + Mistral + DeepSeek -->
      <div class="p-3 bg-bg-elevated border border-border-subtle rounded-xl space-y-2">
        <p class="text-[9px] font-mono uppercase tracking-widest text-text-muted">Open / Other</p>
        <div id="mb-open-checks" class="space-y-1.5"></div>
      </div>
    </div>
  </div>

  <!-- Comparison table -->
  <div class="overflow-x-auto rounded-xl border border-border-subtle">
    <table id="mb-table" class="w-full min-w-[600px] text-sm">
      <thead id="mb-thead"></thead>
      <tbody id="mb-tbody"></tbody>
    </table>
  </div>

  <p class="text-[10px] font-mono text-text-muted">
    * Benchmarks sourced from official model cards and public leaderboards. Self-reported numbers may not be directly comparable across providers. Pricing as of April 2026 — check provider pages for current rates.
  </p>
</div>

<script>
  /**
   * Model Benchmark Comparator — client logic.
   * Pure data + DOM, zero deps.
   */

  /* ── Model data ─────────────────────────────────────────────────*/
  interface ModelData {
    id: string;
    name: string;
    provider: 'openai' | 'anthropic' | 'google' | 'open';
    // Context (tokens)
    inputCtx: number;
    outputCtx: number;
    // Pricing (USD per 1M tokens) — null = self-hosted / not applicable
    priceIn: number | null;
    priceOut: number | null;
    batchPricing: boolean;
    // Benchmarks (%) — null = not published
    mmlu: number | null;
    humaneval: number | null;
    math: number | null;
    gpqa: number | null;
    // Capabilities
    vision: boolean;
    toolUse: boolean;
    extendedThinking: boolean;
    cutoff: string;
  }

  // Data verified April 2026 from official model cards + public leaderboards.
  // Self-hosted models (Llama, Mistral) show null for pricing.
  const MODELS: ModelData[] = [
    {
      id: 'gpt-4o',
      name: 'GPT-4o',
      provider: 'openai',
      inputCtx: 128000, outputCtx: 16384,
      priceIn: 2.50, priceOut: 10.00, batchPricing: true,
