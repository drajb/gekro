      mmlu: 96.7, humaneval: 96.3, math: 96.7, gpqa: 87.7,
      vision: true, toolUse: true, extendedThinking: true,
      cutoff: 'Jun 2024',
    },
    {
      id: 'o4-mini',
      name: 'o4-mini',
      provider: 'openai',
      inputCtx: 200000, outputCtx: 100000,
      priceIn: 1.10, priceOut: 4.40, batchPricing: true,
      mmlu: 93.4, humaneval: 93.7, math: 99.5, gpqa: 79.7,
