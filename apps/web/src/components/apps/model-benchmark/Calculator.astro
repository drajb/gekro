      provider: 'anthropic',
      inputCtx: 200000, outputCtx: 8192,
      priceIn: 3.00, priceOut: 15.00, batchPricing: true,
      mmlu: 88.7, humaneval: 93.7, math: 78.3, gpqa: 65.0,
      vision: true, toolUse: true, extendedThinking: false,
      cutoff: 'Apr 2024',
    },
    {
      id: 'claude-37-sonnet',
      name: 'Claude 3.7 Sonnet',
      provider: 'anthropic',
      inputCtx: 200000, outputCtx: 128000,
      priceIn: 3.00, priceOut: 15.00, batchPricing: true,
      mmlu: 90.5, humaneval: 96.2, math: 81.0, gpqa: 68.9,
      vision: true, toolUse: true, extendedThinking: true,
      cutoff: 'Nov 2024',
    },
    {
      id: 'claude-35-haiku',
      name: 'Claude 3.5 Haiku',
      provider: 'anthropic',
      inputCtx: 200000, outputCtx: 8192,
      priceIn: 0.80, priceOut: 4.00, batchPricing: true,
      mmlu: 75.2, humaneval: 88.2, math: 69.4, gpqa: 41.6,
      vision: true, toolUse: true, extendedThinking: false,
      cutoff: 'Jul 2024',
    },
    {
      id: 'claude-opus-4',
      name: 'Claude Opus 4',
