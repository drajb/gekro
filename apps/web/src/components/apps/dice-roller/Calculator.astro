---
// Dice Roller — up to 4 dice, CSS 3D, crypto random, zero deps
---

<div id="dr-app" class="space-y-6">

  <!-- Die count selector -->
  <div class="flex items-center gap-3">
    <p class="text-xs font-mono text-text-muted shrink-0">Number of dice</p>
    <div class="flex gap-1.5">
      {[1,2,3,4].map(n => (
        <button
          class="dr-count-btn w-10 h-10 rounded-xl border text-sm font-mono font-semibold transition-all"
          data-count={n}
        >{n}</button>
      ))}
    </div>
  </div>

  <!-- Dice tray -->
  <div id="dr-tray" class="flex flex-wrap justify-center gap-6 py-8 min-h-[180px] items-center">
    <!-- dice injected by JS -->
  </div>

  <!-- Result + roll button -->
  <div class="flex flex-col items-center gap-4">
    <div class="text-center min-h-[4rem] space-y-1">
      <p id="dr-sum-label" class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Total</p>
      <p id="dr-sum" class="text-5xl font-heading font-bold text-accent tabular-nums">&nbsp;</p>
      <p id="dr-values" class="text-xs font-mono text-text-muted">&nbsp;</p>
    </div>

    <button id="dr-roll-btn"
      class="px-12 py-4 bg-accent/20 border border-accent/40 rounded-2xl text-accent font-mono font-bold text-lg
             hover:bg-accent/30 active:scale-95 transition-all select-none">
      Roll
    </button>
    <p class="text-[10px] font-mono text-text-muted">Press <kbd class="px-1.5 py-0.5 bg-bg-elevated border border-border-subtle rounded text-[10px]">Space</kbd> to roll</p>
  </div>

  <!-- History -->
  <div class="space-y-2">
    <div class="flex items-center justify-between px-1">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Roll history</p>
      <button id="dr-clear-history" class="text-[10px] font-mono text-text-muted hover:text-red-400 transition-colors">Clear</button>
    </div>
    <div id="dr-history"
      class="max-h-40 overflow-y-auto rounded-xl border border-border-subtle bg-bg-elevated divide-y divide-border-subtle">
      <p id="dr-history-empty" class="px-4 py-3 text-xs font-mono text-text-muted/50 text-center">No rolls yet</p>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-3 gap-3">
    <div class="p-3 bg-bg-surface border border-border-subtle rounded-xl text-center">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Rolls</p>
      <p id="dr-stat-rolls" class="text-xl font-heading font-bold text-text-primary mt-1">0</p>
    </div>
    <div class="p-3 bg-bg-surface border border-border-subtle rounded-xl text-center">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Avg total</p>
      <p id="dr-stat-avg" class="text-xl font-heading font-bold text-text-primary mt-1">—</p>
    </div>
    <div class="p-3 bg-bg-surface border border-border-subtle rounded-xl text-center">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Best roll</p>
      <p id="dr-stat-best" class="text-xl font-heading font-bold text-accent mt-1">—</p>
    </div>
  </div>

</div>

<style>
  /* Count button states */
  .dr-count-btn {
    background: var(--color-bg-elevated);
    border-color: var(--color-border-subtle);
    color: var(--color-text-muted);
  }
  .dr-count-btn.active {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    color: var(--color-accent);
  }
  .dr-count-btn:hover:not(.active) {
    border-color: color-mix(in srgb, var(--color-accent) 25%, transparent);
    color: var(--color-text-secondary);
  }

  /* 3-D scene */
  .die-scene {
    perspective: 400px;
    width: 90px;
    height: 90px;
  }
  .die-cube {
    width: 90px;
    height: 90px;
    position: relative;
    transform-style: preserve-3d;
    transform: rotateX(-20deg) rotateY(30deg);
    transition: transform 0.1s;
  }
  .die-cube.rolling {
    animation: diceRoll var(--roll-dur, 0.6s) cubic-bezier(0.25,0.1,0.25,1) forwards;
  }
  @keyframes diceRoll {
    0%   { transform: rotateX(0deg)   rotateY(0deg)   rotateZ(0deg); }
    30%  { transform: rotateX(320deg) rotateY(200deg) rotateZ(90deg); }
    60%  { transform: rotateX(560deg) rotateY(400deg) rotateZ(180deg); }
    85%  { transform: rotateX(var(--rx) + 20deg) rotateY(var(--ry)) rotateZ(var(--rz)); }
    100% { transform: rotateX(var(--rx)) rotateY(var(--ry)) rotateZ(var(--rz)); }
  }
  .die-face {
    position: absolute;
    width: 90px;
    height: 90px;
    border-radius: 14px;
    backface-visibility: hidden;
    display: grid;
    place-items: center;
    background: var(--color-bg-surface);
    border: 2px solid var(--color-border-subtle);
    box-shadow: inset 0 1px 3px rgba(255,255,255,0.06), inset 0 -2px 4px rgba(0,0,0,0.3);
  }
  .die-face.face-front  { transform: translateZ(45px); }
  .die-face.face-back   { transform: rotateY(180deg) translateZ(45px); }
  .die-face.face-right  { transform: rotateY(90deg)  translateZ(45px); }
  .die-face.face-left   { transform: rotateY(-90deg) translateZ(45px); }
  .die-face.face-top    { transform: rotateX(90deg)  translateZ(45px); }
  .die-face.face-bottom { transform: rotateX(-90deg) translateZ(45px); }

  /* Pip grid */
  .pip-grid {
    display: grid;
    width: 68px;
    height: 68px;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 1fr);
    gap: 0;
    place-items: center;
  }
  .pip {
    width: 11px;
    height: 11px;
    border-radius: 50%;
    background: var(--color-text-primary);
    box-shadow: 0 1px 2px rgba(0,0,0,0.5);
  }
  .pip.accent { background: var(--color-accent); }
  .pip.invisible { visibility: hidden; }
</style>

<script>
  // Pip layout per face value: 9 cells (3×3), each entry is visible (true) or not
  const PIP_LAYOUTS: Record<number, boolean[]> = {
    1: [F,F,F, F,T,F, F,F,F],
    2: [T,F,F, F,F,F, F,F,T],
    3: [T,F,F, F,T,F, F,F,T],
    4: [T,F,T, F,F,F, T,F,T],
    5: [T,F,T, F,T,F, T,F,T],
    6: [T,F,T, T,F,T, T,F,T],
  };
  // @ts-ignore — F/T used as shorthand above
  var F=false, T=true; // hoisted, used in PIP_LAYOUTS literal

  // CSS rotation to show each face value as front face
  // Standard die: 1 opp 6, 2 opp 5, 3 opp 4; right-hand rule
  const FACE_ROTATIONS: Record<number, [number,number,number]> = {
    1: [0, 0, 0],         // front
    6: [0, 180, 0],       // back
    2: [0, -90, 0],       // left
    5: [0, 90, 0],        // right
    3: [-90, 0, 0],       // top
    4: [90, 0, 0],        // bottom
  };

  const makePips = (value: number, isAccent = false): string => {
    const layout = PIP_LAYOUTS[value] || PIP_LAYOUTS[1];
    return `<div class="pip-grid">${layout.map(v =>
      `<div class="pip${v ? (isAccent ? ' accent' : '') : ' invisible'}"></div>`
    ).join('')}</div>`;
  };

  const makeDie = (id: number): string => {
    // Build a static cube; JS will update face content per roll
    const faces = ['front','back','right','left','top','bottom'];
    return `
      <div class="die-scene" id="dr-scene-${id}">
        <div class="die-cube" id="dr-cube-${id}">
          ${faces.map(f => `<div class="die-face face-${f}" id="dr-face-${f}-${id}"></div>`).join('')}
        </div>
      </div>`;
  };

  const setDieFaces = (id: number, value: number) => {
    // Map each physical face of the cube to a die value so the front shows `value`
    // Standard die adjacency: front=value, back=7-value, right=5, left=2, top=3, bottom=4
    // (simplified: front always shows value, back=7-value, others fixed)
    const faceValues: Record<string, number> = {
      front:  value,
      back:   7 - value,
      right:  5,
      left:   2,
      top:    3,
      bottom: 4,
    };
    // Avoid duplicates for edge values
    if (value === 2) { faceValues.left = 6; faceValues.right = 1; }
    if (value === 5) { faceValues.right = 6; faceValues.left = 1; }
    if (value === 3) { faceValues.top = 6; faceValues.bottom = 1; }
    if (value === 4) { faceValues.bottom = 6; faceValues.top = 1; }

    Object.entries(faceValues).forEach(([face, val]) => {
      const el = document.getElementById(`dr-face-${face}-${id}`);
      if (el) el.innerHTML = makePips(val, face === 'front');
    });
  };

  const initDr = () => {
    const app = document.getElementById('dr-app');
    if (!app || (app as any)._drInit) return;
    (app as any)._drInit = true;

    const tray      = document.getElementById('dr-tray')!;
    const sumEl     = document.getElementById('dr-sum')!;
    const sumLabel  = document.getElementById('dr-sum-label')!;
    const valuesEl  = document.getElementById('dr-values')!;
    const rollBtn   = document.getElementById('dr-roll-btn')!;
    const histEl    = document.getElementById('dr-history')!;
    const emptyHist = document.getElementById('dr-history-empty')!;
    const clearHist = document.getElementById('dr-clear-history')!;
    const statRolls = document.getElementById('dr-stat-rolls')!;
    const statAvg   = document.getElementById('dr-stat-avg')!;
    const statBest  = document.getElementById('dr-stat-best')!;
    const countBtns = app.querySelectorAll<HTMLButtonElement>('.dr-count-btn');

    let diceCount = 1;
    let rolling = false;
    let totalRolls = 0, sumOfTotals = 0, bestTotal = 0;
    let history: { values: number[]; total: number }[] = [];

    const randD6 = (): number => {
      const arr = new Uint32Array(1);
      crypto.getRandomValues(arr);
      return (arr[0] % 6) + 1;
    };

    const setCount = (n: number) => {
      diceCount = n;
      countBtns.forEach(b => b.classList.toggle('active', parseInt(b.dataset.count || '1') === n));
      tray.innerHTML = Array.from({length: n}, (_, i) => makeDie(i)).join('');
      // Init all faces to 1
      for (let i = 0; i < n; i++) setDieFaces(i, 1);
      sumEl.textContent = '\u00a0';
      valuesEl.textContent = '\u00a0';
    };

    const roll = () => {
      if (rolling) return;
      rolling = true;
      (rollBtn as HTMLButtonElement).disabled = true;

      const results: number[] = Array.from({length: diceCount}, () => randD6());

      // Animate each die
      results.forEach((val, i) => {
        const cube = document.getElementById(`dr-cube-${i}`)!;
        const [rx, ry, rz] = FACE_ROTATIONS[val];
        const spinX = (3 + Math.floor(Math.random() * 3)) * 360 + rx;
        const spinY = (3 + Math.floor(Math.random() * 3)) * 360 + ry;
        const dur = 0.55 + Math.random() * 0.2 + i * 0.05;

        cube.style.setProperty('--rx', rx + 'deg');
        cube.style.setProperty('--ry', ry + 'deg');
        cube.style.setProperty('--rz', rz + 'deg');
        cube.style.setProperty('--roll-dur', dur + 's');
        cube.style.animation = 'none';
        void cube.offsetWidth; // reflow
        cube.classList.add('rolling');

        setTimeout(() => {
          cube.classList.remove('rolling');
          cube.style.transform = `rotateX(${rx}deg) rotateY(${ry}deg) rotateZ(${rz}deg)`;
          setDieFaces(i, val);
        }, dur * 1000 + 30);
      });

      const maxDur = 0.55 + 0.2 + (diceCount - 1) * 0.05 + 0.1;
      setTimeout(() => {
        const total = results.reduce((s, v) => s + v, 0);
        sumEl.textContent = String(total);
        sumLabel.textContent = diceCount > 1 ? 'Total' : 'Result';
        valuesEl.textContent = diceCount > 1 ? `[${results.join(' + ')}]` : '';

        // Stats
        totalRolls++;
        sumOfTotals += total;
        if (total > bestTotal) bestTotal = total;
        statRolls.textContent = String(totalRolls);
        statAvg.textContent = (sumOfTotals / totalRolls).toFixed(1);
        statBest.textContent = String(bestTotal);

        // History (newest first)
        history.unshift({ values: results, total });
        emptyHist.style.display = 'none';
        const row = document.createElement('div');
        row.className = 'px-4 py-2 flex items-center justify-between text-xs font-mono';
        row.innerHTML = `
          <span class="text-text-muted">#${totalRolls}</span>
          <span class="text-text-secondary">[${results.join(', ')}]</span>
          <span class="font-semibold text-text-primary">${total}</span>`;
        histEl.insertBefore(row, histEl.firstChild);

        rolling = false;
        (rollBtn as HTMLButtonElement).disabled = false;
      }, maxDur * 1000);
    };

    rollBtn.addEventListener('click', roll);

    clearHist.addEventListener('click', () => {
      history = [];
      [...histEl.querySelectorAll('div:not(#dr-history-empty)')].forEach(el => el.remove());
      emptyHist.style.display = '';
    });

    countBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        if (!rolling) setCount(parseInt(btn.dataset.count || '1'));
      });
    });

    const onKey = (e: KeyboardEvent) => {
      if (e.key === ' ' && !['INPUT','TEXTAREA','SELECT','BUTTON'].includes((e.target as HTMLElement).tagName)) {
        e.preventDefault(); roll();
      }
    };
    document.addEventListener('keydown', onKey);
    document.addEventListener('astro:before-swap', () => document.removeEventListener('keydown', onKey), { once: true });

    document.addEventListener('app:reset', () => {
      history = []; totalRolls = 0; sumOfTotals = 0; bestTotal = 0;
      [...histEl.querySelectorAll('div:not(#dr-history-empty)')].forEach(el => el.remove());
      emptyHist.style.display = '';
      statRolls.textContent = '0'; statAvg.textContent = '—'; statBest.textContent = '—';
      sumEl.textContent = '\u00a0'; valuesEl.textContent = '\u00a0';
      setCount(1);
    });

    document.addEventListener('app:copy', async () => {
      const lines = history.slice(0, 10).map((h, i) =>
        `#${i+1}: [${h.values.join(', ')}] = ${h.total}`);
      try { await navigator.clipboard.writeText(lines.join('\n')); } catch {}
    });

    // Init with 1 die
    setCount(1);
  };

  initDr();
  document.addEventListener('astro:after-swap', initDr);
</script>
