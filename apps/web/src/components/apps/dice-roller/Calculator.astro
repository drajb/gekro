---
// Dice Roller — up to 4 dice, CSS 3D, player names, crypto random, zero deps
---

<div id="dr-app" class="space-y-6">

  <!-- Die count selector -->
  <div class="flex items-center gap-3">
    <p class="text-xs font-mono text-text-muted shrink-0">Number of dice</p>
    <div class="flex gap-1.5">
      {[1,2,3,4].map(n => (
        <button class="dr-count-btn w-10 h-10 rounded-xl border text-sm font-mono font-semibold transition-all" data-count={n}>{n}</button>
      ))}
    </div>
  </div>

  <!-- Dice tray — filled by JS -->
  <div id="dr-tray" class="flex flex-wrap justify-center gap-6 py-4"></div>

  <!-- Results row — individual + total -->
  <div id="dr-results-row" class="hidden">
    <div id="dr-individual-results" class="flex flex-wrap justify-center gap-4 items-end mb-4"></div>
    <div class="flex items-center justify-center gap-3">
      <span class="text-xs font-mono text-text-muted uppercase tracking-widest">Total</span>
      <p id="dr-sum" class="text-5xl font-heading font-bold tabular-nums" style="color:var(--color-accent)">&nbsp;</p>
    </div>
  </div>

  <!-- Roll button -->
  <div class="flex flex-col items-center gap-3">
    <button id="dr-roll-btn"
      class="px-12 py-4 bg-accent/20 border border-accent/40 rounded-2xl text-accent font-mono font-bold text-lg
             hover:bg-accent/30 active:scale-95 transition-all select-none">
      Roll
    </button>
    <p class="text-[10px] font-mono text-text-muted">Press <kbd class="px-1.5 py-0.5 bg-bg-elevated border border-border-subtle rounded text-[10px]">Space</kbd> to roll</p>
  </div>

  <!-- History -->
  <div class="space-y-2">
    <div class="flex items-center justify-between px-1">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Roll history</p>
      <button id="dr-clear-history" class="text-[10px] font-mono text-text-muted hover:text-red-400 transition-colors">Clear</button>
    </div>
    <div id="dr-history" class="max-h-44 overflow-y-auto rounded-xl border border-border-subtle bg-bg-elevated divide-y divide-border-subtle">
      <p id="dr-history-empty" class="px-4 py-3 text-xs font-mono text-text-muted/50 text-center">No rolls yet</p>
    </div>
  </div>

  <!-- Stats -->
  <div class="grid grid-cols-3 gap-3">
    <div class="p-3 bg-bg-surface border border-border-subtle rounded-xl text-center">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Rolls</p>
      <p id="dr-stat-rolls" class="text-xl font-heading font-bold text-text-primary mt-1">0</p>
    </div>
    <div class="p-3 bg-bg-surface border border-border-subtle rounded-xl text-center">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Avg total</p>
      <p id="dr-stat-avg" class="text-xl font-heading font-bold text-text-primary mt-1">—</p>
    </div>
    <div class="p-3 bg-bg-surface border border-border-subtle rounded-xl text-center">
      <p class="text-[10px] font-mono uppercase tracking-widest text-text-muted">Best roll</p>
      <p id="dr-stat-best" class="text-xl font-heading font-bold mt-1" style="color:var(--color-accent)">—</p>
    </div>
  </div>

</div>

<style is:global>
  /* Count buttons (template elements — scoping would work, but keeping global for consistency) */
  #dr-app .dr-count-btn {
    background: var(--color-bg-elevated);
    border-color: var(--color-border-subtle);
    color: var(--color-text-muted);
  }
  #dr-app .dr-count-btn.active {
    background: color-mix(in srgb, var(--color-accent) 12%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    color: var(--color-accent);
  }
  #dr-app .dr-count-btn:hover:not(.active) {
    border-color: color-mix(in srgb, var(--color-accent) 25%, transparent);
    color: var(--color-text-secondary);
  }

  /* 3-D scene — these elements are created via JS innerHTML so they need is:global */
  #dr-app .die-scene { perspective: 420px; width: 90px; height: 90px; }
  #dr-app .die-cube {
    width: 90px; height: 90px;
    position: relative;
    transform-style: preserve-3d;
    transform: rotateX(-20deg) rotateY(25deg);
  }
  #dr-app .die-cube.rolling {
    animation: diceRoll var(--roll-dur, 0.7s) cubic-bezier(0.2,0,0.4,1) forwards;
  }
  @keyframes diceRoll {
    0%   { transform: rotateX(0deg)    rotateY(0deg)    rotateZ(0deg);    }
    20%  { transform: rotateX(300deg)  rotateY(240deg)  rotateZ(120deg);  }
    45%  { transform: rotateX(720deg)  rotateY(540deg)  rotateZ(300deg);  }
    70%  { transform: rotateX(1080deg) rotateY(810deg)  rotateZ(450deg);  }
    85%  { transform: rotateX(1260deg) rotateY(990deg)  rotateZ(540deg);  }
    100% { transform: rotateX(1440deg) rotateY(1080deg) rotateZ(720deg);  }
  }
  #dr-app .die-face {
    position: absolute; width: 90px; height: 90px; border-radius: 14px;
    backface-visibility: hidden; display: grid; place-items: center;
    background: var(--color-bg-surface);
    border: 2px solid var(--color-border-subtle);
    box-shadow: inset 0 1px 3px rgba(255,255,255,0.06), inset 0 -2px 6px rgba(0,0,0,0.35);
  }
  #dr-app .die-face.face-front  { transform: translateZ(45px); }
  #dr-app .die-face.face-back   { transform: rotateY(180deg)  translateZ(45px); }
  #dr-app .die-face.face-right  { transform: rotateY(90deg)   translateZ(45px); }
  #dr-app .die-face.face-left   { transform: rotateY(-90deg)  translateZ(45px); }
  #dr-app .die-face.face-top    { transform: rotateX(90deg)   translateZ(45px); }
  #dr-app .die-face.face-bottom { transform: rotateX(-90deg)  translateZ(45px); }

  /* Pips */
  #dr-app .pip-grid {
    display: grid; width: 68px; height: 68px;
    grid-template-columns: repeat(3,1fr); grid-template-rows: repeat(3,1fr);
    place-items: center;
  }
  #dr-app .pip { width: 11px; height: 11px; border-radius: 50%; background: var(--color-text-primary); box-shadow: 0 1px 2px rgba(0,0,0,0.5); }
  #dr-app .pip.invisible { visibility: hidden; }
  #dr-app .pip.accent { background: var(--color-accent); }

  /* Player name input */
  #dr-app .dr-name-input {
    background: transparent; border: none; border-bottom: 1px solid var(--color-border-subtle);
    color: var(--color-text-muted); font-size: 0.7rem; font-family: monospace;
    text-align: center; width: 90px; outline: none; padding: 2px 0;
    transition: border-color 0.2s, color 0.2s;
  }
  #dr-app .dr-name-input:focus { border-color: var(--color-accent); color: var(--color-text-primary); }

  /* Die value display */
  #dr-app .dr-die-value {
    font-size: 2.5rem; font-weight: 700; font-family: var(--font-heading, sans-serif);
    line-height: 1; min-height: 2.5rem; color: var(--color-text-muted); text-align: center;
    transition: color 0.3s;
  }
</style>

<script>
  // Pip layouts: 9 cells (3×3), true=visible
  const T=true, F=false;
  const PIPS: Record<number,boolean[]> = {
    1:[F,F,F, F,T,F, F,F,F],
    2:[T,F,F, F,F,F, F,F,T],
    3:[T,F,F, F,T,F, F,F,T],
    4:[T,F,T, F,F,F, T,F,T],
    5:[T,F,T, F,T,F, T,F,T],
    6:[T,F,T, T,F,T, T,F,T],
  };
  // Face rotations (rx,ry,rz) so that face VALUE shows as the front face
  // Standard die: 1 opp 6, 2 opp 5, 3 opp 4
  const FACE_ROTATIONS: Record<number,[number,number,number]> = {
    1: [0,    0,   0],
    2: [0,   90,   0],
    3: [-90,  0,   0],
    4: [90,   0,   0],
    5: [0,  -90,   0],
    6: [0,  180,   0],
  };
  // Physical die face layout (fixed — same for every roll)
  // 1 opp 6, 2 opp 5, 3 opp 4; FACE_ROTATIONS[val] brings val's face to the viewer
  const FACE_LAYOUT: Record<string,number> = {front:1, back:6, left:2, right:5, top:3, bottom:4};
  // Which face is visible after applying FACE_ROTATIONS[val]
  const VISIBLE_FACE: Record<number,string> = {1:'front', 2:'left', 3:'top', 4:'bottom', 5:'right', 6:'back'};
  const COLORS = ['var(--color-accent)','#22c55e','#f59e0b','#a855f7'];
  const FACES  = ['front','back','right','left','top','bottom'];

  const makePips = (val: number, accent=false): string =>
    `<div class="pip-grid">${(PIPS[val]||PIPS[1]).map(v=>`<div class="pip${v?(accent?' accent':''):' invisible'}"></div>`).join('')}</div>`;

  const setDieFaces = (id: number, val: number) => {
    const vis = VISIBLE_FACE[val] || 'front';
    FACES.forEach(face => {
      const el = document.getElementById(`dr-face-${face}-${id}`);
      if (el) el.innerHTML = makePips(FACE_LAYOUT[face], face === vis);
    });
  };

  const makeDieHTML = (i: number, name: string): string => `
    <div class="flex flex-col items-center gap-1" id="dr-slot-${i}">
      <input type="text" class="dr-name-input" id="dr-name-${i}" value="${name}" placeholder="Player ${i+1}" maxlength="16"/>
      <div class="die-scene">
        <div class="die-cube" id="dr-cube-${i}">
          ${FACES.map(f=>`<div class="die-face face-${f}" id="dr-face-${f}-${i}"></div>`).join('')}
        </div>
      </div>
      <div class="dr-die-value" id="dr-val-${i}">—</div>
    </div>`;

  const initDr = () => {
    const app = document.getElementById('dr-app');
    if (!app || (app as any)._drInit) return;
    (app as any)._drInit = true;

    const tray       = document.getElementById('dr-tray')!;
    const resultsRow = document.getElementById('dr-results-row')!;
    const indivEl    = document.getElementById('dr-individual-results')!;
    const sumEl      = document.getElementById('dr-sum')!;
    const rollBtn    = document.getElementById('dr-roll-btn')!;
    const histEl     = document.getElementById('dr-history')!;
    const emptyHist  = document.getElementById('dr-history-empty')!;
    const clearHist  = document.getElementById('dr-clear-history')!;
    const statRolls  = document.getElementById('dr-stat-rolls')!;
    const statAvg    = document.getElementById('dr-stat-avg')!;
    const statBest   = document.getElementById('dr-stat-best')!;
    const countBtns  = app.querySelectorAll<HTMLButtonElement>('.dr-count-btn');

    let diceCount = 1;
    let rolling = false;
    let totalRolls = 0, sumOfTotals = 0, bestTotal = 0;
    let playerNames: string[] = ['Player 1','Player 2','Player 3','Player 4'];

    const randD6 = (): number => {
      const a = new Uint32Array(1); crypto.getRandomValues(a); return (a[0] % 6) + 1;
    };

    const getName = (i: number): string => {
      const el = document.getElementById(`dr-name-${i}`) as HTMLInputElement | null;
      return el?.value.trim() || playerNames[i] || `Player ${i+1}`;
    };

    const setCount = (n: number) => {
      // Save current names
      for (let i = 0; i < diceCount; i++) {
        const el = document.getElementById(`dr-name-${i}`) as HTMLInputElement | null;
        if (el) playerNames[i] = el.value;
      }
      diceCount = n;
      countBtns.forEach(b => b.classList.toggle('active', parseInt(b.dataset.count||'1') === n));

      tray.innerHTML = Array.from({length:n},(_,i) => makeDieHTML(i, playerNames[i] || `Player ${i+1}`)).join('');
      for (let i = 0; i < n; i++) setDieFaces(i, 1);

      resultsRow.classList.add('hidden');
      sumEl.textContent = '\u00a0';
      indivEl.innerHTML = '';
    };

    const roll = () => {
      if (rolling) return;
      rolling = true;
      (rollBtn as HTMLButtonElement).disabled = true;

      const results: number[] = Array.from({length:diceCount}, () => randD6());

      results.forEach((val, i) => {
        const cube = document.getElementById(`dr-cube-${i}`)!;
        const [rx, ry, rz] = FACE_ROTATIONS[val];
        // Animation ends at 1440/1080/720 (multiples of 360 → same as 0,0,0)
        // After animation, we snap to face rotation via inline style
        const dur = 0.55 + Math.random() * 0.2 + i * 0.06;

        // Reset: clear any inline overrides, reflow, then let class drive the animation
        cube.classList.remove('rolling');
        cube.style.animation  = '';  // clear inline so class can take over
        cube.style.transition = 'none';
        cube.style.transform  = 'rotateX(0deg) rotateY(0deg) rotateZ(0deg)';
        void cube.offsetWidth; // force reflow
        cube.style.setProperty('--roll-dur', dur + 's');
        cube.classList.add('rolling');

        setTimeout(() => {
          // Lock inline transform to animation-end equivalent before removing class
          cube.style.animation  = 'none'; // inline wins — freezes the cube
          cube.style.transition = 'none';
          cube.style.transform  = 'rotateX(0deg) rotateY(0deg) rotateZ(0deg)';
          cube.classList.remove('rolling');
          // Two rAF frames ensure the locked state is painted before we transition
          requestAnimationFrame(() => requestAnimationFrame(() => {
            cube.style.transition = 'transform 0.15s ease-out';
            cube.style.transform  = `rotateX(${rx}deg) rotateY(${ry}deg) rotateZ(${rz}deg)`;
            setDieFaces(i, val);
            const valEl = document.getElementById(`dr-val-${i}`);
            if (valEl) { valEl.textContent = String(val); valEl.style.color = COLORS[i % COLORS.length]; }
          }));
        }, dur * 1000);
      });

      const maxDur = 0.55 + 0.2 + (diceCount - 1) * 0.06 + 0.25;
      setTimeout(() => {
        const total = results.reduce((s,v)=>s+v,0);

        // Show results
        resultsRow.classList.remove('hidden');
        sumEl.textContent = String(total);

        // Individual breakdown (only show labels if > 1 die)
        if (diceCount > 1) {
          indivEl.innerHTML = results.map((v,i) => `
            <div class="text-center">
              <p class="text-[9px] font-mono text-text-muted mb-0.5 truncate max-w-[80px]">${getName(i)}</p>
              <p class="text-4xl font-heading font-bold leading-none" style="color:${COLORS[i%COLORS.length]}">${v}</p>
            </div>`).join('');
        } else {
          indivEl.innerHTML = '';
        }

        // Stats
        totalRolls++;
        sumOfTotals += total;
        if (total > bestTotal) bestTotal = total;
        statRolls.textContent = String(totalRolls);
        statAvg.textContent   = (sumOfTotals / totalRolls).toFixed(1);
        statBest.textContent  = String(bestTotal);

        // History row
        emptyHist.style.display = 'none';
        const names = Array.from({length:diceCount},(_,i)=>getName(i));
        const detail = diceCount > 1
          ? results.map((v,i)=>`${names[i]}: ${v}`).join(' · ')
          : `${names[0]}: ${results[0]}`;
        const row = document.createElement('div');
        row.className = 'px-4 py-2.5 flex items-center gap-3 text-xs font-mono';
        row.innerHTML = `
          <span class="text-text-muted shrink-0">#${totalRolls}</span>
          <span class="text-text-secondary flex-1 truncate">${detail}</span>
          <span class="font-bold shrink-0" style="color:var(--color-accent)">${total}</span>`;
        histEl.insertBefore(row, histEl.firstChild);

        rolling = false;
        (rollBtn as HTMLButtonElement).disabled = false;
      }, maxDur * 1000);
    };

    rollBtn.addEventListener('click', roll);

    countBtns.forEach(btn => btn.addEventListener('click', () => { if (!rolling) setCount(parseInt(btn.dataset.count||'1')); }));

    clearHist.addEventListener('click', () => {
      [...histEl.querySelectorAll('div:not(#dr-history-empty)')].forEach(el => el.remove());
      emptyHist.style.display = '';
    });

    const onKey = (e: KeyboardEvent) => {
      if (e.key === ' ' && !['INPUT','TEXTAREA','SELECT','BUTTON'].includes((e.target as HTMLElement).tagName)) {
        e.preventDefault(); roll();
      }
    };
    document.addEventListener('keydown', onKey);
    document.addEventListener('astro:before-swap', () => document.removeEventListener('keydown', onKey), {once:true});

    document.addEventListener('app:reset', () => {
      playerNames = ['Player 1','Player 2','Player 3','Player 4'];
      totalRolls=0; sumOfTotals=0; bestTotal=0;
      [...histEl.querySelectorAll('div:not(#dr-history-empty)')].forEach(el=>el.remove());
      emptyHist.style.display='';
      statRolls.textContent='0'; statAvg.textContent='—'; statBest.textContent='—';
      resultsRow.classList.add('hidden');
      setCount(1);
    });

    document.addEventListener('app:copy', async () => {
      const rows = [...histEl.querySelectorAll('div:not(#dr-history-empty)')].slice(0,10)
        .map(r => r.textContent?.trim().replace(/\s+/g,' ') || '');
      try { await navigator.clipboard.writeText(rows.join('\n')); } catch {}
    });

    setCount(1);
  };

  initDr();
  document.addEventListener('astro:after-swap', initDr);
</script>
