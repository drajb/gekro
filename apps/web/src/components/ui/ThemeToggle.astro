---
/**
 * ThemeToggle.astro — Light/dark reader mode toggle button
 *
 * Used in: BlogLayout.astro, ExperimentLayout.astro (top-right corner of articles)
 * NOT used on the homepage, about, contact, or now pages.
 *
 * Theme mechanism:
 *  Toggling adds/removes the `.theme-light` class on `document.body`.
 *  global.css defines CSS variable overrides scoped to `.theme-light body` or
 *  `body.theme-light`, which switches the colour scheme without re-rendering.
 *  The preference is persisted to localStorage under 'reader-theme'.
 *
 * View Transition integration:
 *  Uses document.startViewTransition() (if available) to animate the theme
 *  change with a reveal transition anchored to the click position
 *  (--click-x/--click-y CSS vars set just before the transition).
 *
 * Script type:
 *  is:inline — must run before first paint to prevent FOUC for users with
 *  a cached 'light' preference. Module scripts run after hydration and would
 *  show a flash of dark mode first.
 *
 * data-initialized guard:
 *  Prevents the click handler from being attached twice if setupThemeToggle()
 *  is called multiple times (e.g., after repeated View Transitions on the
 *  same reading page).
 *
 * Non-reading pages:
 *  When the button isn't present (homepage, contact, etc.), setupThemeToggle()
 *  forcibly resets the body to dark mode so light-mode styles don't bleed
 *  from a previous reading page into non-reading pages.
 */
---

<button
  id="theme-toggle"
  class="relative p-2.5 rounded-full border border-border-subtle hover:bg-bg-elevated hover:border-border hover:text-accent transition-all text-text-muted z-50 flex items-center justify-center bg-bg-surface/50 backdrop-blur-sm"
  aria-label="Toggle reader theme"
  title="Toggle Reading Mode"
>
  <!-- Sun Icon (Hidden by default for dark mode) -->
  <svg id="icon-sun" class="w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="4"></circle>
    <path d="M12 2v2"></path>
    <path d="M12 20v2"></path>
    <path d="m4.93 4.93 1.41 1.41"></path>
    <path d="m17.66 17.66 1.41 1.41"></path>
    <path d="M2 12h2"></path>
    <path d="M20 12h2"></path>
    <path d="m6.34 17.66-1.41 1.41"></path>
    <path d="m19.07 4.93-1.41 1.41"></path>
  </svg>
  
  <!-- Moon Icon -->
  <svg id="icon-moon" class="w-4 h-4" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
  </svg>
</button>

<script is:inline>
  const setupThemeToggle = () => {
    const btn = document.getElementById('theme-toggle');
    
    // If the component is not on this page (e.g. user navigated to homepage), force completely dark
    if (!btn) {
      document.body.classList.remove('theme-light', 'bg-bg-base');
      return;
    }

    if (btn.hasAttribute('data-initialized')) return;
    btn.setAttribute('data-initialized', 'true');

    // One-time pulse hint — 3 soft accent pulses on first session visit to a
    // reading page, so new users notice the toggle exists. Gated by
    // sessionStorage so it doesn't replay on every navigation.
    if (!sessionStorage.getItem('theme-toggle-hinted')) {
      sessionStorage.setItem('theme-toggle-hinted', '1');
      btn.classList.add('pulse-hint');
      // Animation is 2s × 3 iterations = 6s; remove class after so it doesn't
      // interfere with future hover box-shadow states
      setTimeout(() => btn.classList.remove('pulse-hint'), 6000);
    }

    const iconSun = document.getElementById('icon-sun');
    const iconMoon = document.getElementById('icon-moon');
    const defaultArticle = document.querySelector('article');
    const proseContainers = document.querySelectorAll('.prose');

    const isLight = localStorage.getItem('reader-theme') === 'light';

    // To prevent layout shift or visual gaps if article doesn't usually have background color,
    // we must dynamically ensure parents don't override the reading experience.
    const updateUI = (light) => {
      if (light) {
        document.body.classList.add('theme-light', 'bg-bg-base');
        if (defaultArticle) defaultArticle.classList.add('bg-bg-base');
        proseContainers.forEach(prose => prose.classList.remove('prose-invert'));
        if (iconMoon && iconSun) {
          iconMoon.classList.add('hidden');
          iconSun.classList.remove('hidden');
        }
      } else {
        document.body.classList.remove('theme-light', 'bg-bg-base');
        if (defaultArticle) defaultArticle.classList.remove('bg-bg-base');
        proseContainers.forEach(prose => prose.classList.add('prose-invert'));
        if (iconMoon && iconSun) {
          iconSun.classList.add('hidden');
          iconMoon.classList.remove('hidden');
        }
      }
    };

    // Apply immediately on mount to prevent FOUC for cached users
    if (isLight) updateUI(true);

    btn.addEventListener('click', (e) => {
      const isCurrentlyLight = document.body.classList.contains('theme-light');
      const nextTheme = !isCurrentlyLight ? 'light' : 'dark';
      
      const x = e.clientX;
      const y = e.clientY;

      document.documentElement.style.setProperty('--click-x', `${x}px`);
      document.documentElement.style.setProperty('--click-y', `${y}px`);

      if (!document.startViewTransition) {
        updateUI(nextTheme === 'light');
        localStorage.setItem('reader-theme', nextTheme);
        return;
      }

      document.startViewTransition(() => {
        updateUI(nextTheme === 'light');
        localStorage.setItem('reader-theme', nextTheme);
      });
    });
  };

  // Ensure execution on Astro page-load lifecycle
  setupThemeToggle();
  document.addEventListener('astro:after-swap', setupThemeToggle);
</script>

<style>
  /* One-time pulse hint on first session visit — 3 soft accent-coloured
     rings emanate from the button to signal that it's interactive.
     Ring grows from 0px to 6px then fades to transparent. Triggered by
     adding .pulse-hint via JS; removed after 6s (2s × 3 iterations). */
  @keyframes theme-toggle-pulse {
    0%, 100% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 40%, transparent);
    }
    50% {
      box-shadow: 0 0 0 6px color-mix(in srgb, var(--color-accent) 0%, transparent);
    }
  }

  #theme-toggle.pulse-hint {
    animation: theme-toggle-pulse 2s ease-in-out 3;
  }

  /* Respect reduced motion — no pulse for users who prefer less movement */
  @media (prefers-reduced-motion: reduce) {
    #theme-toggle.pulse-hint {
      animation: none;
    }
  }
</style>
