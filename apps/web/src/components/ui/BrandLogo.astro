---
/**
 * BrandLogo.astro — Animated orbital brand mark
 *
 * Used in: Header.astro (top-left nav), Footer.astro (brand column)
 *
 * Renders a pulsing "star" circle with an orbiting "planet" circle —
 * a purely CSS animation using @keyframes pulse-slow and orbit.
 * No JavaScript required.
 *
 * Props:
 *  size      — "sm" | "md" | "lg" (maps to Tailwind w/h classes)
 *  className — forwarded to the outer wrapper div for external positioning
 *
 * Colors:
 *  Hardcoded shadow values reference accent colour hex (#3fb1ff).
 *  The core fill and orbit dots use bg-accent (CSS var) so they respond
 *  to any future accent colour change in global.css.
 */

interface Props {
  size?: "sm" | "md" | "lg";
  className?: string;
}

const { size = "md", className = "" } = Astro.props;

const sizes = {
  sm: "w-10 h-10",
  md: "w-14 h-14",
  lg: "w-28 h-28",
};
---

<div class={`relative flex items-center justify-center ${sizes[size]} ${className} select-none`}>
  <!-- The Star (Core) -->
  <div class="absolute w-2/5 h-2/5 bg-accent rounded-full shadow-[0_0_20px_rgba(63,177,255,0.4)] animate-pulse-slow"></div>
  
  <!-- The Planet (Orbit) -->
  <div class="absolute w-full h-full animate-orbit">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/4 h-1/4 bg-accent rounded-full shadow-[0_0_10px_rgba(63,177,255,0.2)]"></div>
  </div>
</div>

<style>
  .animate-pulse-slow {
    animation: pulse-slow 4s ease-in-out infinite;
  }

  .animate-orbit {
    animation: orbit 12s linear infinite;
  }

  @keyframes pulse-slow {
    0%, 100% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.1); opacity: 0.8; }
  }

  @keyframes orbit {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
  }
</style>
