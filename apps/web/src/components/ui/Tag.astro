---
/**
 * Tag.astro — Topic chip / filter badge
 *
 * Used in: blog/index.astro (sidebar filter), index.astro (sidebar chip cloud)
 *
 * Each chip links to /topics/[slug] where slug is the lowercased,
 * hyphenated version of `title` — matching the slug format in topics/[topic].astro.
 *
 * Props:
 *  title  — topic name (used as display text and for URL generation)
 *  count  — optional post count, shown in parentheses at reduced opacity
 *  active — when true, renders with solid accent fill (used for "All Posts")
 *
 * The filter click behaviour (client-side topic filtering on the archive page)
 * is handled by the SearchWidget, not by this component.
 */

interface Props {
  title: string;
  count?: number;
  active?: boolean;
}

const { title, count, active } = Astro.props;
---

<a 
  href={`/topics/${title.toLowerCase().replace(/\s+/g, '-')}`}
  class={`px-4 py-2 rounded-full border transition-all duration-300 font-mono text-sm flex items-center gap-2 ${
    active 
      ? 'bg-accent text-bg-base border-accent' 
      : 'bg-bg-elevated text-text-secondary border-border hover:border-accent hover:text-accent'
  }`}
>
  {title}
  {count !== undefined && (
    <span class={`text-[10px] opacity-60 ${active ? 'text-bg-base' : 'text-text-muted'}`}>
      ({count})
    </span>
  )}
</a>
