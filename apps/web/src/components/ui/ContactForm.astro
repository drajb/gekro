---
/**
 * ContactForm.astro — Contact form with FormSpree backend + Turnstile CAPTCHA
 *
 * Used in: contact.astro
 *
 * Submission:
 *  Posts to FormSpree (endpoint hardcoded: formspree.io/f/mwvrddbr) via fetch.
 *  On success: hides the form, shows the #form-status success overlay.
 *  On failure: shows the #form-error inline error paragraph (never alert()).
 *
 * CAPTCHA:
 *  Cloudflare Turnstile widget rendered when PUBLIC_TURNSTILE_SITE_KEY is set.
 *  The Turnstile API script is loaded via a regular <script> tag (not is:inline)
 *  to avoid blocking the initial render.
 *  If PUBLIC_TURNSTILE_SITE_KEY is missing, the CAPTCHA widget is omitted —
 *  the form still works but is unprotected (acceptable in local dev).
 *
 * Spam protection:
 *  Honeypot field (_gotcha) is hidden via inline style — FormSpree discards
 *  submissions where this field is filled in by bots.
 *
 * View Transitions:
 *  initContactForm() re-attaches the submit handler after each astro:after-swap.
 *  Without this, the form would still submit via native action (Formspree POST)
 *  but lose the async UX, success overlay, and inline error display.
 */

const turnstileSiteKey = import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || '';
---

<div class="p-8 lg:p-12 bg-bg-surface border border-border rounded-2xl space-y-8 relative overflow-hidden group">
  <!-- Subtle background glow -->
  <div class="absolute top-0 right-0 w-64 h-64 bg-accent/5 rounded-full -mr-32 -mt-32 blur-3xl transition-opacity group-hover:opacity-100 opacity-50"></div>
  
  <form 
    action="https://formspree.io/f/mwvrddbr" 
    method="POST"
    id="contact-form"
    class="relative z-10 space-y-8"
  >
    <!-- Honeypot (Spam Protection) -->
    <input type="text" name="_gotcha" style="display:none" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="space-y-2">
        <label for="name" class="text-[10px] uppercase font-mono tracking-widest text-text-muted ml-1">Name</label>
        <input 
          type="text" 
          id="name" 
          name="name" 
          required 
          placeholder="Your Name"
          class="w-full h-12 bg-bg-base border border-border rounded-lg px-4 text-sm text-text-primary focus:border-accent focus:outline-none transition-colors placeholder:text-text-muted/30"
        />
      </div>
      <div class="space-y-2">
        <label for="email" class="text-[10px] uppercase font-mono tracking-widest text-text-muted ml-1">Email Address</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required 
          placeholder="you@domain.com"
          class="w-full h-12 bg-bg-base border border-border rounded-lg px-4 text-sm text-text-primary focus:border-accent focus:outline-none transition-colors placeholder:text-text-muted/30"
        />
      </div>
    </div>

    <div class="space-y-2">
      <label for="message" class="text-[10px] uppercase font-mono tracking-widest text-text-muted ml-1">Message</label>
      <textarea 
        id="message" 
        name="message" 
        rows="6" 
        required 
        placeholder="Tell me about your build..."
        class="w-full bg-bg-base border border-border rounded-lg p-4 text-sm text-text-primary focus:border-accent focus:outline-none transition-colors placeholder:text-text-muted/30 resize-none"
      ></textarea>
    </div>

    <!-- Cloudflare Turnstile -->
    {turnstileSiteKey && (
      <div class="cf-turnstile" data-sitekey={turnstileSiteKey} data-theme="dark"></div>
    )}

    <button 
      type="submit" 
      class="w-full md:w-auto px-12 py-4 bg-accent text-bg-base font-heading font-medium rounded-full hover:bg-white hover:scale-[1.02] active:scale-95 transition-all duration-300"
    >
      Send Message →
    </button>
  </form>

  <!-- Success overlay — shown after a successful Formspree submission -->
  <div id="form-status" class="hidden absolute inset-0 z-20 bg-bg-surface flex flex-col items-center justify-center space-y-4 text-center p-8">
    <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center text-accent text-2xl">✓</div>
    <h3 class="text-2xl font-heading text-text-primary">Message Received</h3>
    <p class="text-sm text-text-secondary max-w-xs px-8">Thanks for reaching out. I'll get back to you shortly.</p>
    <button onclick="document.getElementById('form-status').classList.add('hidden')" class="text-xs font-mono text-accent hover:underline mt-8">Send another</button>
  </div>

  <!-- Inline error message — replaces the jarring alert() on network or API failure -->
  <p id="form-error" class="hidden text-sm text-accent-danger font-mono mt-4" role="alert"></p>
</div>

<script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>

<script>
  // Bound to astro:after-swap so the submit handler re-attaches after any
  // View Transition into /contact. Without this the form still posts to
  // Formspree via native action, but loses the async UX + success overlay.
  function initContactForm() {
    const form = document.getElementById('contact-form') as HTMLFormElement | null;
    const status = document.getElementById('form-status');
    const errorMsg = document.getElementById('form-error');
    if (!form) return;

    const showError = (msg: string) => {
      if (!errorMsg) return;
      errorMsg.textContent = msg;
      errorMsg.classList.remove('hidden');
      // Auto-hide after 6 seconds
      setTimeout(() => errorMsg.classList.add('hidden'), 6000);
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorMsg) errorMsg.classList.add('hidden'); // clear previous error
      const formData = new FormData(form);

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' }
        });

        if (response.ok) {
          status?.classList.remove('hidden');
          form.reset();
        } else {
          showError('Submission failed. Please try again or reach out on LinkedIn.');
        }
      } catch (err) {
        showError('Network error — direct signals might be jammed. Try LinkedIn instead.');
      }
    });
  }

  initContactForm();
  document.addEventListener('astro:after-swap', initContactForm);
</script>
