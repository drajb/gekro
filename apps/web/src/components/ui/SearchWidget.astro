---
/**
 * SearchWidget.astro — Pagefind-powered client-side search
 *
 * Used in: blog/index.astro (top of archive page)
 *
 * Pagefind indexes the built site at postbuild time (after `astro build`).
 * The index lives at /pagefind/ and is not available during `pnpm dev`.
 * In dev mode, the "search unavailable" message is shown instead.
 *
 * Initialisation:
 *  initSearch() fetches /pagefind/pagefind-ui.js to probe availability before
 *  importing it. This avoids an unhandled module error if the index hasn't
 *  been built yet (common in fresh forks / CI environments).
 *
 * Styling:
 *  Pagefind UI CSS variables are overridden to match the site design system.
 *  resetStyles: false prevents Pagefind from injecting its own default styles
 *  that would conflict with the site's Tailwind base.
 *
 * is:inline:
 *  The script uses is:inline so it runs immediately and re-runs on View
 *  Transitions (Astro module scripts run once per page load, not per swap).
 *  The PagefindUI constructor is safe to call multiple times — it replaces
 *  the #pagefind-search container's content on each call.
 */
---
<!--
  Pagefind Search Component
  Pagefind indexes your site at build time (postbuild script).
  This UI loads from /pagefind/pagefind-ui.js — only available after `pnpm build`.
  In dev mode it gracefully degrades to "search unavailable".
-->
<div id="search-wrapper" class="relative w-full max-w-xl mx-auto">
  <div id="pagefind-search"></div>
  {import.meta.env.DEV && (
    <p id="search-unavailable" class="hidden text-sm text-text-muted font-mono text-center py-4">
      Search is available after a production build.
    </p>
  )}
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

<script is:inline>
  const initSearch = async () => {
    // Check if pagefind is available (only after build)
    try {
      const response = await fetch('/pagefind/pagefind-ui.js');
      if (!response.ok) throw new Error('Search not ready');
      
      const { PagefindUI } = await import('/pagefind/pagefind-ui.js');
      new PagefindUI({
        element: '#pagefind-search',
        showSubResults: true,
        showImages: false,
        resetStyles: false,
        excerptLength: 20,
        translations: {
          placeholder: 'Search posts and experiments...',
        }
      });
    } catch (e) {
      console.log('Search initialization delayed or unavailable.');
      document.getElementById('search-unavailable')?.classList.remove('hidden');
    }
  };

  initSearch();
  document.addEventListener('astro:after-swap', initSearch);
</script>

<!-- Pagefind UI variables live in global.css (scoped to #pagefind-search
     and #search-modal-pagefind). Kept there to avoid duplication between
     this widget and the Cmd+K SearchModal. -->
