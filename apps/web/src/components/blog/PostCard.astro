---
/**
 * PostCard.astro — Blog post preview card
 *
 * Used in: blog/index.astro (archive grid), index.astro (recent posts),
 *           topics/[topic].astro (filtered grid), RelatedPosts.astro
 *
 * Props:
 *  post — a FormattedPost-shaped object. `slug` must have a `.current` key
 *          (the Sanity slug shape); local posts are normalised to this shape
 *          by getAllPosts() in lib/utils/posts.ts.
 *
 * Reading time:
 *  Uses post.readingTime if provided (from frontmatter); falls back to
 *  calculateReadingTime(tldr || description) for Sanity posts that omit it.
 *  The fallback is inaccurate for full-length posts — pass readingTime
 *  from frontmatter for accurate values.
 *
 * Mouse glow effect:
 *  CSS custom properties --mouse-x/--mouse-y are updated on mousemove and
 *  consumed by the .glow-layer CSS radial gradient. The gradient is fully
 *  defined in the <style> block — no inline styles needed (prior inline style
 *  was always overridden by the CSS block; fixed 2026-04-15).
 *
 * Entrance animation:
 *  Motion One inView() triggers a fade+slide-up once. _animated flag prevents
 *  re-triggering after initCards() re-runs on astro:after-swap.
 */

import { calculateReadingTime } from '../../lib/utils/reading-time';

interface Props {
  post: {
    title: string;
    description: string;
    slug: { current: string };
    tldr?: string;
    publishedAt: string;
    topics: string[];
    difficulty?: 'Beginner' | 'Intermediate' | 'Advanced';
    readingTime?: number;
    mainImage?: string;
  };
}

const { post } = Astro.props;
const readingTime = post.readingTime || calculateReadingTime(post.tldr || post.description || ""); 
const formattedDate = new Date(post.publishedAt).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a 
  href={`/blog/${post.slug.current}`}
  class="post-card group relative block p-5 md:p-6 bg-bg-surface border border-border rounded-xl transition-all duration-300 hover:border-accent hover:shadow-2xl hover:shadow-accent/5"
>
  <!-- Glow layer — follows the mouse via --mouse-x/--mouse-y CSS vars set by JS.
       Gradient is defined entirely in the <style> block below; no inline style needed. -->
  <div class="glow-layer pointer-events-none absolute -inset-px rounded-xl opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>

  <div class="relative z-10 space-y-4">
    <div class="flex justify-between items-start">
      <div class="flex flex-wrap gap-2">
        {post.topics.map((topic) => (
          <span class="text-[10px] uppercase tracking-wider text-accent font-mono border border-accent/20 px-2 py-0.5 rounded-full bg-accent/5">
            {topic}
          </span>
        ))}
      </div>
      <span class="text-xs text-text-muted font-mono">{readingTime} min read</span>
    </div>

    <div class="space-y-2">
      <h3 class="text-lg md:text-xl font-heading font-medium text-text-primary transition-colors">
        {post.title}
      </h3>
      <p class="text-sm text-text-secondary line-clamp-2 leading-relaxed">
        {post.tldr || post.description}
      </p>
    </div>

    <div class="pt-4 border-t border-border-subtle flex justify-between items-center text-xs text-text-muted">
      <time datetime={post.publishedAt}>{formattedDate}</time>
      <span class="group-hover:translate-x-1 transition-transform text-accent inline-flex items-center gap-1">
        Read More <span class="text-lg">→</span>
      </span>
    </div>
  </div>
</a>

<script>
  import { animate, inView } from "motion";

  const initCards = () => {
    const cards = document.querySelectorAll(".post-card");
    const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    
    cards.forEach((card) => {
      // Entrance animation
      if (!isReducedMotion && !(card as any)._animated) {
        (card as any)._animated = true;
        inView(card, () => {
          animate(
            card,
            { opacity: [0, 1], y: [20, 0] },
            { duration: 0.6, easing: [0.22, 1, 0.36, 1] }
          );
        });
      }

      // Mouse glow + 3D tilt — both driven by the same mousemove handler.
      // Performance: rect is cached on mouseenter (never changes while inside the card).
      // DOM writes are RAF-gated: mousemove only stores coords; a single RAF callback
      // flushes them once per frame — at most 60 writes/s regardless of mouse poll rate.
      if (!(card as any)._glowInitialized) {
        (card as any)._glowInitialized = true;

        let rect = card.getBoundingClientRect();
        let rafPending = false;
        let isHovered = false;
        let pendingX = 0;
        let pendingY = 0;

        // Cache the rect once on entry — far cheaper than per-move getBoundingClientRect()
        card.addEventListener("mouseenter", () => {
          isHovered = true;
          rect = card.getBoundingClientRect();
        });

        card.addEventListener("mousemove", (e: any) => {
          // Store latest coords only — zero DOM reads here
          pendingX = e.clientX - rect.left;
          pendingY = e.clientY - rect.top;

          if (!rafPending) {
            rafPending = true;
            requestAnimationFrame(() => {
              // Guard: mouseleave may have fired in the 16ms window before this runs.
              // Without the check, the RAF would re-apply the tilt after the reset,
              // producing a one-frame flicker.
              if (isHovered) {
                (card as HTMLElement).style.setProperty("--mouse-x", `${pendingX}px`);
                (card as HTMLElement).style.setProperty("--mouse-y", `${pendingY}px`);

                if (!isReducedMotion) {
                  const rotateY = ((pendingX - rect.width / 2) / (rect.width / 2)) * 8;
                  const rotateX = ((rect.height / 2 - pendingY) / (rect.height / 2)) * 8;
                  (card as HTMLElement).style.transform =
                    `perspective(800px) rotateX(${rotateX}deg) rotateY(${rotateY}deg) translateY(-4px)`;
                }
              }
              rafPending = false;
            });
          }
        }, { passive: true });

        card.addEventListener("mouseleave", () => {
          isHovered = false;
          if (!isReducedMotion) {
            (card as HTMLElement).style.transform = '';
          }
        });
      }
    });
  };

  initCards();
  document.addEventListener('astro:after-swap', initCards);
</script>

<style>
  .post-card {
    /* CSS variable used internally — keeps glow intensity in one place */
    --color-glow: color-mix(in srgb, var(--color-accent) 15%, transparent);

    /* 3D tilt setup — preserve-3d enables rotateX/rotateY perspective;
       will-change hints the browser to promote the card to its own layer */
    transform-style: preserve-3d;
    will-change: transform;
  }

  /* Radial gradient glow that follows the cursor.
     --mouse-x / --mouse-y are updated via mousemove in the <script> block.
     Default to 0px so there is no flash if the script hasn't run yet. */
  .glow-layer {
    background: radial-gradient(
      400px circle at var(--mouse-x, 0px) var(--mouse-y, 0px),
      rgba(255, 255, 255, 0.05),
      transparent 40%
    );
  }
</style>
