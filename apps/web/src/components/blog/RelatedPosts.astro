---
/**
 * RelatedPosts.astro — Related posts section at the bottom of a blog post
 *
 * Used in: blog/[slug].astro (rendered inside the article body slot)
 *
 * Algorithm:
 *  1. Exclude the current post (by slug)
 *  2. For each remaining post, count how many topics it shares with the current
 *  3. Keep only posts with at least 1 shared topic
 *  4. Sort descending by sharedTopics count (most relevant first)
 *  5. Take the top 3 results
 *
 * The section is omitted entirely if no related posts are found.
 *
 * Props:
 *  currentSlug   — slug of the current post (to exclude it from results)
 *  currentTopics — topics array of the current post (to match against)
 *  allPosts      — full post list from getAllPosts() (passed from the page,
 *                  not fetched here, to avoid a second Sanity fetch in the
 *                  component tree)
 *
 * readingTime:
 *  Must be included in the allPosts objects so PostCard shows the correct
 *  value from frontmatter rather than re-computing from the short description.
 */

import PostCard from './PostCard.astro';

interface Props {
  currentSlug: string;
  currentTopics: string[];
  allPosts: {
    title: string;
    slug: { current: string };
    description?: string;
    tldr?: string;
    publishedAt: string;
    topics: string[];
    difficulty?: 'Beginner' | 'Intermediate' | 'Advanced';
    // readingTime must be passed through so PostCard shows the correct value
    // from frontmatter rather than re-computing from the short tldr/description
    readingTime?: number;
  }[];
}

const { currentSlug, currentTopics, allPosts } = Astro.props;

// Find posts sharing at least one topic, excluding current
const related = allPosts
  .filter(p => p.slug.current !== currentSlug)
  .map(p => ({
    post: p,
    sharedTopics: p.topics.filter(t => currentTopics.includes(t)).length,
  }))
  .filter(({ sharedTopics }) => sharedTopics > 0)
  .sort((a, b) => b.sharedTopics - a.sharedTopics)
  .slice(0, 3)
  .map(({ post }) => post);
---

{related.length > 0 && (
  <section class="mt-24 pt-16 border-t border-border-subtle space-y-10">
    <div class="space-y-1">
      <h3 class="text-xs font-mono uppercase tracking-[0.2em] text-text-muted">Continue Reading</h3>
      <p class="text-2xl font-heading text-text-primary">Related from the lab</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {related.map(post => <PostCard post={post} />)}
    </div>
  </section>
)}
