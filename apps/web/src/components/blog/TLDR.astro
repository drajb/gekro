---
/**
 * TLDR.astro — TL;DR / summary callout block
 *
 * Used in: blog/[slug].astro (rendered before the first H2, governance rule)
 *
 * The summary content is passed as a <slot /> child, not a prop, so it
 * can contain arbitrary markup (links, code spans, etc.).
 *
 * Governance rule: TLDR must appear before the first H2 in every blog post.
 * This ensures readers and AI crawlers see the summary before the article body.
 *
 * Props:
 *  title — override the default "TL;DR" label (rarely needed)
 *
 * The prose-tldr style removes the bottom margin from the last <p> inside
 * the slot so there is no excess spacing inside the callout box.
 */

interface Props {
  title?: string;
}

const { title = "TL;DR" } = Astro.props;
---

<section 
  aria-label="Summary" 
  class="relative my-12 overflow-hidden rounded-2xl border-l-4 border-accent bg-bg-surface p-8 lg:p-10"
>
  <div class="absolute -right-8 -top-8 h-32 w-32 rounded-full bg-accent/5 blur-3xl"></div>
  
  <div class="relative z-10 space-y-4">
    <h2 class="font-mono text-xs uppercase tracking-[0.2em] text-accent">
      {title}
    </h2>
    <div class="prose-tldr text-lg leading-relaxed text-text-primary italic lg:text-xl">
      <slot />
    </div>
  </div>
</section>

<style>
  .prose-tldr :global(p:last-child) {
    margin-bottom: 0;
  }
</style>
