---
/**
 * HeroCanvasNeural.astro — Full-viewport Three.js neural particle canvas
 *
 * Renders a floating neural-network particle field as the hero background.
 * Used on: homepage, about, contact, now pages.
 *
 * Architecture:
 *  - 150 particles in a 3D bounding box, each with random velocity
 *  - Pairs within CONNECT_DIST (15 units) are linked with semi-transparent lines
 *  - Camera rotates to follow mouse position (smooth lerp, factor 0.05)
 *  - WebGL renderer: pixel ratio capped at 1.5 to protect GPU on HiDPI screens
 *  - AdditiveBlending on both points and lines for the glowing neural look
 *
 * Colors:
 *  Hardcoded hex 0x3fb1ff — THREE.Color cannot consume CSS variables.
 *  This matches --color-accent in global.css. If the accent colour changes,
 *  update these hex literals too.
 *
 * Lifecycle / View Transitions:
 *  - astro:before-swap → destroyThree() — tears down renderer before DOM swap
 *    (prevents WebGL context leak and dangling animation frames)
 *  - astro:after-swap  → startThree()  — re-initialises after each swap
 *  - startThree() defers via requestIdleCallback to protect FCP/TBT
 *
 * Reduced motion:
 *  CSS hides #three-container and shows .fallback-gradient instead.
 *  No JS is disabled — the Three.js script still runs but is invisible.
 *  This is intentional: the script is lightweight and hiding it via CSS
 *  is simpler than JS feature-detecting prefers-reduced-motion.
 */
---
<div id="neural-canvas-container" class="absolute inset-0 z-0 bg-bg-base pointer-events-auto overflow-hidden">
  <div id="three-container" class="w-full h-full"></div>
  <div class="fallback-gradient absolute inset-0 bg-gradient-to-br from-bg-base to-bg-elevated hidden"></div>
</div>

<style>
  #three-container {
    opacity: 0;
    transition: opacity 2s ease;
  }
  #three-container.ready {
    opacity: 1;
  }
  @media (prefers-reduced-motion: reduce) {
    #three-container { display: none !important; }
    .fallback-gradient { display: block !important; }
  }
</style>

<script>
  // Static import is intentional — Three.js is needed immediately for the hero canvas.
  // This is NOT in frontmatter (rule: "never in frontmatter"); Astro bundles it per-page.
  import * as THREE from 'three';

  let renderer: THREE.WebGLRenderer | null = null;
  let scene: THREE.Scene | null = null;
  let camera: THREE.PerspectiveCamera | null = null;
  let points: THREE.Points | null = null;
  let lines: THREE.LineSegments | null = null;
  let animationId: number | null = null;
  let onMouseMoveRef: ((e: MouseEvent) => void) | null = null;
  let onResizeRef: (() => void) | null = null;

  const PARTICLE_COUNT = 150;
  const CONNECT_DIST = 15;
  const BOX_SIZE = 40;

  /**
   * destroyThree — full teardown of the WebGL context and event listeners.
   *
   * Called before each View Transition swap (astro:before-swap) so the old
   * renderer is fully disposed before the DOM is replaced. Without this,
   * navigating between pages that mount HeroCanvasNeural would leak WebGL
   * contexts (browsers cap at ~8–16 contexts per page).
   *
   * forceContextLoss() is required in addition to dispose() to immediately
   * release the GPU context rather than waiting for GC.
   */
  const destroyThree = () => {
    if (animationId !== null) cancelAnimationFrame(animationId);
    if (onMouseMoveRef) window.removeEventListener('mousemove', onMouseMoveRef);
    if (onResizeRef) window.removeEventListener('resize', onResizeRef);
    onMouseMoveRef = null;
    onResizeRef = null;
    if (renderer) {
      renderer.dispose();
      renderer.forceContextLoss();
      renderer.domElement.remove();
    }
    renderer = null;
    scene = null;
    camera = null;
  };

  const initThree = () => {
    destroyThree();

    const container = document.getElementById('three-container');
    if (!container) return;

    scene = new THREE.Scene();
    camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 30;

    renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true, powerPreference: "high-performance" });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 1.5));
    container.appendChild(renderer.domElement);

    // Particles
    const positions = new Float32Array(PARTICLE_COUNT * 3);
    const velocities = new Float32Array(PARTICLE_COUNT * 3);
    
    for (let i = 0; i < PARTICLE_COUNT; i++) {
      positions[i * 3] = (Math.random() - 0.5) * BOX_SIZE;
      positions[i * 3 + 1] = (Math.random() - 0.5) * BOX_SIZE;
      positions[i * 3 + 2] = (Math.random() - 0.5) * BOX_SIZE;

      velocities[i * 3] = (Math.random() - 0.5) * 0.02;
      velocities[i * 3 + 1] = (Math.random() - 0.5) * 0.02;
      velocities[i * 3 + 2] = (Math.random() - 0.5) * 0.02;
    }

    const pointsGeometry = new THREE.BufferGeometry();
    pointsGeometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    
    // Hardcoded hex values required — THREE.Color cannot consume CSS variables.
    // These match --color-accent (#3fb1ff) from global.css.
    const pointsMaterial = new THREE.PointsMaterial({
      color: 0x3fb1ff,
      size: 0.15,
      transparent: true,
      opacity: 0.8,
      blending: THREE.AdditiveBlending
    });

    points = new THREE.Points(pointsGeometry, pointsMaterial);
    scene.add(points);

    // Lines (Connectors)
    const lineMaterial = new THREE.LineBasicMaterial({
      color: 0x3fb1ff,
      transparent: true,
      opacity: 0.1,
      blending: THREE.AdditiveBlending
    });
    
    const linesGeometry = new THREE.BufferGeometry();
    lines = new THREE.LineSegments(linesGeometry, lineMaterial);
    scene.add(lines);

    let mouseX = 0;
    let mouseY = 0;
    let targetX = 0;
    let targetY = 0;

    onMouseMoveRef = (e: MouseEvent) => {
      mouseX = (e.clientX - window.innerWidth / 2) / 100;
      mouseY = (e.clientY - window.innerHeight / 2) / 100;
    };

    window.addEventListener('mousemove', onMouseMoveRef);

    const animate = () => {
      if (!points || !scene || !camera || !renderer) return;
      animationId = requestAnimationFrame(animate);

      // Smooth mouse follow
      targetX += (mouseX - targetX) * 0.05;
      targetY += (mouseY - targetY) * 0.05;
      
      scene.rotation.y = targetX * 0.2;
      scene.rotation.x = -targetY * 0.2;

      const posAttr = points.geometry.attributes.position;
      const linePositions: number[] = [];

      for (let i = 0; i < PARTICLE_COUNT; i++) {
        // Move particles
        posAttr.setX(i, posAttr.getX(i) + velocities[i * 3]);
        posAttr.setY(i, posAttr.getY(i) + velocities[i * 3 + 1]);
        posAttr.setZ(i, posAttr.getZ(i) + velocities[i * 3 + 2]);

        // Box bounce
        if (Math.abs(posAttr.getX(i)) > BOX_SIZE / 2) velocities[i * 3] *= -1;
        if (Math.abs(posAttr.getY(i)) > BOX_SIZE / 2) velocities[i * 3 + 1] *= -1;
        if (Math.abs(posAttr.getZ(i)) > BOX_SIZE / 2) velocities[i * 3 + 2] *= -1;

        // Connections
        for (let j = i + 1; j < PARTICLE_COUNT; j++) {
          const dx = posAttr.getX(i) - posAttr.getX(j);
          const dy = posAttr.getY(i) - posAttr.getY(j);
          const dz = posAttr.getZ(i) - posAttr.getZ(j);
          const dist = Math.sqrt(dx * dx + dy * dy + dz * dz);

          if (dist < CONNECT_DIST) {
            linePositions.push(posAttr.getX(i), posAttr.getY(i), posAttr.getZ(i));
            linePositions.push(posAttr.getX(j), posAttr.getY(j), posAttr.getZ(j));
          }
        }
      }

      posAttr.needsUpdate = true;
      lines.geometry.setAttribute('position', new THREE.Float32BufferAttribute(linePositions, 3));
      
      renderer.render(scene, camera);
    };

    animate();
    container.classList.add('ready');

    onResizeRef = () => {
      if (!camera || !renderer) return;
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
    };
    window.addEventListener('resize', onResizeRef);
  };

  /**
   * startThree — defers initThree() to idle time to protect FCP/TBT.
   *
   * requestIdleCallback fires after the browser finishes painting; the 2000ms
   * timeout is a safety net for browsers that delay idle callbacks indefinitely.
   * Falls back to setTimeout(500) for browsers without requestIdleCallback.
   */
  const startThree = () => {
    if ('requestIdleCallback' in window) {
      requestIdleCallback(() => initThree(), { timeout: 2000 });
    } else {
      setTimeout(initThree, 500);
    }
  };

  // Init on first load; destroy before each swap; re-init after each swap
  startThree();
  document.addEventListener('astro:before-swap', destroyThree);
  document.addEventListener('astro:after-swap', startThree);
</script>
