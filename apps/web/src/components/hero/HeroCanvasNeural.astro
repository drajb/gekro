---
---
<div id="neural-canvas-container" class="absolute inset-0 z-0 bg-bg-base pointer-events-auto overflow-hidden">
  <canvas id="neural-webgl"></canvas>
  <div class="fallback-gradient absolute inset-0 bg-gradient-to-br from-bg-base to-bg-elevated hidden"></div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    #neural-webgl { display: none !important; }
    .fallback-gradient { display: block !important; }
  }
</style>

<script>
  let animFrameId: number | null = null;

  const destroyNeural = () => {
    if (animFrameId !== null) {
      cancelAnimationFrame(animFrameId);
      animFrameId = null;
    }
  };

  const initNeural = () => {
    destroyNeural();

    const canvas = document.getElementById('neural-webgl') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let W = canvas.width = window.innerWidth;
    let H = canvas.height = window.innerHeight;

    const NODE_COUNT = W < 768 ? 45 : 90;
    const MAX_DIST = 200;
    const PACKET_SPEED = 1.8;

    // Force field radii
    const REPEL_RADIUS = 80;    // inner zone: flee
    const ATTRACT_RADIUS = 220; // outer edge of orbit ring

    const COLOR_PACKET_WARM = '#f59e0b';
    const COLOR_PACKET_WHITE = '#e4e4e7';

    interface Node {
      x: number; y: number;
      vx: number; vy: number;
      ox: number; oy: number; // original spawn position (soft home)
      radius: number;
      glow: number;
      glowTarget: number;
      glowTimer: number;
    }
    interface Packet {
      fromIdx: number; toIdx: number;
      t: number; color: string; size: number;
    }

    const nodes: Node[] = [];
    const packets: Packet[] = [];

    for (let i = 0; i < NODE_COUNT; i++) {
      const x = Math.random() * W, y = Math.random() * H;
      nodes.push({
        x, y, ox: x, oy: y,
        vx: (Math.random() - 0.5) * 0.3,
        vy: (Math.random() - 0.5) * 0.3,
        radius: 1.5 + Math.random() * 3,
        glow: 0, glowTarget: 0,
        glowTimer: Math.random() * 200,
      });
    }

    // Spawn a packet — biased toward nodes near the cursor for "activation" feel
    const spawnPacket = (mouse: { x: number; y: number }) => {
      // Weight candidates by proximity to cursor (closer = more likely to fire)
      const weighted = nodes.map((n, i) => {
        const d = Math.hypot(n.x - mouse.x, n.y - mouse.y);
        const weight = d < ATTRACT_RADIUS ? 3 : 1; // 3x more likely near cursor
        return { i, weight };
      });
      // Weighted random selection
      const totalWeight = weighted.reduce((s, w) => s + w.weight, 0);
      let r = Math.random() * totalWeight;
      let fromIdx = 0;
      for (const w of weighted) {
        r -= w.weight;
        if (r <= 0) { fromIdx = w.i; break; }
      }

      const from = nodes[fromIdx];
      const candidates = nodes
        .map((n, i) => ({ i, d: Math.hypot(n.x - from.x, n.y - from.y) }))
        .filter(c => c.i !== fromIdx && c.d < MAX_DIST)
        .sort((a, b) => a.d - b.d);
      if (!candidates.length) return;

      const toIdx = candidates[Math.floor(Math.random() * Math.min(4, candidates.length))].i;
      nodes[fromIdx].glowTarget = 1;
      packets.push({
        fromIdx, toIdx, t: 0,
        color: Math.random() > 0.3 ? COLOR_PACKET_WARM : COLOR_PACKET_WHITE,
        size: 2 + Math.random() * 2.5,
      });
    };

    let mouse = { x: W / 2, y: H / 2 };
    let isMouseOnPage = false;

    const onMouseMove = (e: MouseEvent) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
      isMouseOnPage = true;
    };
    const onMouseLeave = () => { isMouseOnPage = false; };
    const onResize = () => {
      W = canvas.width = window.innerWidth;
      H = canvas.height = window.innerHeight;
    };

    window.addEventListener('mousemove', onMouseMove);
    document.addEventListener('mouseleave', onMouseLeave);
    window.addEventListener('resize', onResize);

    let globalAlpha = 0;
    let frame = 0;

    const tick = () => {
      ctx.clearRect(0, 0, W, H);
      if (globalAlpha < 1) globalAlpha = Math.min(1, globalAlpha + 0.008);
      ctx.globalAlpha = globalAlpha;

      frame++;
      if (frame % 35 === 0) spawnPacket(mouse);

      // --- Update nodes with dual-zone force field ---
      for (const n of nodes) {
        const dx = mouse.x - n.x;
        const dy = mouse.y - n.y;
        const dist = Math.hypot(dx, dy);

        if (isMouseOnPage && dist > 0) {
          if (dist < REPEL_RADIUS) {
            // INNER ZONE: strong repulsion — nodes flee the cursor tip
            const strength = (1 - dist / REPEL_RADIUS) * 0.18;
            n.vx -= (dx / dist) * strength;
            n.vy -= (dy / dist) * strength;
          } else if (dist < ATTRACT_RADIUS) {
            // ORBIT RING: attraction — nodes orbit the cursor from a distance
            // Stronger as they approach the inner boundary
            const t = 1 - (dist - REPEL_RADIUS) / (ATTRACT_RADIUS - REPEL_RADIUS);
            const strength = t * t * 0.012;
            n.vx += (dx / dist) * strength;
            n.vy += (dy / dist) * strength;
          }
        }

        // Soft drift — very gentle pull back toward spawn origin so nodes
        // don't permanently escape after the cursor leaves
        const hx = n.ox - n.x, hy = n.oy - n.y;
        const hDist = Math.hypot(hx, hy);
        if (hDist > 5) {
          n.vx += (hx / hDist) * 0.003;
          n.vy += (hy / hDist) * 0.003;
        }

        // Speed cap + dampen
        const speed = Math.hypot(n.vx, n.vy);
        if (speed > 4) { n.vx = (n.vx / speed) * 4; n.vy = (n.vy / speed) * 4; }
        n.vx *= 0.96; n.vy *= 0.96;
        n.x += n.vx; n.y += n.vy;

        // Soft wrap (don't teleport, just gently push back)
        if (n.x < 0) n.vx += 0.1;
        if (n.x > W) n.vx -= 0.1;
        if (n.y < 0) n.vy += 0.1;
        if (n.y > H) n.vy -= 0.1;

        // Glow pulse timing
        n.glowTimer++;
        if (n.glowTimer > 180 + Math.random() * 120) {
          n.glowTarget = n.glowTarget === 0 ? 1 : 0;
          n.glowTimer = 0;
        }
        n.glow += (n.glowTarget - n.glow) * 0.04;
      }

      // --- Cursor glow (force field origin) ---
      if (isMouseOnPage) {
        // Repel zone — subtle reddish void
        const repelGrad = ctx.createRadialGradient(mouse.x, mouse.y, 0, mouse.x, mouse.y, REPEL_RADIUS);
        repelGrad.addColorStop(0, 'rgba(255, 255, 255, 0.015)');
        repelGrad.addColorStop(1, 'transparent');
        ctx.beginPath();
        ctx.arc(mouse.x, mouse.y, REPEL_RADIUS, 0, Math.PI * 2);
        ctx.fillStyle = repelGrad;
        ctx.fill();

        // Orbit ring — faint amber halo
        const orbitGrad = ctx.createRadialGradient(mouse.x, mouse.y, REPEL_RADIUS, mouse.x, mouse.y, ATTRACT_RADIUS);
        orbitGrad.addColorStop(0, 'rgba(245, 158, 11, 0.02)');
        orbitGrad.addColorStop(1, 'transparent');
        ctx.beginPath();
        ctx.arc(mouse.x, mouse.y, ATTRACT_RADIUS, 0, Math.PI * 2);
        ctx.fillStyle = orbitGrad;
        ctx.fill();
      }

      // --- Draw edges ---
      ctx.lineWidth = 0.5;
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          const d = Math.hypot(nodes[i].x - nodes[j].x, nodes[i].y - nodes[j].y);
          if (d > MAX_DIST) continue;
          const alpha = (1 - d / MAX_DIST) * 0.10;
          ctx.strokeStyle = `rgba(150, 150, 160, ${alpha})`;
          ctx.beginPath();
          ctx.moveTo(nodes[i].x, nodes[i].y);
          ctx.lineTo(nodes[j].x, nodes[j].y);
          ctx.stroke();
        }
      }

      // --- Draw & update packets ---
      for (let i = packets.length - 1; i >= 0; i--) {
        const p = packets[i];
        const from = nodes[p.fromIdx], to = nodes[p.toIdx];
        const d = Math.hypot(from.x - to.x, from.y - to.y);
        if (d > MAX_DIST * 1.4) { packets.splice(i, 1); continue; }
        p.t += PACKET_SPEED / d;
        if (p.t >= 1) { nodes[p.toIdx].glowTarget = 1; packets.splice(i, 1); continue; }

        const px = from.x + (to.x - from.x) * p.t;
        const py = from.y + (to.y - from.y) * p.t;

        const grad = ctx.createRadialGradient(px, py, 0, px, py, p.size * 5);
        grad.addColorStop(0, p.color + '99');
        grad.addColorStop(1, 'transparent');
        ctx.beginPath(); ctx.arc(px, py, p.size * 5, 0, Math.PI * 2);
        ctx.fillStyle = grad; ctx.fill();

        ctx.beginPath(); ctx.arc(px, py, p.size, 0, Math.PI * 2);
        ctx.fillStyle = p.color; ctx.fill();
      }

      // --- Draw nodes ---
      for (const n of nodes) {
        if (n.glow > 0.05) {
          const grd = ctx.createRadialGradient(n.x, n.y, 0, n.x, n.y, n.radius * 9);
          grd.addColorStop(0, `rgba(245, 158, 11, ${0.45 * n.glow})`);
          grd.addColorStop(1, 'transparent');
          ctx.beginPath(); ctx.arc(n.x, n.y, n.radius * 9, 0, Math.PI * 2);
          ctx.fillStyle = grd; ctx.fill();
        }
        ctx.beginPath(); ctx.arc(n.x, n.y, n.radius, 0, Math.PI * 2);
        ctx.fillStyle = n.glow > 0.3
          ? `rgba(245, 158, 11, ${0.4 + n.glow * 0.6})`
          : 'rgba(55, 55, 65, 0.9)';
        ctx.fill();
      }

      animFrameId = requestAnimationFrame(tick);
    };

    animFrameId = requestAnimationFrame(tick);
  };

  document.addEventListener('astro:before-swap', destroyNeural);
  document.addEventListener('astro:after-swap', () => {
    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) initNeural();
  });

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) initNeural();
</script>
