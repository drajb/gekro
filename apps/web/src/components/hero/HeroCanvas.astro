---
---
<div id="hero-canvas-container" class="absolute inset-0 z-0 bg-bg-base pointer-events-auto overflow-hidden">
  <canvas id="hero-webgl"></canvas>
  <div class="fallback-motion absolute inset-0 bg-gradient-to-br from-bg-base to-bg-elevated hidden"></div>
</div>

<style>
  @media (prefers-reduced-motion: reduce) {
    #hero-webgl { display: none !important; }
    .fallback-motion { display: block !important; }
  }
</style>

<script>
  import * as THREE from 'three';
  import heroShader from './hero.glsl?raw';

  // Track the active animation loop and renderer so we can tear them down cleanly
  let animFrameId: number | null = null;
  let activeRenderer: THREE.WebGLRenderer | null = null;

  const destroyThree = () => {
    if (animFrameId !== null) {
      cancelAnimationFrame(animFrameId);
      animFrameId = null;
    }
    if (activeRenderer) {
      activeRenderer.dispose();
      activeRenderer = null;
    }
  };

  const initThree = () => {
    // Always destroy any previous instance first
    destroyThree();

    const canvas = document.getElementById('hero-webgl') as HTMLCanvasElement;
    if (!canvas) return;

    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true });
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    activeRenderer = renderer;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
    camera.position.z = 25;

    // Shader Preparation
    const vertexShader = `#define VERTEX\n${heroShader}`;
    const fragmentShader = `#define FRAGMENT\n${heroShader}`;

    const isMobile = window.innerWidth < 768;
    const particleCount = isMobile ? 12000 : 35000;
    const geometry = new THREE.BufferGeometry();
    const positions = new Float32Array(particleCount * 3);
    const normals = new Float32Array(particleCount * 3);
    const colors = new Float32Array(particleCount * 3);
    const sizes = new Float32Array(particleCount);

    const baseColor = new THREE.Color('#27272a');
    const accentColor = new THREE.Color('#3fb1ff');
    const glowColor = new THREE.Color('#fafafa');

    for (let i = 0; i < particleCount; i++) {
      const theta = 2.0 * Math.PI * Math.random();
      const phi = Math.acos(2.0 * Math.random() - 1.0);
      const r = 12 + Math.random() * 8;
      
      const px = r * Math.sin(phi) * Math.cos(theta);
      const py = r * Math.sin(phi) * Math.sin(theta);
      const pz = r * Math.cos(phi);

      positions[i * 3] = px;
      positions[i * 3 + 1] = py;
      positions[i * 3 + 2] = pz;

      const normal = new THREE.Vector3(px, py, pz).normalize();
      normals[i * 3] = normal.x;
      normals[i * 3 + 1] = normal.y;
      normals[i * 3 + 2] = normal.z;

      const colorRand = Math.random();
      let color = baseColor;
      if (colorRand > 0.98) color = glowColor;
      else if (colorRand > 0.85) color = accentColor;
      
      colors[i * 3] = color.r;
      colors[i * 3 + 1] = color.g;
      colors[i * 3 + 2] = color.b;

      sizes[i] = 0.02 + Math.random() * 0.12;
    }

    geometry.setAttribute('position', new THREE.BufferAttribute(positions, 3));
    geometry.setAttribute('normal', new THREE.BufferAttribute(normals, 3));
    geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));
    geometry.setAttribute('aSize', new THREE.BufferAttribute(sizes, 1));

    const uniforms = {
      uTime: { value: 0 },
      uMouse: { value: new THREE.Vector2(0, 0) },
      uScroll: { value: 0 },
      uPixelRatio: { value: Math.min(window.devicePixelRatio, 2) }
    };

    const material = new THREE.ShaderMaterial({
      vertexShader,
      fragmentShader,
      uniforms,
      transparent: true,
      blending: THREE.AdditiveBlending,
      depthWrite: false
    });

    const particles = new THREE.Points(geometry, material);
    scene.add(particles);

    // Intro animation — only on first load, not after transitions
    particles.scale.set(0, 0, 0);
    import('gsap').then(({ gsap }) => {
      gsap.to(particles.scale, {
        x: 1, y: 1, z: 1,
        duration: 2.5,
        ease: 'expo.out',
        delay: 0.5
      });
    });

    let mouseX = 0;
    let mouseY = 0;
    let targetMouseX = 0;
    let targetMouseY = 0;

    const onMouseMove = (e: MouseEvent) => {
      targetMouseX = (e.clientX / window.innerWidth) * 2 - 1;
      targetMouseY = -(e.clientY / window.innerHeight) * 2 + 1;
    };

    const onScroll = () => {
      const scrollY = window.scrollY;
      const height = window.innerHeight;
      uniforms.uScroll.value = Math.min(scrollY / height, 1.0);
    };

    const onResize = () => {
      camera.aspect = window.innerWidth / window.innerHeight;
      camera.updateProjectionMatrix();
      renderer.setSize(window.innerWidth, window.innerHeight);
      uniforms.uPixelRatio.value = Math.min(window.devicePixelRatio, 2);
    };

    window.addEventListener('mousemove', onMouseMove);
    window.addEventListener('scroll', onScroll);
    window.addEventListener('resize', onResize);

    const clock = new THREE.Clock();

    const tick = () => {
      // Stop the loop if the renderer was disposed (navigation happened)
      if (!activeRenderer) return;

      const elapsedTime = clock.getElapsedTime();
      uniforms.uTime.value = elapsedTime;
      
      mouseX += (targetMouseX - mouseX) * 0.05;
      mouseY += (targetMouseY - mouseY) * 0.05;
      uniforms.uMouse.value.set(mouseX, mouseY);
      
      particles.rotation.y = elapsedTime * 0.03 + uniforms.uScroll.value * 2.0;
      particles.rotation.z = Math.sin(elapsedTime * 0.1) * 0.1;
      
      renderer.render(scene, camera);
      animFrameId = requestAnimationFrame(tick);
    };

    animFrameId = requestAnimationFrame(tick);
  };

  // Tear down before Astro swaps the page to prevent stale loops
  document.addEventListener('astro:before-swap', destroyThree);

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    initThree();
  }
</script>
