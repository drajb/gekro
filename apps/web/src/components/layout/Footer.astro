---
/**
 * Footer.astro — Global site footer
 *
 * Mounted in: BaseLayout.astro (present on every page, below the #swup div)
 *
 * Layout:
 *  Two-column grid at md+ breakpoints:
 *  - Left: brand mark, tagline, social links (LinkedIn / GitHub), copyright,
 *           "System Sync" live clock
 *  - Right: two navigation columns (Navigation + Connect & AI)
 *
 * System Sync clock:
 *  buildTime is computed server-side at build time (SSG). The client-side
 *  updateSyncTime() overrides it immediately on mount and then ticks every
 *  second, so the displayed time is always live. The astro:after-swap listener
 *  re-queries #sync-time after View Transitions (new DOM node).
 *
 * Colors:
 *  All text uses CSS variable classes (text-text-primary, text-text-secondary)
 *  so the footer adapts correctly under the .theme-light reader mode.
 *  text-white was removed in 2026-04-15 bug fix — it bypassed the variable
 *  system and rendered as white-on-white in light mode.
 *
 * DeepWiki badge:
 *  Loaded via Astro <Image> from the DeepWiki CDN URL. If the CDN is
 *  unavailable, the badge simply doesn't render (no alt text fallback shown
 *  because it's decorative).
 */

import { Image } from 'astro:assets';
import BrandLogo from '../ui/BrandLogo.astro';
const currentYear = new Date().getFullYear();
const buildTime = new Date().toLocaleTimeString('en-GB', { 
  hour12: false,
  hour: '2-digit',
  minute: '2-digit',
  second: '2-digit',
  timeZone: 'UTC'
}) + ' UTC';
---

<footer class="relative z-10 w-full bg-bg-base border-t border-border-subtle py-24 px-6 overflow-hidden">
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
  
  <div class="max-w-6xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-16">
    <div class="space-y-8">
      <div class="flex items-center gap-3">
        <BrandLogo size="sm" />
        <span class="text-xl font-heading font-medium text-text-primary">gekro</span>
      </div>
      <p class="text-text-secondary max-w-sm leading-relaxed">
        Personal engineering lab documented by Rohit. Building at the intersection of <span class="text-text-primary">AI agents</span>, <span class="text-text-primary">Tesla telemetry</span>, and <span class="text-text-primary">green infrastructure</span>.
      </p>
      <div class="flex gap-4">
        <a href="https://www.linkedin.com/in/rohitburani/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn profile" class="w-10 h-10 flex items-center justify-center rounded-full border border-border text-text-muted hover:border-accent hover:text-accent transition-all">in</a>
        <a href="https://github.com/drajb" target="_blank" rel="noopener noreferrer" aria-label="GitHub profile" class="w-10 h-10 flex items-center justify-center rounded-full border border-border text-text-muted hover:border-accent hover:text-accent transition-all">gh</a>
      </div>
      <p class="text-[10px] font-mono text-text-muted uppercase tracking-widest pt-4">© {currentYear} gekro.</p>
      <div class="flex items-center gap-2 pt-2">
        <div class="w-1.5 h-1.5 rounded-full bg-accent animate-pulse"></div>
        <p class="text-[9px] font-mono text-text-muted uppercase tracking-widest">
          Last System Sync: <span id="sync-time" class="text-text-secondary">{buildTime}</span>
        </p>
      </div>

      <script>
        const updateSyncTime = () => {
          const now = new Date();
          const time = now.toLocaleTimeString('en-GB', { 
            hour12: false,
            hour: '2-digit',
            minute: '2-digit',
            second: '2-digit',
            timeZone: 'UTC'
          });
          const syncEl = document.getElementById('sync-time');
          if (syncEl) syncEl.innerText = `${time} UTC`;
        };

        // Run on mount
        updateSyncTime();
        setInterval(updateSyncTime, 1000);

        // Re-run after view transitions
        document.addEventListener('astro:after-swap', () => {
          updateSyncTime();
        });
      </script>

      <!-- Discoverability hints — barely visible by design. Signals to power
           users that the backtick terminal and Cmd+K search exist without
           shouting. Opacity-30 / 50 lets them fade into the footer. -->
      <p class="text-[9px] font-mono text-text-muted/30 uppercase tracking-widest pt-2">
        press <kbd class="text-text-muted/50">`</kbd> for terminal &bull; <kbd class="text-text-muted/50">⌘K</kbd> / <kbd class="text-text-muted/50">Ctrl+K</kbd> to search
      </p>
    </div>

    <div class="grid grid-cols-2 gap-8">
      <div class="space-y-6">
        <h4 class="text-xs font-mono uppercase tracking-widest text-text-primary">Navigation</h4>
        <ul class="space-y-4">
          <li><a href="/blog" class="text-sm text-text-secondary hover:text-accent transition-colors">Blog</a></li>
          <li><a href="/experiments" class="text-sm text-text-secondary hover:text-accent transition-colors">Experiments</a></li>
          <li><a href="/about" class="text-sm text-text-secondary hover:text-accent transition-colors">About</a></li>
        </ul>
      </div>
      <div class="space-y-6">
        <h4 class="text-xs font-mono uppercase tracking-widest text-text-primary">Connect & AI</h4>
        <ul class="space-y-4">
          <li><a href="/contact" class="text-sm text-text-secondary hover:text-accent transition-colors">Contact</a></li>
          <li><a href="/llms.txt" class="text-sm text-text-secondary hover:text-accent transition-colors">/llms.txt</a></li>
          <li><a href="/rss.xml" class="text-sm text-text-secondary hover:text-accent transition-colors">RSS Feed</a></li>
          <li class="pt-2">
            <a href="https://deepwiki.com/drajb/gekro" target="_blank" rel="noopener noreferrer" class="inline-block hover:opacity-80 transition-opacity" aria-label="Ask DeepWiki">
              <Image src="https://deepwiki.com/badge.svg" alt="Ask DeepWiki Badge" width={110} height={20} class="h-5 w-auto" />
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

</footer>
