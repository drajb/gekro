---
/**
 * ExperimentLayout.astro — Shell for individual experiment detail pages
 *                          (/experiments/[slug])
 *
 * Extends BaseLayout and provides:
 *  - JSON-LD structured data (TechArticle schema) for SEO
 *  - ReadingProgress scroll bar
 *  - ThemeToggle (light/dark reader mode)
 *  - Experiment meta header: status badge, complexity, stack chips,
 *    start date, and GitHub/return-to-lab link
 *  - Executive Summary callout block
 *  - Prose-styled article slot
 *  - Mermaid diagram rendering (CDN script + JS init)
 *
 * Props:
 *  experiment — Experiment frontmatter object containing:
 *    title, summary, status ('active'|'completed'|'archived'),
 *    difficulty, stack[], startDate, githubUrl? (optional)
 *
 * Mermaid:
 *  Loaded from CDN (mermaid@10). initMermaid() queries Shiki-rendered
 *  `pre[data-language="mermaid"]` blocks, replaces them with rendered SVGs.
 *  The listener is registered once per module execution (not is:inline),
 *  preventing accumulation on repeated visits (bug fixed 2026-04-15).
 */

import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '../components/blog/ReadingProgress.astro';
import JsonLD from '../components/seo/JsonLD.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';

/**
 * ExperimentMeta — the subset of experiment frontmatter this layout reads.
 * Mirrors the `experiments` Zod schema in `content/config.ts`; kept as a
 * local type (rather than re-exporting the Zod-inferred type) so Sanity-fed
 * experiments can satisfy the same shape without importing astro:content.
 */
interface ExperimentMeta {
  title: string;
  summary: string;
  aiSummary?: string;
  status: 'active' | 'completed' | 'archived';
  difficulty: 'Beginner' | 'Intermediate' | 'Advanced';
  stack: string[];
  topics?: string[];
  startDate: string;
  githubUrl?: string;
  slug?: string;
}

interface Props {
  experiment: ExperimentMeta;
}

const { experiment } = Astro.props;

const seoDescription = experiment.aiSummary || experiment.summary;
const slug = experiment.slug;
const ogImage = slug ? `/og/experiments/${slug}.png` : '/og/default.png';
const pageURL = slug ? `https://gekro.com/experiments/${slug}/` : 'https://gekro.com/experiments/';
const absoluteOgImage = `https://gekro.com${ogImage}`;
const primaryTopic = experiment.topics?.[0];

// JSON-LD TechArticle schema — expanded per 2026-04-17 SEO pass
const schema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": experiment.title,
  "description": seoDescription,
  "image": [absoluteOgImage],
  "datePublished": experiment.startDate,
  "dateModified": experiment.startDate,
  "proficiencyLevel": experiment.difficulty,
  "author": {
    "@type": "Person",
    "@id": "https://gekro.com/about/#person",
    "name": "Rohit Burani",
    "url": "https://gekro.com/about/"
  },
  "publisher": {
    "@type": "Organization",
    "@id": "https://gekro.com/#organization",
    "name": "gekro",
    "url": "https://gekro.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://gekro.com/og/default.png",
      "width": 1200,
      "height": 630
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageURL
  },
  ...(experiment.stack?.length ? { "keywords": experiment.stack.join(', ') } : {}),
  ...(primaryTopic ? { "articleSection": primaryTopic } : {}),
};

// BreadcrumbList: Home → Experiments → <experiment title>
const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://gekro.com/" },
    { "@type": "ListItem", "position": 2, "name": "Experiments", "item": "https://gekro.com/experiments/" },
    { "@type": "ListItem", "position": 3, "name": experiment.title, "item": pageURL },
  ],
};
---

<BaseLayout
  title={`${experiment.title} | Labs`}
  description={seoDescription}
  ogImage={ogImage}
  ogType="article"
  publishedTime={experiment.startDate}
  modifiedTime={experiment.startDate}
  author="Rohit Burani"
  section={primaryTopic}
  tags={experiment.stack}
>
  <JsonLD data={schema} />
  <JsonLD data={breadcrumbs} />
  <ReadingProgress />

  <article class="max-w-6xl mx-auto px-6 py-32 relative overflow-hidden rounded-[2rem] transition-colors duration-[400ms]">
    <!-- Theme toggle: top-right, mirrors BlogLayout placement.
         Mobile top-20 clears the fixed header's menu-toggle button that
         lives at the same right-6 / top-4 area on small screens. -->
    <div class="absolute top-20 md:top-8 right-6 md:right-10 z-50">
      <ThemeToggle />
    </div>

    <!-- ── Experiment meta header ── -->
    <header class="space-y-12 mb-24">
      <div class="space-y-6">
        <span class="text-xs font-mono uppercase tracking-[0.3em] text-accent">Experiment Log</span>
        <h1 class="text-5xl lg:text-8xl font-heading font-medium text-text-primary tracking-tighter">
          {experiment.title}
        </h1>
      </div>

      <!-- Status / complexity / stack / date grid -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 border-y border-border-subtle py-8">
        <div>
          <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Status</span>
          <span class="text-sm text-accent uppercase tracking-widest">{experiment.status}</span>
        </div>
        <div>
          <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Complexity</span>
          <span class="text-sm text-text-primary tracking-wide">{experiment.difficulty}</span>
        </div>
        <div>
          <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Stack</span>
          <div class="flex flex-wrap gap-2 pt-1">
            {experiment.stack.map((s) => (
              <span class="text-[10px] bg-bg-elevated px-2 py-0.5 border border-border rounded">{s}</span>
            ))}
          </div>
        </div>
        <div>
          <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Started</span>
          <span class="text-sm text-text-primary">{new Date(experiment.startDate + 'T12:00:00').toLocaleDateString('en-US', { month: 'long', year: 'numeric' })}</span>
        </div>
        <!-- Show GitHub link if provided, otherwise fall back to lab navigation -->
        {experiment.githubUrl ? (
          <div>
            <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Source</span>
            <a href={experiment.githubUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-accent underline flex items-center gap-1">
              GitHub
            </a>
          </div>
        ) : (
          <div>
            <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Lab Navigation</span>
            <a href="/experiments" class="text-sm text-accent hover:underline flex items-center gap-2 text-nowrap">
              ← Return to my lab
            </a>
          </div>
        )}
      </div>
    </header>

    <!-- ── Article body ── -->
    <div class="max-w-4xl mx-auto px-6 py-24">
      <div class="prose prose-invert max-w-none
                  prose-headings:font-heading prose-headings:font-medium
                  prose-h1:text-5xl prose-h1:mb-20
                  prose-h2:text-3xl prose-h2:mt-32 prose-h2:mb-12
                  prose-h3:text-xl prose-h3:mt-16 prose-h3:mb-8
                  prose-p:text-lg prose-p:leading-relaxed prose-p:text-text-secondary prose-p:mb-8
                  prose-li:text-lg prose-li:text-text-secondary
                  prose-strong:text-text-primary prose-strong:font-semibold
                  prose-code:text-accent prose-code:bg-accent/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                  prose-pre:bg-bg-surface prose-pre:border prose-pre:border-border-subtle prose-pre:rounded-2xl
                  prose-img:rounded-2xl prose-img:border prose-img:border-border-subtle
                  prose-hr:border-border-subtle prose-hr:my-24">

        <!-- Executive Summary callout — pulls from experiment.summary frontmatter -->
        <div class="p-8 lg:p-12 bg-bg-surface border border-border rounded-2xl mb-16">
          <h3 class="text-xs uppercase font-mono tracking-widest text-text-muted mb-8">Executive Summary</h3>
          <p class="text-xl lg:text-3xl text-text-primary leading-tight font-heading italic">
            {experiment.summary}
          </p>
        </div>

        <!-- Markdown content rendered here -->
        <slot />
      </div>

      <!-- Return to lab link -->
      <div class="mt-32 pt-16 border-t border-border-subtle">
        <a href="/experiments" class="inline-flex items-center gap-2 text-sm font-mono text-text-muted hover:text-accent transition-colors group">
          <span class="transition-transform group-hover:-translate-x-1">←</span>
          Return to my lab
        </a>
      </div>
    </div>
  </article>

  <!-- ── Mermaid diagram support ────────────────────────────────────────────── -->
  <!-- CDN load; initMermaid() below replaces Shiki-rendered mermaid code blocks -->
  <!-- with live SVG renders after each page load / View Transition.             -->
  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
  <script>
    /**
     * initMermaid — renders `mermaid` fenced code blocks as SVG diagrams.
     *
     * Astro/Shiki wraps fenced code blocks as <pre data-language="mermaid">.
     * We query those, extract the raw text content, and hand it to mermaid.render().
     * The resulting SVG replaces the <pre> element in the DOM.
     *
     * Uses a regular module script (not is:inline) so the astro:after-swap
     * listener is only registered once per session — not once per experiment
     * page visit (which was causing listener stacking, fixed 2026-04-15).
     *
     * Note: mermaid is loaded globally via is:inline CDN script above, so we
     * access it via (window as any).mermaid to satisfy TypeScript.
     */
    const initMermaid = async () => {
      if (typeof (window as any).mermaid === 'undefined') {
        console.error('Mermaid not loaded');
        return;
      }

      const mermaid = (window as any).mermaid;

      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',
        securityLevel: 'loose',
        fontFamily: 'JetBrains Mono, monospace',
      });

      // Target Astro's Shiki-highlighted mermaid code blocks
      const diagrams = document.querySelectorAll('pre[data-language="mermaid"]');
      for (let i = 0; i < diagrams.length; i++) {
        const pre = diagrams[i];
        const content = pre.textContent; // raw text survives Shiki's span wrapping
        if (content) {
          const id = `mermaid-${i}`;
          try {
            const { svg } = await mermaid.render(id, content);

            const wrapper = document.createElement('div');
            wrapper.className = 'mermaid-rendered my-12 flex justify-center bg-bg-surface p-8 rounded-2xl border border-border-subtle overflow-x-auto';
            wrapper.innerHTML = svg;

            pre.replaceWith(wrapper);
          } catch (err) {
            console.error('Mermaid render error:', err);
          }
        }
      }
    };

    initMermaid();
    document.addEventListener('astro:after-swap', initMermaid);
  </script>
</BaseLayout>
