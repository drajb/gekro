---
import BaseLayout from './BaseLayout.astro';
import ReadingProgress from '../components/blog/ReadingProgress.astro';
import JsonLD from '../components/seo/JsonLD.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';

interface Props {
  experiment: any;
}

const { experiment } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": experiment.title,
  "description": experiment.summary,
  "author": {
    "@type": "Person",
    "name": "Rohit"
  }
};
---

<BaseLayout title={`${experiment.title} | Labs`} description={experiment.summary}>
  <JsonLD data={schema} />
  <ReadingProgress />
  
  <article class="max-w-6xl mx-auto px-6 py-32 relative overflow-hidden rounded-[2rem] transition-colors duration-[400ms]">
    <div class="absolute top-8 right-6 md:right-10 z-50">
      <ThemeToggle />
    </div>
    
    <header class="space-y-12 mb-24">
      <div class="space-y-6">
        <span class="text-xs font-mono uppercase tracking-[0.3em] text-accent">Experiment Log</span>
        <h1 class="text-5xl lg:text-8xl font-heading font-medium text-text-primary tracking-tighter">
          {experiment.title}
        </h1>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-5 gap-8 border-y border-border-subtle py-8">
        <div>
          <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Status</span>
          <span class="text-sm text-accent uppercase tracking-widest">{experiment.status}</span>
        </div>
        <div>
          <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Complexity</span>
          <span class="text-sm text-text-primary tracking-wide">{experiment.difficulty}</span>
        </div>
        <div>
          <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Stack</span>
          <div class="flex flex-wrap gap-2 pt-1">
            {experiment.stack.map(s => (
              <span class="text-[10px] bg-bg-elevated px-2 py-0.5 border border-border rounded">{s}</span>
            ))}
          </div>
        </div>
        <div>
          <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Started</span>
          <span class="text-sm text-text-primary">{experiment.startDate}</span>
        </div>
        {experiment.githubUrl ? (
          <div>
            <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Source</span>
            <a href={experiment.githubUrl} target="_blank" rel="noopener noreferrer" class="text-sm text-text-secondary hover:text-accent underline flex items-center gap-1">
              GitHub
            </a>
          </div>
        ) : (
          <div>
             <span class="block text-[10px] uppercase font-mono text-text-muted mb-1">Lab Navigation</span>
             <a href="/experiments" class="text-sm text-accent hover:underline flex items-center gap-2 text-nowrap">
               ← Return to my lab
             </a>
          </div>
        )}
      </div>
    </header>
    
    <div class="max-w-4xl mx-auto px-6 py-24">
      <div class="prose prose-invert max-w-none 
                  prose-headings:font-heading prose-headings:font-medium
                  prose-h1:text-5xl prose-h1:mb-20
                  prose-h2:text-3xl prose-h2:mt-32 prose-h2:mb-12
                  prose-h3:text-xl prose-h3:mt-16 prose-h3:mb-8
                  prose-p:text-lg prose-p:leading-relaxed prose-p:text-text-secondary prose-p:mb-8
                  prose-li:text-lg prose-li:text-text-secondary
                  prose-strong:text-text-primary prose-strong:font-semibold
                  prose-code:text-accent prose-code:bg-accent/5 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded
                  prose-pre:bg-bg-surface prose-pre:border prose-pre:border-border-subtle prose-pre:rounded-2xl
                  prose-img:rounded-2xl prose-img:border prose-img:border-border-subtle
                  prose-hr:border-border-subtle prose-hr:my-24">
        <div class="p-8 lg:p-12 bg-bg-surface border border-border rounded-2xl mb-16">
          <h3 class="text-xs uppercase font-mono tracking-widest text-text-muted mb-8">Executive Summary</h3>
          <p class="text-xl lg:text-3xl text-text-primary leading-tight font-heading italic">
            {experiment.summary}
          </p>
        </div>
        <slot />
      </div>
      
      <div class="mt-32 pt-16 border-t border-border-subtle">
        <a href="/experiments" class="inline-flex items-center gap-2 text-sm font-mono text-text-muted hover:text-accent transition-colors group">
          <span class="transition-transform group-hover:-translate-x-1">←</span>
          Return to my lab
        </a>
      </div>
    </div>
  </article>

  <script is:inline src="https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.min.js"></script>
  <script is:inline>
    const initMermaid = async () => {
      if (typeof mermaid === 'undefined') {
        console.error('Mermaid not loaded');
        return;
      }

      mermaid.initialize({
        startOnLoad: false,
        theme: 'dark',
        securityLevel: 'loose',
        fontFamily: 'JetBrains Mono, monospace',
      });
      
      // Target Astro's Shiki-highlighted code blocks
      const diagrams = document.querySelectorAll('pre[data-language="mermaid"]');
      for (let i = 0; i < diagrams.length; i++) {
        const pre = diagrams[i];
        const content = pre.textContent; // This gets the raw text even from spanned highlighing
        if (content) {
          const id = `mermaid-${i}`;
          try {
            const { svg } = await mermaid.render(id, content);
            
            // Create wrapper
            const wrapper = document.createElement('div');
            wrapper.className = 'mermaid-rendered my-12 flex justify-center bg-bg-surface p-8 rounded-2xl border border-border-subtle overflow-x-auto';
            wrapper.innerHTML = svg;
            
            // Replace the entire <pre> block
            pre.replaceWith(wrapper);
          } catch (err) {
            console.error('Mermaid render error:', err);
          }
        }
      }
    };

    // Run on mount
    initMermaid();
    // Run after view transitions
    document.addEventListener('astro:after-swap', initMermaid);
  </script>
</BaseLayout>
