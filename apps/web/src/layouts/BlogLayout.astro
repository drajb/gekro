---
/**
 * BlogLayout.astro — Shell for individual blog post pages (/blog/[slug])
 *
 * Extends BaseLayout and provides:
 *  - JSON-LD structured data (BlogPosting schema) for SEO / AI citation
 *  - ReadingProgress scroll bar (GSAP ScrollTrigger, re-inits on swap)
 *  - ThemeToggle button (light/dark reader mode, top-right corner)
 *  - PostHeader (title, date, topics, reading time)
 *  - 5-column grid: 4-col article body + 1-col sticky sidebar (TOC + share)
 *  - NewsletterEmbed and GiscusComments below the article
 *  - "Copy Link" button wired via initCopyLink() + astro:after-swap
 *
 * Props:
 *  post     — FormattedPost (local markdown + Sanity union, defined in
 *             `lib/utils/posts.ts`). Includes optional aiSummary/summary so
 *             the local-flattening path in `[slug].astro` keeps full type
 *             information through the layout.
 *  headings — Array of { depth, text, slug } extracted from the post markdown.
 *             Used by PostTOC in the sidebar.
 *
 * SEO description fallback chain: aiSummary → tldr → description → ''
 * This mirrors the same chain used in SEOHead and the JSON-LD schema.
 */

import BaseLayout from './BaseLayout.astro';
import PostHeader from '../components/blog/PostHeader.astro';
import PostTOC from '../components/blog/PostTOC.astro';
import ReadingProgress from '../components/blog/ReadingProgress.astro';
import JsonLD from '../components/seo/JsonLD.astro';
import GiscusComments from '../components/blog/GiscusComments.astro';
import NewsletterEmbed from '../components/ui/NewsletterEmbed.astro';
import ThemeToggle from '../components/ui/ThemeToggle.astro';
import type { FormattedPost } from '../lib/utils/posts';

/**
 * Accepts a `FormattedPost`-shaped object — the flattened union of local
 * Content Collection posts and Sanity posts built by `[slug].astro`. The
 * concrete object may also carry extra pass-through fields from the
 * original Zod-validated frontmatter (summary, etc.) which are already
 * declared as optional on FormattedPost.
 */
interface Heading {
  depth: number;
  text: string;
  slug: string;
}

interface Props {
  post: FormattedPost;
  headings: Heading[];
}

const { post, headings } = Astro.props;

// SEO description: prefer richer AI-optimised summary over the short description field
const seoDescription = post.aiSummary || post.tldr || post.description || '';

// Resolve the post slug in a shape-agnostic way — FormattedPost wraps it in
// {current}, but the local-flatten path in [slug].astro may pass a string.
const postSlug =
  typeof post.slug === 'string' ? post.slug : post.slug?.current;

// Per-post OG image endpoint. The /og/blog/[slug].png route is a prerendered
// endpoint that generates a branded PNG at build time. If the post declared
// its own mainImage, prefer that; otherwise use the dynamic endpoint.
const ogImage =
  post.mainImage
    ? post.mainImage
    : postSlug ? `/og/blog/${postSlug}.png` : '/og/default.png';

const pageURL = `https://gekro.com/blog/${postSlug}/`;
// Primary topic becomes the OG article:section — used by LinkedIn / FB / some
// feed readers for content categorisation.
const primaryTopic = post.topics?.[0];

// JSON-LD BlogPosting schema — expanded per 2026-04-17 SEO pass to include
// image, wordCount, keywords, mainEntityOfPage, dateModified (falls back to
// datePublished if the frontmatter doesn't track modifications separately).
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : `https://gekro.com${ogImage}`;
const wordCount = post.readingTime ? post.readingTime * 200 : undefined;
const schema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": seoDescription,
  "image": [absoluteOgImage],
  "datePublished": post.publishedAt,
  "dateModified": post.updatedAt || post.publishedAt,
  "author": {
    "@type": "Person",
    "@id": "https://gekro.com/about/#person",
    "name": "Rohit Burani",
    "url": "https://gekro.com/about/"
  },
  "publisher": {
    "@type": "Organization",
    "@id": "https://gekro.com/#organization",
    "name": "gekro",
    "url": "https://gekro.com",
    "logo": {
      "@type": "ImageObject",
      "url": "https://gekro.com/og/default.png",
      "width": 1200,
      "height": 630
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": pageURL
  },
  ...(wordCount ? { "wordCount": wordCount } : {}),
  ...(post.topics?.length ? { "keywords": post.topics.join(', ') } : {}),
  ...(primaryTopic ? { "articleSection": primaryTopic } : {}),
};

// BreadcrumbList: Home → Blog → <post title>
const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://gekro.com/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://gekro.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.title, "item": pageURL },
  ],
};
---

<BaseLayout
  title={post.title}
  description={seoDescription}
  ogImage={ogImage}
  ogType="article"
  publishedTime={post.publishedAt}
  modifiedTime={post.updatedAt || post.publishedAt}
  author="Rohit Burani"
  section={primaryTopic}
  tags={post.topics}
>
  <!-- Structured data injected into <head> via a <script type="application/ld+json"> -->
  <JsonLD data={schema} />
  <JsonLD data={breadcrumbs} />

  <!-- Thin accent-coloured bar that grows as you scroll through the article -->
  <ReadingProgress />

  <!-- Max-width container with rounded corners; light theme applies here when toggled -->
  <article class="max-w-6xl mx-auto px-6 relative overflow-hidden rounded-[2rem] transition-colors duration-[400ms]">

    <!-- Theme toggle floated to top-right — only active on reading pages.
         Mobile uses top-20 (80px) to clear the fixed header's menu-toggle
         button (~76px tall with py-4 padding) which lives at the same
         right-6 position and would otherwise stack on top of this button. -->
    <div class="absolute top-20 md:top-8 right-6 md:right-10 z-50">
      <ThemeToggle />
    </div>

    <!-- Title, publish date, topic chips, reading time -->
    <PostHeader
      title={post.title}
      publishedAt={post.publishedAt}
      topics={post.topics || []}
      tldr={post.tldr}
      readingTime={post.readingTime}
    />

    <!-- 5-column grid: article body (4 cols) + sticky sidebar (1 col, lg only) -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 relative">
      <!-- ── Article body ── -->
      <main class="lg:col-span-4 pb-24">
        <slot />
      </main>

      <!-- ── Sticky sidebar: TOC + Share buttons (desktop only) ── -->
      <aside class="hidden lg:block lg:col-span-1 border-l border-border-subtle pl-12 h-fit">
        <div class="sticky top-32 space-y-12">
          <!-- Auto-generated table of contents from H2/H3 headings -->
          <PostTOC headings={headings} />

          <!-- Share section -->
          <div class="space-y-6">
            <h4 class="text-[10px] uppercase font-mono tracking-[0.2em] text-text-muted">Share Post</h4>
            <div class="flex flex-col gap-4">
              <!-- LinkedIn share link — uses the current page URL via encodeURIComponent -->
              <a
                href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.url.toString())}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-xs font-mono text-text-secondary hover:text-accent transition-colors flex items-center gap-2 group"
              >
                <span class="opacity-40 group-hover:opacity-100 transition-opacity">↗</span> LinkedIn
              </a>

              <!-- Copy Link button — JS-powered, wired via initCopyLink() below -->
              <button
                id="copy-link"
                class="text-xs font-mono text-text-secondary hover:text-accent transition-colors flex items-center gap-2 group text-left"
                aria-label="Copy link to post"
              >
                <span class="opacity-40 group-hover:opacity-100 transition-opacity">#</span> Copy Link
              </button>
            </div>
          </div>
        </div>
      </aside>
    </div>

    <!-- Newsletter signup (Beehiiv embed or fallback form) -->
    <NewsletterEmbed />

    <!-- GitHub Discussions comments embed -->
    <GiscusComments />

    <!-- Post footer — thanks message + back-to-blog link -->
    <footer class="mt-16 py-16 border-t border-border-subtle">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8">
        <div class="space-y-2">
          <h4 class="text-xl font-heading text-text-primary">Thanks for reading.</h4>
          <p class="text-sm text-text-secondary">If you enjoyed this, consider sharing it with your network.</p>
        </div>
        <a href="/blog" class="px-8 py-4 border border-border rounded-full hover:border-accent text-sm font-mono transition-all">
          ← Back to Blog
        </a>
      </div>
    </footer>
  </article>

  <script>
    /**
     * initCopyLink — wires the Copy Link sidebar button.
     *
     * Bound to astro:after-swap so the listener re-attaches to the new DOM
     * on every View Transition (post → post navigation). Without this, the
     * button silently no-ops after the first navigation (issue 2026-04-11).
     */
    function initCopyLink() {
      const copyBtn = document.getElementById('copy-link');
      if (!copyBtn) return;

      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText(window.location.href);
          const originalHTML = copyBtn.innerHTML;
          copyBtn.innerHTML = '<span class="text-emerald-400">✓</span> Copied!';
          setTimeout(() => { copyBtn.innerHTML = originalHTML; }, 2000);
        } catch (err) {
          console.error('Failed to copy link:', err);
        }
      });
    }

    initCopyLink();
    document.addEventListener('astro:after-swap', initCopyLink);
  </script>
</BaseLayout>
