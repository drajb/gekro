---
import { ViewTransitions } from 'astro:transitions';
import SEOHead from '../components/seo/SEOHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-CB8NCKPW6Q"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', 'G-CB8NCKPW6Q');
    </script>
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MBGML7FV');</script>
    <!-- End Google Tag Manager -->
    <SEOHead title={title} description={description} />
    <ViewTransitions />
  </head>
  <body class="bg-bg-base text-text-primary selection:bg-accent selection:text-bg-base antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MBGML7FV"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <div id="swup" class="transition-fade">
      <slot />
    </div>
    <Footer />

    <script>
      import { gsap } from 'gsap';

      document.addEventListener('astro:after-swap', () => {
        if (typeof window !== 'undefined') {
          gsap.from('main', {
            opacity: 0,
            y: 20,
            duration: 0.6,
            ease: 'power3.out',
          });
        }
      });
    </script>
  </body>
</html>
