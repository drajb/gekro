---
/**
 * BaseLayout.astro — Root shell for every page on gekro.com
 *
 * Responsibilities:
 *  - Injects <head> (SEO, fonts, GA, GTM, ViewTransitions)
 *  - Wraps page content in the #swup transition container
 *  - Mounts the global fixed Header, Footer, and LabTerminal (the `\`` easter-egg)
 *  - Mounts CursorFollower (custom cursor dot, desktop only)
 *  - Mounts SearchModal (Cmd+K / Ctrl+K Pagefind overlay)
 *  - Runs a GSAP fade-in on <main> after every View Transition swap
 *
 * Props:
 *  title       — page <title> (required; SEOHead appends "| gekro" if not present)
 *  description — meta description (optional; SEOHead uses its own default if absent)
 *
 * Analytics wiring:
 *  - Google Analytics (GA4): env-var driven via PUBLIC_GA_MEASUREMENT_ID
 *  - Google Tag Manager: HARDCODED override (GTM-MBGML7FV) — decision 2026-03-30.
 *    Do NOT convert back to an env var without an "Override" from Rohit.
 *    GTM is deferred 3.5s to protect TBT / FCP (incident 2026-04-01).
 *  - Cloudflare Web Analytics: HARDCODED override (beacon token) — same decision.
 *
 * View Transitions:
 *  Astro's <ViewTransitions /> drives all page-to-page navigation.
 *  Any component that attaches DOM event listeners MUST also listen for
 *  'astro:after-swap' and re-attach them, because the old DOM is replaced
 *  on each transition and inline one-shot scripts do not re-run.
 *  Pattern: call initX() once, then addEventListener('astro:after-swap', initX).
 */

import { ViewTransitions } from 'astro:transitions';
import SEOHead from '../components/seo/SEOHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import LabTerminal from '../components/LabTerminal.astro';
import CursorFollower from '../components/ui/CursorFollower.astro';
import SearchModal from '../components/ui/SearchModal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  section?: string;
  tags?: string[];
}

const {
  title,
  description,
  ogImage,
  ogType,
  publishedTime,
  modifiedTime,
  author,
  section,
  tags,
} = Astro.props;
// GA4 is env-var driven and silently omitted when missing (unlike GTM/CF)
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';
---

<!doctype html>
<html lang="en">
  <head>
    <!-- ─── Google Analytics 4 (env-var driven, omitted if not configured) ─── -->
    {gaId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>}
    {gaId && (
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}

    <!-- ─── Google Tag Manager (deferred 3.5s to protect TBT/FCP) ─────────── -->
    <!-- HARDCODED override — decision 2026-03-30. Do not move to env var.     -->
    <script is:inline>
      setTimeout(function(){
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-MBGML7FV');
      }, 3500);
    </script>
    <!-- ─── End GTM ──────────────────────────────────────────────────────────── -->

    <!-- SEO meta, OG tags, canonical, font loading, AI-discoverability links -->
    <SEOHead
      title={title}
      description={description}
      ogImage={ogImage}
      ogType={ogType}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      author={author}
      section={section}
      tags={tags}
    />

    <!-- Enables SPA-style page transitions using the View Transitions API -->
    <ViewTransitions />
  </head>

  <body class="bg-bg-base text-text-primary selection:bg-accent selection:text-bg-base antialiased">
    <!-- GTM noscript fallback (required for GTM compliance) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MBGML7FV"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <!-- Global sticky header (nav + mobile menu) -->
    <Header />

    <!-- #swup wraps all page-specific slot content and is the View Transitions target -->
    <div id="swup" class="transition-fade">
      <slot />
    </div>

    <!-- Global footer with System Sync heartbeat clock -->
    <Footer />

    <!-- Post-swap GSAP fade: gives each new page a subtle entrance -->
    <script>
      document.addEventListener('astro:after-swap', async () => {
        if (typeof window !== 'undefined') {
          const { gsap } = await import('gsap');
          gsap.from('main', {
            opacity: 0,
            y: 20,
            duration: 0.6,
            ease: 'power3.out',
          });
        }
      });
    </script>

    <!-- ─── Cloudflare Web Analytics ───────────────────────────────────────── -->
    <!-- HARDCODED override — decision 2026-03-30. Do not move to env var.      -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "c5e0a28057dd450da40a567079cc5b40"}'></script>
    <!-- ─── End Cloudflare Web Analytics ────────────────────────────────────── -->

    <!-- Hidden easter-egg terminal — opens with the backtick (`) key -->
    <LabTerminal />

    <!-- Custom cursor dot (desktop only — hidden on touch, mobile, and reduced-motion).
         Mounted outside #swup so it survives View Transitions. -->
    <CursorFollower />

    <!-- Global Cmd+K / Ctrl+K search modal (Pagefind-powered, lazy-loaded).
         Mounted outside #swup so the keydown listener persists across swaps. -->
    <SearchModal />
  </body>
</html>
