---
import { ViewTransitions } from 'astro:transitions';
import SEOHead from '../components/seo/SEOHead.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import LabTerminal from '../components/LabTerminal.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
const gaId = import.meta.env.PUBLIC_GA_MEASUREMENT_ID || '';
---

<!doctype html>
<html lang="en">
  <head>
    {gaId && <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>}
    {gaId && (
      <script is:inline define:vars={{ gaId }}>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', gaId);
      </script>
    )}
    <!-- Google Tag Manager -->
    <script is:inline>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
    new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
    j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
    'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
    })(window,document,'script','dataLayer','GTM-MBGML7FV');</script>
    <!-- End Google Tag Manager -->
    <SEOHead title={title} description={description} />
    <ViewTransitions />
  </head>
  <body class="bg-bg-base text-text-primary selection:bg-accent selection:text-bg-base antialiased">
    <!-- Google Tag Manager (noscript) -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-MBGML7FV"
    height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
    <!-- End Google Tag Manager (noscript) -->
    <Header />
    <div id="swup" class="transition-fade">
      <slot />
    </div>
    <Footer />

    <script>
      document.addEventListener('astro:after-swap', async () => {
        if (typeof window !== 'undefined') {
          const { gsap } = await import('gsap');
          gsap.from('main', {
            opacity: 0,
            y: 20,
            duration: 0.6,
            ease: 'power3.out',
          });
        }
      });
    </script>
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "c5e0a28057dd450da40a567079cc5b40"}'></script>
    <!-- End Cloudflare Web Analytics -->
    <LabTerminal />
  </body>
</html>
