---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Slides | gekro" description="Presentations and keynotes from the lab.">
  <main class="max-w-6xl mx-auto px-6 py-32 space-y-24">
    <header class="space-y-6 max-w-2xl">
      <h1 class="text-5xl lg:text-8xl font-heading font-medium text-text-primary tracking-tighter">
        Slides.
      </h1>
      <p class="text-xl text-text-secondary">
        Technical keynotes, architecture deep-dives, and philosophical frameworks for the AI era.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {[
        { 
          title: "The Agentic Shift", 
          date: "Oct 2025", 
          description: "Moving from Chat interfaces to Autonomous loops.",
          link: "#"
        },
        { 
          title: "Sovereign Engineering", 
          date: "Dec 2025", 
          description: "Building resilient labs that don't depend on Big Tech.",
          link: "#"
        },
        { 
          title: "Physical AI at the Edge", 
          date: "Feb 2026", 
          description: "Connecting local LLMs to hardware telemetry.",
          link: "#"
        }
      ].map(slide => (
        <div class="group relative bg-bg-elevated p-8 rounded-2xl border border-border hover:border-accent transition-all duration-500">
          <div class="absolute inset-0 bg-accent/5 opacity-0 group-hover:opacity-100 transition-opacity"></div>
          <span class="text-xs font-mono text-accent uppercase tracking-widest">{slide.date}</span>
          <h2 class="text-2xl font-heading text-text-primary mt-4 mb-2">{slide.title}</h2>
          <p class="text-sm text-text-secondary leading-relaxed mb-8">{slide.description}</p>
          <a href={slide.link} class="text-xs font-mono text-text-muted hover:text-accent uppercase tracking-widest inline-flex items-center gap-2">
            View Presentation <span class="group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      ))}
    </div>
  </main>
</BaseLayout>
