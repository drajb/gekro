---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCard from '../../components/apps/AppCard.astro';
import JsonLD from '../../components/seo/JsonLD.astro';
import { getCollection } from 'astro:content';

const apps = await getCollection('apps', ({ data }) => data.status !== 'archived');
apps.sort((a, b) => new Date(b.data.publishedAt).getTime() - new Date(a.data.publishedAt).getTime());

const categories = [
  { id: 'all',     label: 'All',     count: apps.length },
  { id: 'ai',      label: 'AI',      count: apps.filter(a => a.data.category === 'ai').length },
  { id: 'finance', label: 'Finance', count: apps.filter(a => a.data.category === 'finance').length },
  { id: 'dev',     label: 'Dev',     count: apps.filter(a => a.data.category === 'dev').length },
  { id: 'trading', label: 'Trading', count: apps.filter(a => a.data.category === 'trading').length },
  { id: 'ev',      label: 'EV',      count: apps.filter(a => a.data.category === 'ev').length },
  { id: 'infra',   label: 'Infra',   count: apps.filter(a => a.data.category === 'infra').length },
].filter(c => c.id === 'all' || c.count > 0);

const uniqueCategories = new Set(apps.map(a => a.data.category)).size;

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://gekro.com/apps/',
  name: 'gekro Apps',
  description: 'Free tools I built for myself. Sourced data. No login.',
  url: 'https://gekro.com/apps/',
  isPartOf: { '@id': 'https://gekro.com/#website' },
  mainEntity: {
    '@type': 'ItemList',
    numberOfItems: apps.length,
    itemListElement: apps.map((app, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      url: `https://gekro.com/apps/${app.slug}/`,
      name: app.data.title,
    })),
  },
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://gekro.com/' },
    { '@type': 'ListItem', position: 2, name: 'Apps', item: 'https://gekro.com/apps/' },
  ],
};
---

<BaseLayout
  title="Apps | gekro"
  description="Free tools I built for myself. Sourced data. No login. Single-session calculators and utilities from an AI engineer's bench."
>
  <JsonLD data={collectionSchema} />
  <JsonLD data={breadcrumbs} />

  <main class="max-w-6xl mx-auto px-6 pt-32 pb-20">

    <!-- Hero -->
    <div class="relative mb-12">
      <!-- Subtle grid bg -->
      <div class="absolute inset-0 -mx-6 -mt-8 rounded-2xl overflow-hidden pointer-events-none opacity-20" aria-hidden="true">
        <div class="absolute inset-0" style="background-image: linear-gradient(var(--color-border-subtle) 1px, transparent 1px), linear-gradient(90deg, var(--color-border-subtle) 1px, transparent 1px); background-size: 40px 40px;"></div>
        <div class="absolute inset-0" style="background: radial-gradient(ellipse 80% 60% at 50% 0%, transparent 40%, var(--color-bg-base) 100%);"></div>
      </div>

      <div class="relative space-y-5">
        <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-accent">Free Tools · No Login · Client-only</p>
        <h1 class="text-5xl lg:text-7xl font-heading font-semibold tracking-tight leading-none">
          <span class="text-text-primary">Engineer's</span><br />
          <span style="background: linear-gradient(135deg, var(--color-text-primary) 0%, var(--color-accent) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">Toolbox</span>
        </h1>

        <p class="text-lg text-text-secondary max-w-xl leading-relaxed">
          Tools I built for my own workflow — now public. Each runs entirely in your browser. Nothing stored anywhere.
        </p>

        <!-- Stats strip -->
        <div class="flex items-center gap-6 pt-2">
          <div class="flex items-baseline gap-1.5">
            <span class="text-3xl font-heading font-bold text-text-primary">{apps.length}</span>
            <span class="text-xs font-mono text-text-muted uppercase tracking-wider">apps</span>
          </div>
          <div class="w-px h-6 bg-border-subtle"></div>
          <div class="flex items-baseline gap-1.5">
            <span class="text-3xl font-heading font-bold text-text-primary">{uniqueCategories}</span>
            <span class="text-xs font-mono text-text-muted uppercase tracking-wider">categories</span>
          </div>
          <div class="w-px h-6 bg-border-subtle"></div>
          <div class="flex items-baseline gap-1.5">
            <span class="text-3xl font-heading font-bold text-text-primary">0</span>
            <span class="text-xs font-mono text-text-muted uppercase tracking-wider">logins</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Search + filter bar -->
    <div class="flex flex-col sm:flex-row gap-3 mb-8">
      <!-- Search -->
      <div class="relative flex-1">
        <input
          type="search"
          id="apps-search"
          placeholder="Search apps…"
          autocomplete="off"
          class="w-full bg-bg-elevated border border-border rounded-xl pl-10 pr-4 py-2.5
                 text-text-primary text-sm font-mono placeholder:text-text-muted
                 focus:outline-none focus:border-accent/40 focus:ring-1 focus:ring-accent/10
                 hover:border-border-subtle transition-colors"
        />
        <span class="absolute left-3.5 top-1/2 -translate-y-1/2 text-text-muted text-sm pointer-events-none">⌕</span>
      </div>

      <!-- Category chips -->
      <div class="flex items-center gap-1.5 flex-wrap">
        {categories.map(cat => (
          <button
            class:list={[
              'filter-chip text-[10px] font-mono uppercase tracking-widest px-3 py-2 rounded-lg border transition-all',
              cat.id === 'all' ? 'active' : '',
            ]}
            data-category={cat.id}
          >
            {cat.label}
            {cat.id !== 'all' && <span class="ml-1 opacity-50">{cat.count}</span>}
          </button>
        ))}
      </div>
    </div>

    <!-- Card grid -->
    {apps.length > 0 ? (
      <div id="apps-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {apps.map(app => (
          <div data-card-wrapper data-category-val={app.data.category}>
            <AppCard
              title={app.data.title}
              job={app.data.job}
              category={app.data.category}
              icon={app.data.icon}
              status={app.data.status}
              slug={app.slug}
              publishedAt={app.data.publishedAt}
            />
          </div>
        ))}
      </div>
    ) : (
      <div class="py-24 text-center border border-dashed border-border rounded-xl">
        <p class="text-text-muted">First app is being calibrated. Check back soon.</p>
      </div>
    )}

    <!-- Empty state for filters -->
    <div id="apps-empty" style="display:none" class="mt-6 py-16 text-center border border-dashed border-border rounded-xl">
      <p class="text-text-muted font-mono text-sm">No apps match that filter.</p>
    </div>

  </main>
</BaseLayout>

<script>
  const initAppsPage = () => {
    const search = document.getElementById('apps-search') as HTMLInputElement | null;
    const chips = document.querySelectorAll<HTMLButtonElement>('.filter-chip');
    const cards = document.querySelectorAll<HTMLElement>('.app-card');
    const emptyState = document.getElementById('apps-empty');
    if (!search) return;

    let activeCategory = 'all';

    const applyFilters = () => {
      const query = search.value.toLowerCase().trim();
      cards.forEach(card => {
        const title = (card.querySelector('h3')?.textContent || '').toLowerCase();
        const job = (card.querySelector('p')?.textContent || '').toLowerCase();
        const category = card.closest<HTMLElement>('[data-card-wrapper]')?.dataset.categoryVal || '';

        const matchesSearch = !query || title.includes(query) || job.includes(query);
        const matchesCategory = activeCategory === 'all' || category === activeCategory;

        const wrapper = card.closest<HTMLElement>('[data-card-wrapper]');
        if (wrapper) wrapper.style.display = matchesSearch && matchesCategory ? '' : 'none';
      });

      const anyVisible = [...cards].some(c => {
        const w = c.closest<HTMLElement>('[data-card-wrapper]');
        return w && w.style.display !== 'none';
      });
      if (emptyState) emptyState.style.display = anyVisible ? 'none' : '';
    };

    search.addEventListener('input', applyFilters);

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        activeCategory = chip.dataset.category || 'all';
        chips.forEach(c => c.classList.toggle('active', c.dataset.category === activeCategory));
        applyFilters();
      });
    });
  };

  initAppsPage();
  document.addEventListener('astro:after-swap', initAppsPage);
</script>

<style>
  .filter-chip {
    background: var(--color-bg-elevated);
    border-color: var(--color-border);
    color: var(--color-text-muted);
  }
  .filter-chip:hover {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    color: var(--color-text-secondary);
  }
  .filter-chip.active {
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
    color: var(--color-accent);
  }
</style>
