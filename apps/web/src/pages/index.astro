---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCanvasNeural from '../components/hero/HeroCanvasNeural.astro';
import HeroText from '../components/hero/HeroText.astro';
import PostCard from '../components/blog/PostCard.astro';
import ExperimentCard from '../components/experiments/ExperimentCard.astro';
import Tag from '../components/ui/Tag.astro';
import { getCollection } from 'astro:content';
import { getAllPosts, getTopicCounts } from '../lib/utils/posts';

// Experiments from Content Collections (#8: no longer hardcoded)
const allExperiments = await getCollection('experiments');
const latestExperiments = allExperiments
  .sort((a, b) => new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime())
  .slice(0, 3);

// Posts from shared utility (#6: eliminated duplicated fetching logic)
const allPosts = await getAllPosts();
const recentPosts = allPosts.slice(0, 3);

// Compute dynamic topics
const topics = getTopicCounts(allPosts).slice(0, 8);
---

<BaseLayout title="gekro | Building at the edge of what's possible">
  <HeroCanvasNeural />
  
  <main class="relative z-10 w-full min-h-screen">
    <HeroText />
    
    <section class="max-w-6xl mx-auto px-6 py-24 space-y-32">
      <!-- Latest Experiments -->
      <div class="space-y-12">
        <div class="flex justify-between items-end border-b border-border-subtle pb-6">
          <div class="space-y-1">
            <h2 class="text-3xl font-heading font-medium text-text-primary">Latest Experiments</h2>
            <p class="text-sm text-text-muted font-mono">technical case studies & lab notes</p>
          </div>
          <a href="/experiments" class="text-sm font-mono text-accent hover:underline">View all →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {latestExperiments.map(exp => (
            <ExperimentCard experiment={exp.data} slug={exp.slug} />
          ))}
        </div>
      </div>

      <!-- Lab Log (Removed per user request) -->

      <!-- Recent Posts & Topics -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <div class="lg:col-span-2 space-y-12">
          <div class="flex justify-between items-end border-b border-border-subtle pb-6">
            <div class="space-y-1">
              <h2 class="text-3xl font-heading font-medium text-text-primary">Recent Posts</h2>
              <p class="text-sm text-text-muted font-mono">thoughts on engineering & AI</p>
            </div>
            <a href="/blog" class="text-sm font-mono text-accent hover:underline">Archive →</a>
          </div>
          <div class="space-y-6">
            {recentPosts.map(post => (
              <PostCard post={post} />
            ))}
          </div>
        </div>

        <!-- Sidebar (Topics & Subscribe) -->
        <aside class="space-y-16">
          <div class="space-y-8">
            <h3 class="text-sm font-mono text-text-muted uppercase tracking-widest">Core Topics</h3>
            <div class="flex flex-wrap gap-3">
              {topics.map(topic => (
                <Tag title={topic.title} count={topic.count} />
              ))}
            </div>
          </div>

          <div class="p-8 bg-bg-surface border border-border rounded-2xl space-y-6 relative overflow-hidden group newsletter-container">
            <div class="absolute top-0 right-0 w-32 h-32 bg-accent/5 rounded-full -mr-16 -mt-16 blur-3xl transition-colors group-hover:bg-accent/10"></div>
            <div class="relative z-10 space-y-4 newsletter-content">
              <h3 class="text-xl font-heading text-text-primary">Lab Updates</h3>
              <p class="text-sm text-text-secondary leading-relaxed">
                Get notified when I build something worth sharing. No spam, only engineering.
              </p>
              <form class="pt-2 space-y-4" id="newsletter-form">
                <input 
                  type="email" 
                  required 
                  placeholder="Email address..." 
                  class="w-full h-11 bg-bg-base border border-border rounded-lg px-4 text-text-primary text-sm focus:outline-none focus:border-accent transition-colors placeholder:text-text-muted/50"
                />
                <button type="submit" class="w-full py-3 bg-accent text-bg-base font-medium rounded-lg hover:bg-white transition-all transform active:scale-[0.98]">
                  Subscribe
                </button>
              </form>
            </div>

            <!-- Success State -->
            <div class="hidden absolute inset-0 bg-bg-surface flex flex-col items-center justify-center p-8 text-center space-y-4 z-20 newsletter-success">
              <div class="w-12 h-12 bg-accent/10 text-accent rounded-full flex items-center justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
              </div>
              <p class="text-sm font-medium text-text-primary">You're on the list!</p>
              <p class="text-xs text-text-muted">Welcome to the lab logs.</p>
            </div>
          </div>
        </aside>
      </div>
    </section>
  </main>

  <script>
    const initHomeAnimations = async () => {
      const { default: gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');

      gsap.registerPlugin(ScrollTrigger);

      const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (isReducedMotion) return;

      // 1. Section Headers Reveal
      gsap.utils.toArray('section > div:first-child').forEach((header: any) => {
        gsap.from(header, {
          scrollTrigger: {
            trigger: header,
            start: "top 90%",
            toggleActions: "play none none none"
          },
          y: 30,
          opacity: 0,
          duration: 1,
          ease: "expo.out"
        });
      });

      // 2. Experiment Cards Stagger
      gsap.from('.experiment-card', {
        scrollTrigger: {
          trigger: '.experiment-card',
          start: "top 95%",
          toggleActions: "play none none none"
        },
        y: 40,
        opacity: 0,
        duration: 0.8,
        stagger: 0.15,
        ease: "power3.out",
        clearProps: "opacity,transform"
      });

      // 3. Post Cards Stagger
      gsap.from('.post-card', {
        scrollTrigger: {
          trigger: '.post-card',
          start: "top 95%",
          toggleActions: "play none none none"
        },
        x: -30,
        opacity: 0,
        duration: 0.8,
        stagger: 0.1,
        ease: "power2.out",
        clearProps: "opacity,transform"
      });

      // 4. Sidebar Elements Reveal
      gsap.from('aside > div', {
        scrollTrigger: {
          trigger: 'aside',
          start: "top 95%",
          toggleActions: "play none none none"
        },
        y: 30,
        opacity: 0,
        duration: 0.8,
        stagger: 0.15,
        ease: "power2.out",
        clearProps: "opacity,transform"
      });
    };

    // Run on first load and after view transitions
    initHomeAnimations();
    document.addEventListener('astro:after-swap', initHomeAnimations);

    // Newsletter Form Logic
    const form = document.getElementById('newsletter-form') as HTMLFormElement;
    const content = document.querySelector('.newsletter-content') as HTMLElement;
    const success = document.querySelector('.newsletter-success') as HTMLElement;

    if (form && content && success) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        // Mock submission
        const button = form.querySelector('button') as HTMLButtonElement;
        const originalText = button.innerText;
        button.innerText = 'Subscribing...';
        button.disabled = true;

        await new Promise(resolve => setTimeout(resolve, 800));

        content.classList.add('opacity-0', 'pointer-events-none');
        success.classList.remove('hidden');
        success.classList.add('flex', 'animate-in', 'fade-in', 'zoom-in-95', 'duration-500');
      });
    }
  </script>
</BaseLayout>
