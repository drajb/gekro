---
/**
 * index.astro — Homepage (/)
 *
 * Layout: BaseLayout with full-viewport Three.js neural-canvas hero
 *
 * Sections (top to bottom):
 *  1. HeroCanvasNeural — Three.js particle field (full-bleed background)
 *  2. HeroText         — GSAP-animated headline + CTA buttons
 *  3. Recent Posts     — 3 latest posts via getAllPosts() + PostCard grid
 *  4. Core Topics      — Topic chips (Tag component) derived from all posts
 *  5. NewsletterEmbed  — Real Beehiiv embed (or fallback form if env missing)
 *  6. Latest Experiments — 3 newest experiments via getCollection('experiments')
 *
 * Data fetching:
 *  - getAllPosts() merges local Content Collections + Sanity (silent fallback)
 *  - getCollection('experiments') is local-only (Sanity not used for experiments)
 *  - getTopicCounts() derives [{title, count}] from consolidated topics
 *
 * Scripts:
 *  - initHomeAnimations(): GSAP ScrollTrigger stagger for section headers,
 *    experiment cards, post cards, and sidebar elements.
 *    Wrapped in requestIdleCallback to protect FCP/TBT (incident 2026-04-01).
 *  - Both startHomeAnimations() and the astro:after-swap listener are needed
 *    because the homepage can be reached both on first load AND via back-navigation.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import HeroCanvasNeural from '../components/hero/HeroCanvasNeural.astro';
import HeroText from '../components/hero/HeroText.astro';
import PostCard from '../components/blog/PostCard.astro';
import ExperimentCard from '../components/experiments/ExperimentCard.astro';
import Tag from '../components/ui/Tag.astro';
import NewsletterEmbed from '../components/ui/NewsletterEmbed.astro';
import { getCollection } from 'astro:content';
import { getAllPosts, getTopicCounts } from '../lib/utils/posts';

// Experiments from Content Collections (local-only, sorted newest-first)
const allExperiments = await getCollection('experiments');
const latestExperiments = allExperiments
  .sort((a, b) => new Date(b.data.startDate).getTime() - new Date(a.data.startDate).getTime())
  .slice(0, 3);

// Posts via shared utility — merges local + Sanity, sorts newest-first
const allPosts = await getAllPosts();
const recentPosts = allPosts.slice(0, 3);

// Derive topic counts for the sidebar chip cloud (top 8 by post count)
const topics = getTopicCounts(allPosts).slice(0, 8);
---

<BaseLayout title="gekro | Building at the edge of what's possible">
  <!-- Full-bleed Three.js particle hero (z-0, behind all content) -->
  <HeroCanvasNeural />

  <main class="relative z-10 w-full min-h-screen">
    <!-- GSAP-animated headline + CTA buttons -->
    <HeroText />

    <section class="max-w-6xl mx-auto px-6 py-24 space-y-32">

      <!-- ── Section 1: Recent Posts + Sidebar ── -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-16">
        <!-- Post list (2/3 width) -->
        <div class="lg:col-span-2 space-y-12">
          <div class="flex justify-between items-end border-b border-border-subtle pb-6">
            <div class="space-y-1">
              <h2 class="text-3xl font-heading font-medium text-text-primary">Recent Posts</h2>
              <p class="text-sm text-text-muted font-mono">thoughts on engineering & AI</p>
            </div>
            <a href="/blog" class="text-sm font-mono text-accent hover:underline">Archive →</a>
          </div>
          <div class="space-y-6">
            {recentPosts.map(post => (
              <PostCard post={post} />
            ))}
          </div>
        </div>

        <!-- Sidebar: topic chips + newsletter (1/3 width) -->
        <aside class="space-y-16">
          <!-- Topic chip cloud -->
          <div class="space-y-8">
            <h3 class="text-sm font-mono text-text-muted uppercase tracking-widest">Core Topics</h3>
            <div class="flex flex-wrap gap-3">
              {topics.map(topic => (
                <Tag title={topic.title} count={topic.count} />
              ))}
            </div>
          </div>

          <!-- Real newsletter embed — uses Beehiiv when PUBLIC_BEEHIIV_PUBLICATION_ID
               is set, otherwise shows the fallback form from NewsletterEmbed.astro.
               Previously this was a mock form that simulated success without sending
               any data anywhere. -->
          <NewsletterEmbed />
        </aside>
      </div>

      <!-- ── Section 2: Latest Experiments ── -->
      <div class="space-y-12">
        <div class="flex justify-between items-end border-b border-border-subtle pb-6">
          <div class="space-y-1">
            <h2 class="text-3xl font-heading font-medium text-text-primary">Latest Experiments</h2>
            <p class="text-sm text-text-muted font-mono">technical case studies & lab notes</p>
          </div>
          <a href="/experiments" class="text-sm font-mono text-accent hover:underline">View all →</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          {latestExperiments.map(exp => (
            <ExperimentCard experiment={exp.data} slug={exp.slug} />
          ))}
        </div>
      </div>
    </section>
  </main>

  <script>
    /**
     * initHomeAnimations — GSAP ScrollTrigger entrance animations for the homepage.
     *
     * 1. Section Headers Reveal — fade-up on scroll
     * 2. Experiment Cards Stagger — fade-up with 0.15s delay between cards
     * 3. Post Cards Stagger     — slide-in from left with 0.1s delay
     * 4. Sidebar Elements       — fade-up with 0.15s delay
     *
     * Skipped entirely if prefers-reduced-motion is set.
     * clearProps: "opacity,transform" ensures cards are fully visible after animation
     * so they don't disappear if ScrollTrigger is killed on navigation.
     */
    const initHomeAnimations = async () => {
      const { default: gsap } = await import('gsap');
      const { ScrollTrigger } = await import('gsap/ScrollTrigger');

      gsap.registerPlugin(ScrollTrigger);

      const isReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (isReducedMotion) return;

      // 1. Section headers reveal
      gsap.utils.toArray('section > div:first-child').forEach((header: any) => {
        gsap.from(header, {
          scrollTrigger: { trigger: header, start: "top 90%", toggleActions: "play none none none" },
          y: 30, opacity: 0, duration: 1, ease: "expo.out"
        });
      });

      // 2. Experiment cards stagger
      gsap.from('.experiment-card', {
        scrollTrigger: { trigger: '.experiment-card', start: "top 95%", toggleActions: "play none none none" },
        y: 40, opacity: 0, duration: 0.8, stagger: 0.15, ease: "power3.out",
        clearProps: "opacity,transform"
      });

      // 3. Post cards slide-in from left
      gsap.from('.post-card', {
        scrollTrigger: { trigger: '.post-card', start: "top 95%", toggleActions: "play none none none" },
        x: -30, opacity: 0, duration: 0.8, stagger: 0.1, ease: "power2.out",
        clearProps: "opacity,transform"
      });

      // 4. Sidebar elements reveal
      gsap.from('aside > div', {
        scrollTrigger: { trigger: 'aside', start: "top 95%", toggleActions: "play none none none" },
        y: 30, opacity: 0, duration: 0.8, stagger: 0.15, ease: "power2.out",
        clearProps: "opacity,transform"
      });
    };

    /**
     * startHomeAnimations — defers initHomeAnimations to idle time so it doesn't
     * block FCP. requestIdleCallback fires after the browser finishes painting;
     * the 2000ms timeout is a fallback for browsers that delay idle callbacks.
     * Incident: 34s TBT on mobile before this deferral was added (2026-04-01).
     */
    const startHomeAnimations = () => {
      if ('requestIdleCallback' in window) {
        requestIdleCallback(() => initHomeAnimations(), { timeout: 2000 });
      } else {
        setTimeout(initHomeAnimations, 500);
      }
    };

    startHomeAnimations();
    document.addEventListener('astro:after-swap', startHomeAnimations);
  </script>
</BaseLayout>
