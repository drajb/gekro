---
import { getCollection } from 'astro:content';
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  
  return experiments.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const experiment = entry.data;
---

<ExperimentLayout experiment={experiment}>
  <div class="prose prose-invert max-w-none">
    <Content />
  </div>

  <div slot="sidebar" class="space-y-12">
    <div class="p-6 bg-bg-surface border border-border rounded-xl space-y-6">
      <h4 class="text-xs uppercase font-mono tracking-widest text-text-muted">Key Takeaways</h4>
      <ul class="space-y-4">
        {experiment.difficulty && (
           <li class="text-sm text-text-secondary flex gap-3">
            <span class="text-accent">•</span>
            Complexity: {experiment.difficulty}
          </li>
        )}
        <li class="text-sm text-text-secondary flex gap-3">
          <span class="text-accent">•</span>
          Status: {experiment.status}
        </li>
      </ul>
      
      <div class="pt-6 border-t border-border mt-6">
        <a href="/experiments" class="text-xs font-mono text-accent hover:underline flex items-center gap-2">
          ← Back to Experiments
        </a>
      </div>
    </div>
  </div>
</ExperimentLayout>
