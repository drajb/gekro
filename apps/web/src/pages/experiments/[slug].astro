---
import { getCollection } from 'astro:content';
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';

export async function getStaticPaths() {
  const experiments = await getCollection('experiments');
  
  return experiments.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const experiment = entry.data;
---

<ExperimentLayout experiment={experiment}>
  <div class="prose prose-invert max-w-none prose-headings:font-heading prose-headings:font-medium prose-h2:text-3xl prose-h2:border-b prose-h2:border-border prose-h2:pb-4 prose-headings:mt-16 prose-headings:mb-8 prose-p:text-lg prose-p:leading-relaxed prose-p:mb-8 prose-pre:my-12 prose-a:text-accent prose-a:no-underline hover:prose-a:underline">
    <Content />
  </div>

</ExperimentLayout>
