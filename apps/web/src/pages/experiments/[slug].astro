---
/**
 * experiments/[slug].astro — Individual experiment detail page (/experiments/[slug])
 *
 * Static generation: getStaticPaths() builds one page per experiment from
 * local Content Collections. Experiments live only in the local collection —
 * they are not stored in Sanity.
 *
 * Rendering:
 *  entry.render() produces the Content component from the experiment's
 *  markdown body. ExperimentLayout wraps it with the meta header, executive
 *  summary callout, Mermaid diagram support, and the "Return to lab" footer.
 *
 * Prose classes:
 *  Applied on the Content wrapper div here (not inside ExperimentLayout) so
 *  future divergence is easy — e.g., a different experiment type could use
 *  a narrower or wider prose block without touching the layout.
 *
 * Mermaid:
 *  Handled inside ExperimentLayout.astro — the CDN script + initMermaid() live
 *  there. No mermaid logic is needed here.
 */

import { getCollection } from 'astro:content';
import ExperimentLayout from '../../layouts/ExperimentLayout.astro';

export async function getStaticPaths() {
  // All experiments are local-only (no Sanity counterpart)
  const experiments = await getCollection('experiments');

  return experiments.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
// Render markdown content to the Content component
const { Content } = await entry.render();
// Flatten frontmatter for ExperimentLayout props
const experiment = entry.data;
---

<ExperimentLayout experiment={experiment}>
  <!-- Prose wrapper: matches BlogLayout styles for visual consistency across reading pages -->
  <div class="prose prose-invert max-w-none
              prose-headings:font-heading prose-headings:font-medium
              prose-h2:text-3xl prose-h2:border-b prose-h2:border-border prose-h2:pb-4
              prose-headings:mt-16 prose-headings:mb-8
              prose-p:text-lg prose-p:leading-relaxed prose-p:mb-8
              prose-pre:my-12
              prose-a:text-accent prose-a:no-underline hover:prose-a:underline">
    <Content />
  </div>
</ExperimentLayout>
