---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import ExperimentCard from '../../components/experiments/ExperimentCard.astro';
import { client } from '../../lib/sanity/client';
import { ALL_POSTS_QUERY, ALL_EXPERIMENTS_QUERY } from '../../lib/sanity/queries';

export async function getStaticPaths() {
  const localPosts = await getCollection('blog');
  let allTopics = new Set<string>();

  localPosts.forEach(post => {
    post.data.topics?.forEach(t => allTopics.add(t));
  });

  try {
    const sanityPosts = await client.fetch(ALL_POSTS_QUERY);
    sanityPosts.forEach((post: any) => {
      post.topics?.forEach((t: string) => allTopics.add(t));
    });
  } catch (e) {
    console.warn("Sanity topics fetch failed", e);
  }

  return Array.from(allTopics).map(topic => ({
    params: { topic: topic.toLowerCase().replace(/\s+/g, '-') },
    props: { topicName: topic },
  }));
}

const { topicName } = Astro.props;

import { getCollection } from 'astro:content';

const localPosts = await getCollection('blog');
let relatedPosts = [];

try {
  const sanityPosts = await client.fetch(ALL_POSTS_QUERY);
  
  const formattedLocal = localPosts.map(p => ({
    title: p.data.title,
    slug: { current: p.slug },
    description: p.data.description || p.data.summary || "",
    tldr: p.data.tldr || p.data.description || p.data.summary || "",
    publishedAt: p.data.publishedAt,
    topics: p.data.topics,
  }));

  relatedPosts = [...sanityPosts, ...formattedLocal]
    .filter(post => post.topics.some((t: string) => t.toLowerCase() === topicName.toLowerCase()))
    .sort((a, b) => new Date(b.publishedAt).getTime() - new Date(a.publishedAt).getTime());
} catch (e) {
  relatedPosts = localPosts
    .filter(p => p.data.topics.some(t => t.toLowerCase() === topicName.toLowerCase()))
    .map(p => ({
      title: p.data.title,
      slug: { current: p.slug },
      description: p.data.description || p.data.summary || "",
      tldr: p.data.tldr || p.data.description || p.data.summary || "",
      publishedAt: p.data.publishedAt,
      topics: p.data.topics,
    }));
}
---

<BaseLayout title={`${topicName} | gekro`} description={`Explore all articles and experiments related to ${topicName}.`}>
  <main class="max-w-6xl mx-auto px-6 py-32 space-y-24">
    <header class="space-y-4">
      <span class="text-xs font-mono uppercase tracking-widest text-accent">Topic Cluster</span>
      <h1 class="text-4xl lg:text-7xl font-heading font-medium text-text-primary tracking-tighter">
        {topicName}
      </h1>
      <p class="text-text-secondary text-lg max-w-xl italic">
        Curated collection of thoughts and builds centered around {topicName}.
      </p>
    </header>

    <div class="space-y-16">
      <div class="space-y-8">
        <h2 class="text-2xl font-heading text-text-primary border-b border-border pb-4">Written Content</h2>
        {relatedPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {relatedPosts.map(post => <PostCard post={post} />)}
          </div>
        ) : (
          <div class="py-12 text-center border border-dashed border-border rounded-xl">
            <p class="text-text-muted">No articles found in this cluster yet. Stay tuned.</p>
          </div>
        )}
      </div>
      
      <!-- Potentially related experiments here if any -->
    </div>

    <div class="pt-24 border-t border-border-subtle">
      <a href="/blog" class="text-sm font-mono text-accent hover:underline">← Back to Archive</a>
    </div>
  </main>
</BaseLayout>
