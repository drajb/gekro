---
/**
 * topics/[topic].astro — Topic cluster page (/topics/[topic])
 *
 * Static generation: getStaticPaths() derives one page per unique topic slug
 * from all posts. Topics are extracted from the `topics` array on each post
 * and normalised to slug format (lowercase, spaces → hyphens).
 *
 * Rendering:
 *  - `topicName` is the raw display name passed as a prop (not the slug).
 *  - `relatedPosts` filters the full post list to those whose `topics` array
 *    contains topicName (case-insensitive match).
 *  - Experiments are not filtered here yet — a stub comment marks where they
 *    could be added in the future.
 *
 * Data:
 *  getAllPosts() is called twice: once in getStaticPaths() to build the path
 *  list, and once in the component body to get the filtered post list.
 *  This is an acceptable double-fetch for a static site — Astro deduplicates
 *  Content Collection reads via its internal cache at build time.
 */

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import ExperimentCard from '../../components/experiments/ExperimentCard.astro';
import JsonLD from '../../components/seo/JsonLD.astro';
import { getAllPosts } from '../../lib/utils/posts';

export async function getStaticPaths() {
  const allPosts = await getAllPosts();
  // Collect every unique topic name across all posts
  const allTopics = new Set<string>();

  allPosts.forEach(post => {
    post.topics?.forEach((t: string) => allTopics.add(t));
  });

  // Slugify topic name for the URL param; store raw name as prop for display
  return Array.from(allTopics).map(topic => ({
    params: { topic: topic.toLowerCase().replace(/\s+/g, '-') },
    props: { topicName: topic },
  }));
}

const { topicName } = Astro.props;
const topicSlug = topicName.toLowerCase().replace(/\s+/g, '-');
const topicURL = `https://gekro.com/topics/${topicSlug}/`;

// Filter posts: case-insensitive match against the raw topic name
const allPosts = await getAllPosts();
const relatedPosts = allPosts
  .filter(post => post.topics.some((t: string) => t.toLowerCase() === topicName.toLowerCase()));

// CollectionPage schema — tells Google this page is an index of related
// articles. Paired with ItemList of the posts so AI answer engines can
// enumerate what's in the topic cluster without scraping the DOM.
const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "@id": topicURL,
  "name": `${topicName} — gekro topic cluster`,
  "description": `Curated collection of articles and experiments on ${topicName} from gekro.com.`,
  "url": topicURL,
  "isPartOf": { "@id": "https://gekro.com/#website" },
  "mainEntity": {
    "@type": "ItemList",
    "numberOfItems": relatedPosts.length,
    "itemListElement": relatedPosts.map((post, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://gekro.com/blog/${post.slug.current}/`,
      "name": post.title,
    })),
  },
};

const breadcrumbs = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://gekro.com/" },
    { "@type": "ListItem", "position": 2, "name": "Topics", "item": "https://gekro.com/topics/" },
    { "@type": "ListItem", "position": 3, "name": topicName, "item": topicURL },
  ],
};
---

<BaseLayout title={`${topicName} — posts & experiments | gekro`} description={`${relatedPosts.length} article${relatedPosts.length !== 1 ? 's' : ''} on ${topicName} from gekro.com — deep dives, architecture walkthroughs, and engineering post-mortems by Rohit Burani.`}>
  <JsonLD data={collectionSchema} />
  <JsonLD data={breadcrumbs} />
  <main class="max-w-6xl mx-auto px-6 py-32 space-y-24">

    <!-- ── Topic cluster header ── -->
    <header class="space-y-4">
      <span class="text-xs font-mono uppercase tracking-widest text-accent">Topic Cluster</span>
      <h1 class="text-4xl lg:text-7xl font-heading font-medium text-text-primary tracking-tighter">
        {topicName}
      </h1>
      <p class="text-text-secondary text-lg max-w-xl italic">
        Curated collection of thoughts and builds centered around {topicName}.
      </p>
    </header>

    <!-- ── Related content sections ── -->
    <div class="space-y-16">

      <!-- Written content: filtered post cards, 2-column grid -->
      <div class="space-y-8">
        <h2 class="text-2xl font-heading text-text-primary border-b border-border pb-4">Written Content</h2>
        {relatedPosts.length > 0 ? (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            {relatedPosts.map(post => <PostCard post={post} />)}
          </div>
        ) : (
          // Empty state: no posts match this topic yet
          <div class="py-12 text-center border border-dashed border-border rounded-xl">
            <p class="text-text-muted">No articles found in this cluster yet. Stay tuned.</p>
          </div>
        )}
      </div>

      <!-- TODO: Add related experiments section when experiments support topics -->
    </div>

    <!-- ── Back to archive ── -->
    <div class="pt-24 border-t border-border-subtle">
      <a href="/blog" class="text-sm font-mono text-accent hover:underline">← Back to Archive</a>
    </div>
  </main>
</BaseLayout>
